<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <title>@ViewData["Title"] - CareerPath Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>

    <link href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.4.0/dist/css/tabler.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet"/>

    <style>
        .navbar-brand { font-weight: 800; }
        .admin-logo { font-size: 22px; }
        .table-actions { white-space: nowrap; }
    </style>
</head>

<body>
<div class="page">

    <aside class="navbar navbar-vertical navbar-expand-lg" data-bs-theme="dark">
        <div class="container-fluid">
            <h1 class="navbar-brand navbar-brand-autodark">
                <a asp-controller="Admin" asp-action="Dashboard" class="text-white text-decoration-none">
                    <i class="ti ti-school admin-logo me-2"></i>
                    CareerPath
                </a>
            </h1>

            <div class="collapse navbar-collapse show">
                <ul class="navbar-nav pt-lg-3">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                            <span class="nav-link-icon"><i class="ti ti-dashboard"></i></span>
                            <span class="nav-link-title">Dashboard</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Users">
                            <span class="nav-link-icon"><i class="ti ti-users"></i></span>
                            <span class="nav-link-title">Users</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Mentors">
                            <span class="nav-link-icon"><i class="ti ti-user-star"></i></span>
                            <span class="nav-link-title">Mentors</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="CareerTests">
                            <span class="nav-link-icon"><i class="ti ti-clipboard-check"></i></span>
                            <span class="nav-link-title">Career Tests</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Jobs">
                            <span class="nav-link-icon"><i class="ti ti-briefcase"></i></span>
                            <span class="nav-link-title">Jobs</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Resources">
                            <span class="nav-link-icon"><i class="ti ti-books"></i></span>
                            <span class="nav-link-title">Resources</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Reports">
                            <span class="nav-link-icon"><i class="ti ti-chart-bar"></i></span>
                            <span class="nav-link-title">Reports</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Settings">
                            <span class="nav-link-icon"><i class="ti ti-settings"></i></span>
                            <span class="nav-link-title">Settings</span>
                        </a>
                    </li>

                    <li class="nav-item mt-3">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <span class="nav-link-icon"><i class="ti ti-arrow-left"></i></span>
                            <span class="nav-link-title">Back to Website</span>
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </aside>

    <div class="page-wrapper">

        <header class="navbar navbar-expand-md d-print-none">
            <div class="container-xl">
                <div class="navbar-nav flex-row order-md-last ms-auto">
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link d-flex lh-1 text-reset p-0" data-bs-toggle="dropdown">
                            <span class="avatar avatar-sm">AD</span>
                            <div class="d-none d-xl-block ps-2">
                                <div>Admin</div>
                                <div class="mt-1 small text-muted">CareerPath Manager</div>
                            </div>
                        </a>

                        <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                            <a class="dropdown-item" href="#">Profile</a>
                            <a class="dropdown-item" asp-controller="Admin" asp-action="Settings">Settings</a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" asp-controller="Home" asp-action="Index">Logout Demo</a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="page-body">
            <div class="container-xl">
                @RenderBody()
            </div>
        </div>

        <footer class="footer footer-transparent d-print-none">
            <div class="container-xl text-center text-muted">
                © 2026 CareerPath Admin Demo
            </div>
        </footer>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.4.0/dist/js/tabler.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
@RenderSection("Scripts", required: false)

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 