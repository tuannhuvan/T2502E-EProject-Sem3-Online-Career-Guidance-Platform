@{
    var langCookie = Context.Request.Cookies["selected_lang"];
    var isEn = langCookie == "en";
}
<!doctype html>
<html lang="@(isEn ? "en" : "vi")">
<head>
    <meta charset="utf-8"/>
    <title>@ViewData["Title"] - CareerPath Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>

    <link href="@("https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css")" rel="stylesheet"/>
    <link href="@("https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css")" rel="stylesheet"/>

    <style>
        .navbar-brand { font-weight: 800; }
        .admin-logo { font-size: 22px; }
        .table-actions { white-space: nowrap; }

        @@media print {
            .page-wrapper {
                margin-left: 0 !important;
            }
        }
    </style>
</head>

<body>
<div class="page">

    <aside class="navbar navbar-vertical navbar-expand-lg d-print-none" data-bs-theme="dark">
        <div class="container-fluid">
            <h1 class="navbar-brand navbar-brand-autodark">
                <a asp-controller="Admin" asp-action="Dashboard" class="text-white text-decoration-none">
                    <i class="ti ti-school admin-logo me-2"></i>
                    CareerPath
                </a>
            </h1>

            <div class="collapse navbar-collapse show">
                <ul class="navbar-nav pt-lg-3">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                            <span class="nav-link-icon"><i class="ti ti-dashboard"></i></span>
                            <span class="nav-link-title">@(isEn ? "Dashboard" : "Bảng điều khiển")</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Users">
                            <span class="nav-link-icon"><i class="ti ti-users"></i></span>
                            <span class="nav-link-title">@(isEn ? "Users" : "Người dùng")</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Mentors">
                            <span class="nav-link-icon"><i class="ti ti-user-star"></i></span>
                            <span class="nav-link-title">@(isEn ? "Mentors" : "Cố vấn")</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Mentors/PendingApprovals">
                            <span class="nav-link-icon"><i class="ti ti-user-check"></i></span>
                            <span class="nav-link-title">Duyệt Cố vấn</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="CareerTests">
                            <span class="nav-link-icon"><i class="ti ti-clipboard-check"></i></span>
                            <span class="nav-link-title">@(isEn ? "Career Tests" : "Bài trắc nghiệm")</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Categories">
                            <span class="nav-link-icon"><i class="ti ti-category"></i></span>
                            <span class="nav-link-title">@(isEn ? "Categories" : "Chuyên mục")</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Jobs">
                            <span class="nav-link-icon"><i class="ti ti-briefcase"></i></span>
                            <span class="nav-link-title">@(isEn ? "Jobs" : "Việc làm")</span>
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="CareerPaths">
                            <span class="nav-link-icon"><i class="ti ti-route"></i></span>
                            <span class="nav-link-title">@(isEn ? "Career Paths" : "Lộ trình nghề nghiệp")</span>
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Skills">
                            <span class="nav-link-icon"><i class="ti ti-bulb"></i></span>
                            <span class="nav-link-title">@(isEn ? "Skills" : "Kỹ năng")</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Goals">
                            <span class="nav-link-icon d-md-none d-lg-inline-block">
                                <i class="ti ti-target"></i>
                            </span>
                            <span class="nav-link-title">
                                @(isEn ? "Goals" : "Mục tiêu")
                            </span>
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Resources">
                            <span class="nav-link-icon"><i class="ti ti-books"></i></span>
                            <span class="nav-link-title">@(isEn ? "Resources" : "Học liệu")</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Courses">
                            <span class="nav-link-icon">
                                <i class="ti ti-school"></i>
                            </span>
                            <span class="nav-link-title">@(isEn ? "Courses" : "Khóa học")</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AdminResumeTemplates" asp-action="Index">
                            <span class="nav-link-icon"><i class="ti ti-template"></i></span>
                            <span class="nav-link-title">Mẫu CV</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Events">
                            <span class="nav-link-icon"><i class="ti ti-calendar-event"></i></span>
                            <span class="nav-link-title">Sự kiện</span>
                        </a>
                    </li>


                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Reports">
                            <span class="nav-link-icon"><i class="ti ti-chart-bar"></i></span>
                            <span class="nav-link-title">@(isEn ? "Reports" : "Báo cáo")</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Settings">
                            <span class="nav-link-icon"><i class="ti ti-settings"></i></span>
                            <span class="nav-link-title">@(isEn ? "Settings" : "Cài đặt")</span>
                        </a>
                    </li>

                    <li class="nav-item mt-3">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <span class="nav-link-icon"><i class="ti ti-arrow-left"></i></span>
                            <span class="nav-link-title">@(isEn ? "Back to Website" : "Quay lại trang chủ")</span>
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </aside>

    <div class="page-wrapper">

        <header class="navbar navbar-expand-md d-print-none">
            <div class="container-xl">
                <div class="navbar-nav flex-row order-md-last ms-auto">
                    <!-- Language Selector for Admin -->
                    <div class="language-selector" style="display: flex; gap: 10px; margin-right: 15px; align-items: center;">
                        <a href="javascript:void(0)" onclick="changeSystemLanguage('vi')" title="Tiếng Việt" style="text-decoration: none; font-size: 20px; opacity: 0.5; transition: all 0.2s;" id="lang-vi">
                            <span>🇻🇳</span>
                        </a>
                        <a href="javascript:void(0)" onclick="changeSystemLanguage('en')" title="English" style="text-decoration: none; font-size: 20px; opacity: 0.5; transition: all 0.2s;" id="lang-en">
                            <span>🇬🇧</span>
                        </a>
                    </div>

                    <!-- Notification Bell Dropdown -->
                    <div class="nav-item dropdown d-flex align-items-center me-3 position-relative">
                        <a href="#" class="nav-link px-0 text-reset" data-bs-toggle="dropdown" tabindex="-1" aria-label="Show notifications" id="adminNotifBell">
                            <i class="ti ti-bell fs-2"></i>
                            <span class="badge bg-red badge-pill position-absolute top-0 start-100 translate-middle" id="adminNotifBadge" style="display: none;">0</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-arrow dropdown-menu-end dropdown-menu-card" style="width: 320px;">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center py-2">
                                    <h3 class="card-title mb-0 fs-4">🔔 Thông báo ứng tuyển</h3>
                                    <a asp-controller="Admin" asp-action="JobApplications" class="small text-muted text-decoration-none">Xem tất cả</a>
                                </div>
                                <div class="list-group list-group-flush list-group-hoverable" id="adminNotifList">
                                    <div class="text-center p-3 text-muted small" id="adminNotifEmpty">
                                        <i class="ti ti-inbox me-1"></i> Chưa có thông báo mới
                                    </div>
                                </div>
                                <div class="card-footer text-center py-2">
                                    <a asp-controller="Admin" asp-action="JobApplications" class="btn btn-sm btn-outline-primary w-100">
                                        Quản lý đơn ứng tuyển
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link d-flex lh-1 text-reset p-0" data-bs-toggle="dropdown">
                            <span class="avatar avatar-sm">AD</span>
                            <div class="d-none d-xl-block ps-2">
                                <div>Admin</div>
                                <div class="mt-1 small text-muted">@(isEn ? "CareerPath Manager" : "Quản trị viên")</div>
                            </div>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                            <a class="dropdown-item" href="/">@(isEn ? "Profile" : "Thông tin cá nhân")</a>
                            <a class="dropdown-item" asp-controller="Admin" asp-action="Settings">@(isEn ? "Settings" : "Cài đặt")</a>
                            <div class="dropdown-divider"></div>
                            <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" style="display:none;">
                                @Html.AntiForgeryToken()
                            </form>
                            <a class="dropdown-item" href="javascript:void(0);" onclick="document.getElementById('logoutForm').submit();">@(isEn ? "Logout" : "Đăng xuất")</a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="page-body">
            <div class="container-xl">
                @RenderBody()
            </div>
        </div>

        <footer class="footer footer-transparent d-print-none">
            <div class="container-xl text-center text-muted">
                © 2026 CareerPath Admin Demo
            </div>
        </footer>

    </div>
</div>

<script src="@("https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/js/tabler.min.js")"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
@await RenderSectionAsync("Scripts", required: false)

<style>
    /* Google Translate Hiding Styles */
    iframe.goog-te-banner-frame {
        display: none !important;
    }
    .goog-te-balloon-frame {
        display: none !important;
    }
    #google_translate_element, .skiptranslate {
        display: none !important;
    }
    body {
        top: 0 !important;
    }
    .language-selector a.active-lang {
        opacity: 1 !important;
        transform: scale(1.25);
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.15));
    }
</style>

<!-- Google Translate Widget Elements -->
<div id="google_translate_element" style="display:none;"></div>
<script type="text/javascript">
    function googleTranslateElementInit() {
        new google.translate.TranslateElement({
            pageLanguage: 'vi',
            includedLanguages: 'en,vi',
            layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
            autoDisplay: false
        }, 'google_translate_element');
    }
</script>
<script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

<script>
    function changeSystemLanguage(lang) {
        let domain = window.location.hostname;
        if (lang === 'en') {
            document.cookie = "googtrans=/vi/en; path=/; domain=" + domain;
            document.cookie = "googtrans=/vi/en; path=/";
            document.cookie = "selected_lang=en; path=/; domain=" + domain;
            document.cookie = "selected_lang=en; path=/";
        } else {
            document.cookie = "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=" + domain;
            document.cookie = "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/";
            document.cookie = "selected_lang=vi; path=/; domain=" + domain;
            document.cookie = "selected_lang=vi; path=/";
        }
        window.location.reload();
    }

    document.addEventListener("DOMContentLoaded", function() {
        // Highlight active flag based on Cookie
        let match = document.cookie.match(new RegExp('(^| )selected_lang=([^;]+)'));
        let currentLang = match ? match[2] : 'vi';
        
        let flagVi = document.getElementById('lang-vi');
        let flagEn = document.getElementById('lang-en');
        if (flagVi && flagEn) {
            if (currentLang === 'en') {
                flagVi.style.opacity = '0.4';
                flagVi.classList.remove('active-lang');
                flagEn.style.opacity = '1';
                flagEn.classList.add('active-lang');
            } else {
                flagVi.style.opacity = '1';
                flagVi.classList.add('active-lang');
                flagEn.style.opacity = '0.4';
                flagEn.classList.remove('active-lang');
            }
        }

        let latestNotifId = 0;

        // Mark as read when clicking notification bell dropdown
        const bellBtn = document.getElementById('adminNotifBell');
        if (bellBtn) {
            bellBtn.addEventListener('click', function() {
                if (latestNotifId > 0) {
                    localStorage.setItem('adminLastReadNotifId', latestNotifId.toString());
                }
                const badge = document.getElementById('adminNotifBadge');
                if (badge) badge.style.display = 'none';
            });
        }

        // Notification polling for Admin
        function fetchAdminNotifications() {
            fetch('/Admin/GetAdminNotifications')
                .then(res => res.json())
                .then(data => {
                    if (data && data.success) {
                        const badge = document.getElementById('adminNotifBadge');
                        const notifList = document.getElementById('adminNotifList');
                        
                        if (data.notifications && data.notifications.length > 0) {
                            latestNotifId = Math.max(...data.notifications.map(n => n.id));
                            
                            // Auto mark current notifications as read if Admin is viewing a candidate CV or Job Applications dashboard
                            const currentPath = window.location.pathname.toLowerCase();
                            if (currentPath.includes('/admin/viewresume') || currentPath.includes('/admin/jobapplications')) {
                                localStorage.setItem('adminLastReadNotifId', latestNotifId.toString());
                            }

                            const lastReadId = parseInt(localStorage.getItem('adminLastReadNotifId') || '0');
                            
                            // Count unread applications (ID > lastReadId and status is Applied)
                            const unreadItems = data.notifications.filter(n => n.id > lastReadId && n.status === "Applied");
                            
                            if (badge) {
                                if (unreadItems.length > 0) {
                                    badge.textContent = unreadItems.length;
                                    badge.style.display = 'inline-block';
                                } else {
                                    badge.style.display = 'none';
                                }
                            }

                            let html = '';
                            data.notifications.forEach(item => {
                                const isUnread = item.id > lastReadId && item.status === "Applied";
                                html += `
                                    <a href="/Admin/JobApplications?jobId=${item.jobId}" class="list-group-item list-group-item-action py-2 ${isUnread ? 'bg-light-subtle' : ''}">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <div class="fw-bold text-dark text-truncate" style="max-width: 170px;">
                                                ${isUnread ? '🔵 ' : ''}${item.userName}
                                            </div>
                                            <small class="text-muted" style="font-size: 11px;">${item.appliedAt}</small>
                                        </div>
                                        <div class="small text-secondary text-truncate mt-1">
                                            <i class="ti ti-briefcase me-1"></i>Ứng tuyển: ${item.jobTitle}
                                        </div>
                                    </a>
                                `;
                            });
                            if (notifList) notifList.innerHTML = html;
                        } else {
                            if (badge) badge.style.display = 'none';
                            if (notifList) {
                                notifList.innerHTML = `
                                    <div class="text-center p-3 text-muted small">
                                        <i class="ti ti-inbox me-1"></i> Chưa có thông báo đơn ứng tuyển
                                    </div>
                                `;
                            }
                        }
                    }
                })
                .catch(err => console.error('Error loading admin notifications', err));
        }

        fetchAdminNotifications();
        setInterval(fetchAdminNotifications, 30000);
    });
</script>
</body>
</html>