@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - CareerPath</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/page.css" asp-append-version="true" />
</head>
<body>

<header class="navbar">
    <a class="logo" asp-controller="Home" asp-action="Index">
        <span class="logo-icon">🎓</span>
        <span>CareerPath</span>
    </a>

    <nav class="nav-menu">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <a asp-controller="Home" asp-action="CareerTest">Đánh giá nghề nghiệp</a>
        <a asp-controller="Home" asp-action="CareerPath">Gợi ý & Lộ trình</a>
        <a asp-controller="Home" asp-action="Training">Đào tạo</a>
        <a asp-controller="Home" asp-action="Jobs">Việc làm</a>
        <a asp-controller="Home" asp-action="Community">Cộng đồng</a>
    </nav>

    <div class="nav-actions">
        @if (SignInManager.IsSignedIn(User))
        {
            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="navbar-right">
                <ul class="nav navbar-nav navbar-right">
                    @if (User.IsInRole("Admin"))
                    {
                        <li style="margin-right: 15px; display: inline-block;">
                            <a asp-controller="Admin" asp-action="Dashboard" style="color: #ef4444; font-weight: 700; text-decoration: none;">🛡️ Admin Panel</a>
                        </li>
                    }
                    <li>
                        <a asp-controller="Manage" asp-action="Index" title="Manage">Hello @UserManager.GetUserName(User)!</a>
                    </li>
                    <li>
                        <button type="submit" class="btn btn-link navbar-btn navbar-link">Log out</button>
                    </li>
                </ul>
            </form>
        }
        else
        {
            <a class="login-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
            <a class="register-btn" asp-controller="Account" asp-action="Register">Đăng ký</a>
        }
    </div>
</header>

<main>
    @RenderBody()
</main>

<footer class="main-footer">
    <div class="footer-container">
        <div class="footer-brand">
            <h3>🎓 CareerPath</h3>
            <p>Nền tảng hướng nghiệp thông minh, đồng hành cùng bạn trên con đường phát triển sự nghiệp.</p>
            <p>📧 contact@careerpath.vn</p>
            <p>☎ 1900 xxxx</p>
            <p>📍 Hà Nội, Việt Nam</p>
        </div>

        <div class="footer-col">
            <h4>Về chúng tôi</h4>
            <a asp-controller="Home" asp-action="About">Giới thiệu & Đội ngũ</a>
            <a asp-controller="Home" asp-action="News">Tin tức</a>
            <a asp-controller="Home" asp-action="Contact">Liên hệ</a>
        </div>

        <div class="footer-col">
            <h4>Dịch vụ</h4>
            <a asp-controller="Home" asp-action="CareerTest">Đánh giá nghề nghiệp</a>
            <a asp-controller="Home" asp-action="CareerPath">Gợi ý lộ trình</a>
            <a asp-controller="Home" asp-action="Training">Đào tạo</a>
            <a asp-controller="Home" asp-action="Jobs">Việc làm</a>
        </div>

        <div class="footer-col">
            <h4>Hỗ trợ</h4>
            <a asp-controller="Home" asp-action="FAQ">Trung tâm trợ giúp</a>
            <a asp-controller="Home" asp-action="Terms">Điều khoản sử dụng</a>
            <a asp-controller="Home" asp-action="Policy">Chính sách bảo mật</a>
            <a asp-controller="Home" asp-action="FAQ">FAQ</a>
        </div>
    </div>

    <div class="footer-bottom">
        <p>© 2026 CareerPath. All rights reserved.</p>
        <div class="socials">
            <span>f</span>
            <span>in</span>
            <span>x</span>
        </div>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>