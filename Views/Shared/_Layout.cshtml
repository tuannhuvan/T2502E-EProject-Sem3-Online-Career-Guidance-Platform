        </div>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<!-- Global Toast Container -->
<div id="toast-container" class="toast-container"></div>

@if (TempData["SuccessMessage"] != null)
{
    <div id="tempDataSuccess" style="display:none;" data-message="@TempData["SuccessMessage"]"></div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div id="tempDataError" style="display:none;" data-message="@TempData["ErrorMessage"]"></div>
}

<script>
    window.showToast = function(message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) return;

        const card = document.createElement('div');
        card.className = `toast-card toast-${type}`;

        let icon = 'ℹ️';
        if (type === 'success') icon = '✅';
        else if (type === 'error') icon = '❌';
        else if (type === 'warning') icon = '⚠️';

        card.innerHTML = `
            <div class="toast-icon">${icon}</div>
            <div class="toast-content">
                <p class="toast-message">${message}</p>
            </div>
        `;

        container.appendChild(card);

        // Trigger animate-in
        setTimeout(() => card.classList.add('show'), 10);

        // Auto-remove after 4 seconds
        const autoHide = setTimeout(() => {
            card.classList.remove('show');
            card.classList.add('hide');
            setTimeout(() => card.remove(), 400);
        }, 4000);

        // Click to dismiss
        card.onclick = () => {
            clearTimeout(autoHide);
            card.classList.remove('show');
            card.classList.add('hide');
            setTimeout(() => card.remove(), 400);
        };
    };

    document.addEventListener("DOMContentLoaded", function() {
        const successEl = document.getElementById('tempDataSuccess');
        const errorEl = document.getElementById('tempDataError');
        if (successEl) showToast(successEl.getAttribute('data-message'), 'success');
        if (errorEl) showToast(errorEl.getAttribute('data-message'), 'error');
    });
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>