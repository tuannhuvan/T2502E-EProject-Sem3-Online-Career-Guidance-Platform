@model Career_Guidance_Platform.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-badge">🎓 CareerPath</div>

        <h1>Đăng nhập</h1>
        <p>Chào mừng bạn quay trở lại. Tiếp tục hành trình định hướng nghề nghiệp của bạn.</p>

        @if (TempData["RequireAuthForTestResult"] != null)
        {
            <div style="background-color: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; font-size: 14px; line-height: 1.5; font-weight: 500;">
                ℹ️ @TempData["RequireAuthForTestResult"]
            </div>
        }

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="Nhập email của bạn" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-row">
                <label asp-for="RememberMe">
                    <input asp-for="RememberMe" />
                    @Html.DisplayNameFor(m => m.RememberMe)
                </label>
                <a asp-controller="Account" asp-action="ForgotPassword">
                    Quên mật khẩu?
                </a>
            </div>

            <button type="submit" class="auth-btn">Đăng nhập</button>
        </form>

        <p class="auth-switch">
            Chưa có tài khoản?
            <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]">Đăng ký ngay</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var inputs = document.querySelectorAll("input");
            inputs.forEach(function (input) {
                function updateMessage() {
                    input.setCustomValidity("");
                    if (!input.validity.valid) {
                        var fieldName = "";
                        var label = document.querySelector("label[for='" + input.id + "']");
                        if (label) {
                            fieldName = label.textContent.trim();
                        } else if (input.placeholder) {
                            fieldName = input.placeholder;
                        }
                        
                        if (input.validity.valueMissing) {
                            if (fieldName) {
                                input.setCustomValidity("Vui lòng nhập " + fieldName.toLowerCase().replace("?", "") + ".");
                            } else {
                                input.setCustomValidity("Vui lòng điền trường này.");
                            }
                        } else if (input.validity.typeMismatch && input.type === "email") {
                            input.setCustomValidity("Vui lòng nhập đúng định dạng email (ví dụ: name@example.com).");
                        }
                    }
                }
                input.addEventListener("invalid", updateMessage);
                input.addEventListener("input", function () {
                    input.setCustomValidity("");
                });
            });
        });
    </script>
}