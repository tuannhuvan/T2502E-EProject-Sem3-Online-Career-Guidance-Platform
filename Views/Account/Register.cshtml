@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-badge">🎓 CareerPath</div>

        <h1>Tạo tài khoản</h1>
        <p>Bắt đầu khám phá năng lực, nghề nghiệp phù hợp và lộ trình phát triển của bạn.</p>

        <form>
            <div class="form-group">
                <label>Họ và tên</label>
                <input type="text" placeholder="Nhập họ và tên" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" placeholder="Nhập email của bạn" />
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password" placeholder="Tạo mật khẩu" />
            </div>

            <div class="form-group">
                <label>Xác nhận mật khẩu</label>
                <input type="password" placeholder="Nhập lại mật khẩu" />
            </div>

            <div class="form-row terms">
                <label>
                    <input type="checkbox" />
                    Tôi đồng ý với điều khoản sử dụng
                </label>
            </div>

            <button type="button" class="auth-btn">Đăng ký</button>
        </form>

        <p class="auth-switch">
            Đã có tài khoản?
            <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
        </p>
    </div>
</section>