@model Career_Guidance_Platform.Dtos.Auth.RegisterViewModel
@model Career_Guidance_Platform.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-badge">🎓 CareerPath</div>

        <h1>Tạo tài khoản</h1>
        <p>Bắt đầu khám phá năng lực, nghề nghiệp phù hợp và lộ trình phát triển của bạn.</p>

        <form asp-action="Register" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Họ và tên</label>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
        @if (TempData["RequireAuthForTestResult"] != null)
        {
            <div style="background-color: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; font-size: 14px; line-height: 1.5; font-weight: 500;">
                ℹ️ @TempData["RequireAuthForTestResult"]
            </div>
        }

        <form asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" required />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="form-control" placeholder="Nhập email của bạn" />
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="Nhập email của bạn" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Tạo mật khẩu" />
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="Tạo mật khẩu" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Xác nhận mật khẩu</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu" />
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-row terms">
                <label>
                    <input type="checkbox" required />
                    Tôi đồng ý với điều khoản sử dụng
                </label>
            </div>

            <button type="submit" class="auth-btn">Đăng ký</button>
        </form>

        <p class="auth-switch">
            Đã có tài khoản?
            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">Đăng nhập</a>
        </p>
    </div>
</section>
@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var inputs = document.querySelectorAll("input");
            inputs.forEach(function (input) {
                function updateMessage() {
                    input.setCustomValidity("");
                    if (!input.validity.valid) {
                        var fieldName = "";
                        var label = document.querySelector("label[for='" + input.id + "']");
                        if (label) {
                            fieldName = label.textContent.trim();
                        } else if (input.placeholder) {
                            fieldName = input.placeholder;
                        }
                        
                        if (input.validity.valueMissing) {
                            if (input.type === "checkbox") {
                                input.setCustomValidity("Vui lòng đồng ý với điều khoản để tiếp tục.");
                            } else if (fieldName) {
                                input.setCustomValidity("Vui lòng nhập " + fieldName.toLowerCase().replace("?", "") + ".");
                            } else {
                                input.setCustomValidity("Vui lòng điền trường này.");
                            }
                        } else if (input.validity.typeMismatch && input.type === "email") {
                            input.setCustomValidity("Vui lòng nhập đúng định dạng email (ví dụ: name@example.com).");
                        }
                    }
                }
                input.addEventListener("invalid", updateMessage);
                input.addEventListener("input", function () {
                    input.setCustomValidity("");
                });
            });
        });
    </script>
}