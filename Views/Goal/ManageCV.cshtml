@{
    ViewData["Title"] = "Quản lý CV & Đồng bộ Kỹ năng";
    var completedSkills = ViewBag.CompletedSkills as List<string> ?? new List<string>();
    var resumes = ViewBag.Resumes as List<Career_Guidance_Platform.Models.Resume> ?? new List<Career_Guidance_Platform.Models.Resume>();
}

<section class="page-hero" style="background: radial-gradient(circle at top left, #f0fdfa 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); border-bottom: 1px solid #f1f5f9; padding: 70px 24px 50px;">
    <span class="page-badge">📝 Tích hợp hồ sơ CV</span>
    <h1>Đồng bộ kỹ năng vào CV</h1>
    <p>Chọn các kỹ năng đã được kiểm chứng từ Kho kỹ năng để tích hợp trực tiếp vào CV xin việc chuyên nghiệp của bạn.</p>
</section>

<section class="content-section" style="max-width: 1000px; padding: 40px 24px 80px;">



    <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 36px; align-items: start;">
        
        <!-- Left Column: Choose skills -->
        <div class="info-card" style="padding: 32px; border-radius: 20px;">
            <h3 style="font-size: 18px; font-weight: 800; color: #0f172a; margin-bottom: 8px;">1. Chọn kỹ năng đã hoàn thành</h3>
            <p style="color: #64748b; font-size: 14px; margin-bottom: 24px; line-height: 1.5;">Chọn các kỹ năng từ Skill Inventory để hiển thị trên CV của bạn:</p>

            @if (completedSkills.Count == 0)
            {
                <div style="text-align: center; padding: 40px 20px; background: #f8fafc; border-radius: 12px; border: 1px dashed #cbd5e1;">
                    <p style="margin: 0; color: #64748b; font-style: italic; font-size: 14px;">Bạn chưa hoàn thành bất kỳ đánh giá kỹ năng nào.</p>
                    <a asp-controller="Goal" asp-action="Index" class="btn primary-btn" style="margin-top: 15px; font-size: 13px; padding: 8px 16px; border-radius: 8px;">
                        Luyện tập & Thi ngay
                    </a>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @foreach (var skill in completedSkills)
                    {
                        <label style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 14px 16px; display: flex; align-items: center; gap: 12px; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#f1f5f9';" onmouseout="this.style.background='#f8fafc';">
                            <input type="checkbox" class="completed-skill-cb" value="@skill" checked style="width: 18px; height: 18px; cursor: pointer;" />
                            <div>
                                <strong style="font-size: 14.5px; color: #0f172a;">@skill</strong>
                                <span style="font-size: 12px; color: #10b981; display: block; font-weight: 700;">✓ Đã xác minh</span>
                            </div>
                        </label>
                    }
                </div>
            }
        </div>

        <!-- Right Column: Select CV and sync -->
        <div class="info-card" style="padding: 32px; border-radius: 20px; background: linear-gradient(180deg, #f0fdfa 0%, #ffffff 100%); border-color: #99f6e4;">
            <h3 style="font-size: 18px; font-weight: 800; color: #0f172a; margin-bottom: 8px;">2. Đồng bộ hóa vào CV mẫu</h3>
            <p style="color: #64748b; font-size: 14px; margin-bottom: 24px; line-height: 1.5;">Chọn CV đích để cập nhật thông tin kỹ năng:</p>

            @if (resumes.Count == 0)
            {
                <div style="background: #ffffff; border: 1px solid #ccfbf1; padding: 24px; border-radius: 14px; text-align: center;">
                    <p style="font-size: 13.5px; color: #0d9488; font-style: italic; margin-bottom: 16px;">Bạn chưa lưu mẫu CV nào trên hệ thống.</p>
                    <form asp-controller="Goal" asp-action="CreateCVFromSkills" method="post" id="createFormStandalone">
                        <div id="skillsListContainerStandalone"></div>
                        <button type="submit" onclick="submitCreateStandalone(event)" class="btn primary-btn" style="width: 100%; border-radius: 10px; font-size: 14px; padding: 12px;">
                            ✨ Tạo CV mẫu mới với kỹ năng
                        </button>
                    </form>
                </div>
            }
            else
            {
                <form asp-controller="Goal" asp-action="UpdateCV" method="post" id="updateFormStandalone">
                    <div id="skillsListContainerUpdateStandalone"></div>
                    
                    <label style="font-size: 14px; font-weight: 700; color: #334155; display: block; margin-bottom: 8px;">Chọn CV cần cập nhật:</label>
                    <select name="resumeId" required style="width: 100%; height: 48px; border: 1px solid #cbd5e1; border-radius: 10px; padding: 0 12px; font-size: 14.5px; margin-bottom: 24px; background: white;">
                        @foreach (var r in resumes)
                        {
                            <option value="@r.Id">@r.Title (Cập nhật: @(r.UpdatedAt?.ToString("dd/MM/yyyy") ?? r.CreatedAt.ToString("dd/MM/yyyy")))</option>
                        }
                    </select>
                    
                    <button type="submit" onclick="submitUpdateStandalone(event)" class="btn primary-btn" style="width: 100%; border-radius: 10px; font-size: 14.5px; padding: 12px; font-weight: 700; box-shadow: 0 4px 14px rgba(13,148,136,0.2);">
                        🔄 Bắt đầu đồng bộ hóa
                    </button>
                </form>
            }
            
            <div style="margin-top: 20px; text-align: center;">
                <a asp-controller="Goal" asp-action="Index" class="btn secondary-btn" style="width: 100%; justify-content: center; padding: 12px; border-radius: 10px;">
                    ⬅ Quay lại Bảng điều khiển
                </a>
            </div>
        </div>

    </div>
</section>

<script>
    function getSelectedSkillsStandalone() {
        const checked = document.querySelectorAll(".completed-skill-cb:checked");
        return Array.from(checked).map(cb => cb.value);
    }

    function submitUpdateStandalone(event) {
        const skills = getSelectedSkillsStandalone();
        if (skills.length === 0) {
            showToast("Vui lòng chọn ít nhất một kỹ năng để đồng bộ.", "warning");
            event.preventDefault();
            return;
        }

        const container = document.getElementById("skillsListContainerUpdateStandalone");
        container.innerHTML = "";
        skills.forEach(s => {
            const input = document.createElement("input");
            input.type = "hidden";
            input.name = "selectedSkills";
            input.value = s;
            container.appendChild(input);
        });
    }

    function submitCreateStandalone(event) {
        const skills = getSelectedSkillsStandalone();
        if (skills.length === 0) {
            showToast("Vui lòng chọn ít nhất một kỹ năng để tạo CV mới.", "warning");
            event.preventDefault();
            return;
        }

        const container = document.getElementById("skillsListContainerStandalone");
        container.innerHTML = "";
        skills.forEach(s => {
            const input = document.createElement("input");
            input.type = "hidden";
            input.name = "selectedSkills";
            input.value = s;
            container.appendChild(input);
        });
    }
</script>
