@{
    ViewData["Title"] = "Điều khoản sử dụng";
}

<section class="page-hero">
    <span class="page-badge">📄 Quy định chung</span>
    <h1>Điều khoản sử dụng</h1>
    <p>Chào mừng bạn đến với CareerPath. Vui lòng đọc kỹ các điều khoản dịch vụ dưới đây trước khi trải nghiệm nền tảng.</p>
</section>

<section class="content-section">
    <div style="display: grid; grid-template-columns: 260px 1fr; gap: 40px; align-items: start;">
        <!-- Sidebar Navigation -->
        <aside style="position: sticky; top: 100px; display: flex; flex-direction: column; gap: 12px; padding: 20px; background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 16px;">
            <strong style="color: #020617; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;">Mục lục chính</strong>
            <a href="#section-1" style="color: #64748b; font-size: 15px; text-decoration: none; font-weight: 500; transition: 0.2s;" onmouseover="this.style.color='#020617'" onmouseout="this.style.color='#64748b'">1. Chấp thuận điều khoản</a>
            <a href="#section-2" style="color: #64748b; font-size: 15px; text-decoration: none; font-weight: 500; transition: 0.2s;" onmouseover="this.style.color='#020617'" onmouseout="this.style.color='#64748b'">2. Đăng ký tài khoản</a>
            <a href="#section-3" style="color: #64748b; font-size: 15px; text-decoration: none; font-weight: 500; transition: 0.2s;" onmouseover="this.style.color='#020617'" onmouseout="this.style.color='#64748b'">3. Quy tắc ứng xử</a>
            <a href="#section-4" style="color: #64748b; font-size: 15px; text-decoration: none; font-weight: 500; transition: 0.2s;" onmouseover="this.style.color='#020617'" onmouseout="this.style.color='#64748b'">4. Sở hữu trí tuệ</a>
            <a href="#section-5" style="color: #64748b; font-size: 15px; text-decoration: none; font-weight: 500; transition: 0.2s;" onmouseover="this.style.color='#020617'" onmouseout="this.style.color='#64748b'">5. Giới hạn trách nhiệm</a>
        </aside>

        <!-- Content -->
        <article class="legal-content">
            <p style="font-size: 16px; color: #64748b; line-height: 1.8;">Cập nhật lần cuối: Ngày 24 tháng 6 năm 2026. Bằng việc truy cập, đăng ký hoặc sử dụng bất kỳ dịch vụ nào trên hệ thống CareerPath, bạn đồng ý tuân thủ các điều khoản sử dụng này.</p>

            <h2 id="section-1" style="font-size: 24px; color: #020617; margin-top: 30px;">1. Chấp thuận các điều khoản</h2>
            <p>Nếu bạn không đồng ý với bất kỳ điều khoản nào trong văn bản này, vui lòng ngừng sử dụng nền tảng CareerPath ngay lập tức. Chúng tôi có quyền sửa đổi nội dung điều khoản bất kỳ lúc nào mà không cần thông báo trước, và việc bạn tiếp tục sử dụng dịch vụ sau khi điều khoản được cập nhật đồng nghĩa với việc bạn đồng ý với những thay đổi đó.</p>

            <h2 id="section-2" style="font-size: 24px; color: #020617; margin-top: 40px;">2. Quyền và nghĩa vụ khi tạo tài khoản</h2>
            <p>Để trải nghiệm đầy đủ các tính năng hướng nghiệp:</p>
            <ul>
                <li>Bạn cam kết cung cấp thông tin cá nhân (Họ tên, Email...) chính xác và trung thực khi đăng ký tài khoản.</li>
                <li>Bạn có trách nhiệm tự bảo mật mật khẩu tài khoản và chịu trách nhiệm cho tất cả các hoạt động xảy ra dưới tên tài khoản của mình.</li>
                <li>Chúng tôi có quyền tạm khóa hoặc chấm dứt tài khoản mà không cần báo trước nếu phát hiện hành vi gian lận hoặc đăng ký thông tin giả mạo.</li>
            </ul>

            <h2 id="section-3" style="font-size: 24px; color: #020617; margin-top: 40px;">3. Quy tắc ứng xử của người dùng</h2>
            <p>Người dùng CareerPath không được thực hiện các hành vi sau:</p>
            <ul>
                <li>Sử dụng các công cụ tự động, phần mềm độc hại nhằm mục đích can thiệp hoặc phá hoại hệ thống dữ liệu CareerPath.</li>
                <li>Sao chép, phát tán trái phép các câu hỏi kiểm tra, tài liệu lộ trình hoặc nội dung bài học độc quyền của chúng tôi.</li>
                <li>Có hành vi quấy rối, xúc phạm hoặc spam tin nhắn đối với các Mentor hoặc các thành viên khác trong phần cộng đồng hướng nghiệp.</li>
            </ul>

            <h2 id="section-4" style="font-size: 24px; color: #020617; margin-top: 40px;">4. Sở hữu trí tuệ</h2>
            <p>Toàn bộ mã nguồn, cấu trúc thuật toán, giao diện thiết kế, bộ câu hỏi trắc nghiệm, hình ảnh và logo thương hiệu đều thuộc quyền sở hữu trí tuệ duy nhất của CareerPath. Nghiêm cấm mọi hành vi sao chép, tái bản hoặc sử dụng thương mại hóa khi chưa được sự cho phép bằng văn bản từ chúng tôi.</p>

            <h2 id="section-5" style="font-size: 24px; color: #020617; margin-top: 40px;">5. Tuyên bố từ chối trách nhiệm</h2>
            <p>CareerPath cung cấp các bài đánh giá tâm lý hướng nghiệp và đề xuất lộ trình dựa trên khoa học hành vi và dữ liệu thực tế nhằm mục đích tham khảo định hướng học tập. Chúng tôi không đảm bảo tuyệt đối hoặc chịu trách nhiệm pháp lý về việc bạn chắc chắn thành công hay trúng tuyển tại bất kỳ doanh nghiệp nào dựa trên kết quả của bài test.</p>
        </article>
    </div>
</section>
