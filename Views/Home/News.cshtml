@model Career_Guidance_Platform.Models.ViewModels.NewsViewModel
@{
    ViewData["Title"] = "Tin tức & Sự kiện";
}

<section class="page-hero">
    <span class="page-badge">📰 Tin tức & Sự kiện</span>
    <h1>Bản tin CareerPath & Lịch sự kiện</h1>
    <p>Cập nhật những xu hướng tuyển dụng mới nhất, cẩm nang phát triển sự nghiệp và lịch trình các buổi tọa đàm hướng nghiệp.</p>
</section>

<section class="content-section">
    <div style="display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 40px; align-items: start;">
        
        <!-- Left: News Articles -->
        <div>
            <h2 style="font-size: 28px; color: #020617; margin: 0 0 24px;">📰 Tin tức & Cẩm nang hướng nghiệp</h2>
            <div style="display: flex; flex-direction: column; gap: 24px;">
                @foreach (var article in Model.Articles)
                {
                    <div class="info-card" style="display: flex; gap: 24px; padding: 24px; transition: 0.25s;">
                        <!-- News Image Placeholder -->
                        <div style="width: 140px; height: 140px; border-radius: 16px; background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%); display: flex; flex-shrink: 0; align-items: center; justify-content: center; font-size: 40px;">
                            📚
                        </div>
                        <div style="display: flex; flex-direction: column; justify-content: space-between;">
                            <div>
                                <span style="font-size: 12px; font-weight: 700; color: #4f46e5; text-transform: uppercase; letter-spacing: 0.5px; background: #e0e7ff; padding: 4px 10px; border-radius: 999px;">@article.Category</span>
                                <h3 style="font-size: 20px; color: #020617; margin: 10px 0 8px; line-height: 1.4;">@article.Title</h3>
                                <p style="color: #64748b; font-size: 14px; line-height: 1.6; margin: 0 0 12px;">@article.Summary</p>
                            </div>
                            <div style="display: flex; align-items: center; gap: 15px; font-size: 13px; color: #94a3b8;">
                                <span>✍️ Tác giả: <strong>@article.Author</strong></span>
                                <span>•</span>
                                <span>📅 @article.PublishedDate.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Right: Career Events -->
        <div>
            <h2 style="font-size: 28px; color: #020617; margin: 0 0 24px;">🗓️ Lịch sự kiện nghề nghiệp</h2>
            <div style="display: flex; flex-direction: column; gap: 20px;">
                @foreach (var ev in Model.Events)
                {
                    <div class="info-card" style="border-left: 5px solid #06b6d4; padding: 24px; transition: 0.25s;">
                        <span style="font-size: 12px; font-weight: 700; color: #0891b2; text-transform: uppercase; background: #cffafe; padding: 4px 10px; border-radius: 999px;">Sự kiện sắp diễn ra</span>
                        <h3 style="font-size: 18px; color: #020617; margin: 12px 0 8px; line-height: 1.4;">@ev.Title</h3>
                        <p style="color: #64748b; font-size: 13px; line-height: 1.5; margin: 0 0 16px;">@ev.Description</p>
                        
                        <div style="display: flex; flex-direction: column; gap: 8px; font-size: 13px; color: #64748b; margin-bottom: 20px; border-top: 1px dashed #e2e8f0; padding-top: 12px;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span>📅</span>
                                <span>Thời gian: <strong>@ev.EventDate.ToString("dd/MM/yyyy HH:mm")</strong></span>
                            </div>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span>📍</span>
                                <span>Địa điểm: <strong>@ev.Location</strong></span>
                            </div>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span>🗣️</span>
                                <span>Diễn giả: <strong>@ev.Speaker</strong></span>
                            </div>
                        </div>

                        <a href="/CareerEvent/Details/@ev.Id" class="btn primary-btn" style="width: 100%; text-align: center; border-radius: 12px; font-weight: 700; height: 44px; display: flex; align-items: center; justify-content: center; font-size: 14px; text-decoration: none;">Xem chi tiết & Đăng ký</a>
                    </div>
                }
            </div>
        </div>

    </div>
</section>
