@model Career_Guidance_Platform.Models.CommunityPost
@{
    ViewData["Title"] = Model.Title;
}

<section class="page-hero" style="background: radial-gradient(circle at top right, #f5f3ff 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);">
    <span class="page-badge">👥 Chi tiết thảo luận</span>
    <h1 style="font-size: 32px; max-width: 800px; margin: 10px auto; line-height: 1.3;">@Model.Title</h1>
    <div style="display: flex; justify-content: center; gap: 20px; font-size: 13.5px; color: #64748b; margin-top: 15px;">
        <span style="font-weight: 700; color: #4f46e5; text-transform: uppercase; background: #e0e7ff; padding: 2px 10px; border-radius: 999px;">@Model.Category</span>
        <span>👤 Người đăng: <strong>@Model.AuthorName</strong></span>
        <span>📅 Ngày: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
    </div>
</section>

<section class="content-section" style="max-width: 800px; padding-top: 0;">
    <!-- Back to Community Link -->
    <div style="margin-bottom: 24px;">
        <a asp-controller="Home" asp-action="Community" style="color: #4f46e5; text-decoration: none; font-weight: 700; display: inline-flex; align-items: center; gap: 6px;">
            ← Quay lại Cộng đồng
        </a>
    </div>

    <!-- Main Post Content Card -->
    <div class="info-card" style="padding: 32px; border-radius: 24px; margin-bottom: 40px; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);">
        <p style="color: #334155; font-size: 16px; line-height: 1.8; margin: 0 0 24px; white-space: pre-line;">@Model.Content</p>
        
        <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #f1f5f9; padding-top: 20px; font-size: 14px; color: #64748b;">
            <span data-post-id="@Model.Id" class="like-btn" style="display: flex; align-items: center; gap: 6px; cursor: pointer;" onclick="likePost(@Model.Id, this)">
                👍 Thích bài viết (<span class="like-count">@Model.LikesCount</span>)
            </span>
            <span>💬 @Model.RepliesCount Phản hồi</span>
        </div>
    </div>

    <!-- Comments / Replies Area -->
    <div style="margin-bottom: 50px;">
        <h2 style="font-size: 22px; color: #020617; margin-bottom: 24px; font-weight: 800; border-bottom: 2px solid #e2e8f0; padding-bottom: 12px; display: flex; align-items: center; gap: 8px;">
            <span>💬</span> Các phản hồi (@(Model.Comments?.Count ?? 0))
        </h2>

        @if (Model.Comments != null && Model.Comments.Any())
        {
            <div style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 40px;">
                @foreach (var comment in Model.Comments.OrderBy(c => c.CreatedAt))
                {
                    <div class="info-card" style="padding: 20px; border-radius: 16px; background: #fafafa; border-color: #f1f5f9;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-size: 13px;">
                            <span style="color: #0f172a;">👤 <strong>@(comment.Author?.FullName ?? comment.Author?.UserName ?? "Thành viên")</strong></span>
                            <span style="color: #94a3b8;">📅 @comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <p style="color: #334155; font-size: 14.5px; line-height: 1.6; margin: 0; white-space: pre-line;">@comment.Content</p>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="background: #f8fafc; border: 1px dashed #cbd5e1; padding: 30px; text-align: center; border-radius: 16px; margin-bottom: 40px; color: #64748b;">
                <p style="margin: 0; font-style: italic;">Chưa có phản hồi nào cho chủ đề này. Hãy chia sẻ ý kiến của bạn bên dưới!</p>
            </div>
        }

        <!-- Add Comment Form -->
        <div class="info-card" style="padding: 28px; border-radius: 20px; border: 1.5px solid #e2e8f0; box-shadow: 0 4px 20px rgba(0,0,0,0.01);">
            <h3 style="font-size: 18px; color: #020617; margin-top: 0; margin-bottom: 16px; font-weight: 700;">Gửi phản hồi của bạn</h3>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <form asp-controller="Home" asp-action="AddComment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="postId" value="@Model.Id" />

                    <div style="margin-bottom: 20px;">
                        <textarea name="content" required placeholder="Nhập câu trả lời hoặc ý kiến đóng góp của bạn tại đây..." style="width: 100%; padding: 12px 16px; border: 1px solid #cbd5e1; border-radius: 12px; font-size: 14.5px; min-height: 120px; resize: vertical; line-height: 1.5; outline: none; transition: 0.2s;" onfocus="this.style.borderColor='#4f46e5'"></textarea>
                    </div>

                    <div style="display: flex; justify-content: flex-end;">
                        <button type="submit" class="btn" style="background: #4f46e5; color: white; border: none; padding: 12px 30px; border-radius: 12px; font-weight: 700; cursor: pointer; font-size: 14.5px;">Gửi bình luận</button>
                    </div>
                </form>
            }
            else
            {
                <div style="text-align: center; padding: 10px 0;">
                    <p style="color: #64748b; font-size: 14.5px; margin-bottom: 20px;">Vui lòng đăng nhập tài khoản học viên để gửi phản hồi thảo luận.</p>
                    <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Home/PostDetails/@Model.Id" class="btn primary-btn" style="display: inline-block; padding: 10px 24px; text-decoration: none;">Đăng nhập ngay</a>
                </div>
            }
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const likedPosts = JSON.parse(localStorage.getItem('likedPosts') || '[]');
        likedPosts.forEach(postId => {
            const elements = document.querySelectorAll(`[data-post-id="${postId}"]`);
            elements.forEach(element => {
                element.classList.add('liked');
                element.style.color = '#4f46e5';
                element.style.fontWeight = 'bold';
            });
        });
    });

    function likePost(postId, element) {
        const likedPosts = JSON.parse(localStorage.getItem('likedPosts') || '[]');
        const isAlreadyLiked = likedPosts.includes(postId);
        
        fetch(`/Home/LikePost/${postId}?isUnlike=${isAlreadyLiked}`, {
            method: 'POST'
        })
        .then(response => {
            if (!response.ok) {
                throw new Error('Network response was not ok');
            }
            return response.json();
        })
        .then(data => {
            if (data.success) {
                const countElement = element.querySelector('.like-count');
                if (countElement) {
                    countElement.textContent = data.likesCount;
                }
                
                const allElementsOfThisPost = document.querySelectorAll(`[data-post-id="${postId}"]`);
                if (isAlreadyLiked) {
                    // Unlike
                    const index = likedPosts.indexOf(postId);
                    if (index > -1) likedPosts.splice(index, 1);
                    allElementsOfThisPost.forEach(el => {
                        el.classList.remove('liked');
                        el.style.color = 'inherit';
                        el.style.fontWeight = 'normal';
                    });
                    showToast('Đã bỏ thích bài viết!', 'info');
                } else {
                    // Like
                    likedPosts.push(postId);
                    allElementsOfThisPost.forEach(el => {
                        el.classList.add('liked');
                        el.style.color = '#4f46e5';
                        el.style.fontWeight = 'bold';
                    });
                    showToast('Đã thích bài viết!', 'success');
                }
                localStorage.setItem('likedPosts', JSON.stringify(likedPosts));
            } else {
                showToast('Không thể thực hiện hành động.', 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Có lỗi xảy ra, vui lòng thử lại.', 'error');
        });
    }
</script>
