@model IEnumerable<Career_Guidance_Platform.Models.CareerPath>
@{
    ViewData["Title"] = "Gợi ý & Lộ trình";
}

<section class="page-hero">
    <span class="page-badge">🎯 Career Path</span>

    <h1>Gợi ý & Lộ trình nghề nghiệp</h1>

    <p>
        Khám phá các ngành nghề phù hợp với kết quả đánh giá của bạn.
    </p>
</section>

<section class="content-section">

    <div class="news-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var path in Model)
            {
                <div class="news-card">
                    <span style="font-size:12px;font-weight:700;color:#4f46e5;text-transform:uppercase;background:#eef2ff;padding:4px 10px;border-radius:999px;display:inline-block;margin-bottom:10px;">
                        @(path.Category?.Name ?? "Định hướng")
                    </span>
                    <h3 style="margin-top: 5px;">@path.Title</h3>

                    <p style="min-height: 80px;">
                        @if (!string.IsNullOrEmpty(path.Content) && path.Content.Length > 120)
                        {
                            @(path.Content.Substring(0, 117) + "...")
                        }
                        else
                        {
                            @path.Content
                        }
                    </p>

                    <a asp-controller="CareerPath" asp-action="Details" asp-route-id="@path.Id">
                        Xem lộ trình →
                    </a>
                </div>
            }
        }
        else
        {
            <div class="info-card" style="grid-column: 1 / -1; text-align: center; padding: 40px;">
                <p style="color: #64748b; font-style: italic; margin: 0;">Hiện chưa có lộ trình nghề nghiệp nào được xuất bản.</p>
            </div>
        }
    </div>

</section>