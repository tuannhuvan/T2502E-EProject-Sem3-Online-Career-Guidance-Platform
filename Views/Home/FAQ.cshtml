@model IEnumerable<Career_Guidance_Platform.Models.FaqItem>
@{
    ViewData["Title"] = "Trung tâm trợ giúp";
}

<section class="page-hero">
    <span class="page-badge">🙋 Trung tâm trợ giúp & FAQ</span>
    <h1>Chúng tôi có thể giúp gì cho bạn?</h1>
    <p>Tìm kiếm nhanh câu trả lời hoặc chọn theo các chủ đề hỗ trợ phổ biến bên dưới.</p>
    
    <div style="max-width: 600px; margin: 30px auto 0; position: relative;">
        <input type="text" id="faq-search" placeholder="Nhập từ khóa tìm kiếm câu hỏi trợ giúp..." style="width: 100%; height: 56px; border: 1px solid #e5e7eb; border-radius: 999px; padding: 0 24px 0 54px; font-size: 16px; outline: none; box-shadow: 0 8px 30px rgba(0,0,0,0.04); transition: 0.2s;" />
        <span style="position: absolute; left: 24px; top: 16px; font-size: 20px;">🔍</span>
    </div>
</section>

<section class="content-section">
    <div class="faq-categories-grid" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 50px;">
        <div class="info-card faq-cat-card" onclick="filterCategory('all')" id="cat-all" style="cursor: pointer; text-align: center; transition: 0.25s; border-color: #020617; background: #f8fafc;">
            <span style="font-size: 32px; display: block; margin-bottom: 12px;">🌟</span>
            <strong style="color: #020617; font-size: 15px;">Tất cả câu hỏi</strong>
            <p style="font-size: 12px; color: #64748b; margin: 6px 0 0;">Hiển thị toàn bộ bộ câu hỏi vận hành hệ thống.</p>
        </div>
        <div class="info-card faq-cat-card" onclick="filterCategory('General')" style="cursor: pointer; text-align: center; transition: 0.25s;">
            <span style="font-size: 32px; display: block; margin-bottom: 12px;">⚙️</span>
            <strong style="color: #020617; font-size: 15px;">Vận hành chung</strong>
            <p style="font-size: 12px; color: #64748b; margin: 6px 0 0;">Tổng quan cách thức sử dụng, liên hệ ban kỹ thuật.</p>
        </div>
        <div class="info-card faq-cat-card" onclick="filterCategory('Account')" style="cursor: pointer; text-align: center; transition: 0.25s;">
            <span style="font-size: 32px; display: block; margin-bottom: 12px;">👤</span>
            <strong style="color: #020617; font-size: 15px;">Tài khoản & Bảo mật</strong>
            <p style="font-size: 12px; color: #64748b; margin: 6px 0 0;">Quản lý thông tin, đổi mật khẩu, mã hóa dữ liệu.</p>
        </div>
        <div class="info-card faq-cat-card" onclick="filterCategory('Test')" style="cursor: pointer; text-align: center; transition: 0.25s;">
            <span style="font-size: 32px; display: block; margin-bottom: 12px;">✏️</span>
            <strong style="color: #020617; font-size: 15px;">Đánh giá hướng nghiệp</strong>
            <p style="font-size: 12px; color: #64748b; margin: 6px 0 0;">Thuật toán tính toán, lưu trữ kết quả và làm lại bài test.</p>
        </div>
        <div class="info-card faq-cat-card" onclick="filterCategory('Mentor')" style="cursor: pointer; text-align: center; transition: 0.25s;">
            <span style="font-size: 32px; display: block; margin-bottom: 12px;">🤝</span>
            <strong style="color: #020617; font-size: 15px;">Mentor & Cộng đồng</strong>
            <p style="font-size: 12px; color: #64748b; margin: 6px 0 0;">Kết nối chuyên gia, đặt lịch hẹn, sự kiện và đăng bài viết.</p>
        </div>
    </div>

    <div class="faq-list" id="faq-list">
        @foreach (var faq in Model)
        {
            <div class="faq-item" data-category="@faq.Category">
                <div class="faq-question" style="display: flex; justify-content: space-between; align-items: center; cursor: pointer;">
                    <h3 style="font-size: 17px; margin: 0; color: #020617; line-height: 1.4;">@faq.Question</h3>
                    <span class="faq-icon" style="font-size: 18px; font-weight: bold; transition: 0.25s; margin-left: 15px;">+</span>
                </div>
                <div class="faq-answer" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease; color: #64748b; line-height: 1.7; margin-top: 0;">
                    <p style="margin-top: 15px; margin-bottom: 0;">@faq.Answer</p>
                </div>
            </div>
        }
    </div>
</section>

<script>
    // Accordion Logic
    document.querySelectorAll('.faq-question').forEach(question => {
        question.addEventListener('click', () => {
            const answer = question.nextElementSibling;
            const icon = question.querySelector('.faq-icon');
            
            if (answer.style.maxHeight && answer.style.maxHeight !== '0px') {
                answer.style.maxHeight = '0px';
                icon.textContent = '+';
                icon.style.transform = 'rotate(0deg)';
            } else {
                answer.style.maxHeight = answer.scrollHeight + 'px';
                icon.textContent = '−';
                icon.style.transform = 'rotate(180deg)';
            }
        });
    });

    // Search Logic
    const searchInput = document.getElementById('faq-search');
    searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();
        document.querySelectorAll('.faq-item').forEach(item => {
            const questionText = item.querySelector('h3').textContent.toLowerCase();
            const answerText = item.querySelector('.faq-answer p').textContent.toLowerCase();
            
            if (questionText.includes(query) || answerText.includes(query)) {
                item.style.display = 'block';
            } else {
                item.style.display = 'none';
            }
        });
    });

    // Category Filter Logic
    function filterCategory(cat) {
        // Remove active styling from all category cards
        document.querySelectorAll('.faq-cat-card').forEach(card => {
            card.style.borderColor = '#e5e7eb';
            card.style.background = '#ffffff';
        });

        // Add active style to selected card
        const selectedCard = event.currentTarget;
        selectedCard.style.borderColor = '#020617';
        selectedCard.style.background = '#f8fafc';

        // Filter items
        document.querySelectorAll('.faq-item').forEach(item => {
            if (cat === 'all' || item.getAttribute('data-category') === cat) {
                item.style.display = 'block';
            } else {
                item.style.display = 'none';
            }
        });
    }
</script>