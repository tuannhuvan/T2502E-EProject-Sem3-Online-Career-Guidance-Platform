@model IEnumerable<Career_Guidance_Platform.Models.CommunityPost>
@{
    ViewData["Title"] = "Cộng đồng hướng nghiệp";
}

<section class="page-hero">
    <span class="page-badge">👥 Cộng đồng CareerPath</span>
    <h1>Kết nối & Chia sẻ kinh nghiệm</h1>
    <p>Không gian giao lưu thảo luận, chia sẻ tài nguyên học tập và kinh nghiệm phỏng vấn cùng hàng ngàn thành viên và chuyên gia hướng nghiệp.</p>
</section>

<section class="content-section">
    <!-- Community Top Stats & Actions -->
    <div class="info-card" style="display: flex; justify-content: space-between; align-items: center; padding: 24px 32px; margin-bottom: 32px; flex-wrap: wrap; gap: 20px;">
        <div style="display: flex; gap: 40px;">
            <div>
                <strong style="font-size: 24px; color: #020617; display: block;">15,240+</strong>
                <span style="font-size: 13px; color: #64748b;">Thành viên hoạt động</span>
            </div>
            <div style="border-right: 1px solid #e5e7eb; height: 40px; align-self: center;"></div>
            <div>
                <strong style="font-size: 24px; color: #020617; display: block;">3,850+</strong>
                <span style="font-size: 13px; color: #64748b;">Chủ đề thảo luận</span>
            </div>
            <div style="border-right: 1px solid #e5e7eb; height: 40px; align-self: center;"></div>
            <div>
                <strong style="font-size: 24px; color: #020617; display: block;">98%</strong>
                <span style="font-size: 13px; color: #64748b;">Tỷ lệ phản hồi từ Mentor</span>
            </div>
        </div>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <button class="btn primary-btn" onclick="openCreatePostModal()" style="border-radius: 12px; font-weight: 700; height: 48px; border: none; padding: 0 24px; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer;">
                <span>✍️</span> Tạo thảo luận mới
            </button>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Home/Community" class="btn primary-btn" style="border-radius: 12px; font-weight: 700; height: 48px; border: none; padding: 0 24px; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; text-decoration: none; box-sizing: border-box; line-height: 48px;">
                <span>✍️</span> Đăng nhập để thảo luận
            </a>
        }
    </div>

    <!-- Forum Layout -->
    <div style="display: grid; grid-template-columns: 1fr 300px; gap: 32px; align-items: start;">
        <!-- Left: Forum Posts List -->
        <div style="display: flex; flex-direction: column; gap: 18px;">
            @foreach (var post in Model)
            {
                <div class="info-card" style="padding: 24px; transition: 0.25s;" onmouseover="this.style.borderColor='#020617'" onmouseout="this.style.borderColor='#e5e7eb'">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
                        <span style="font-size: 12px; font-weight: 700; color: #4f46e5; text-transform: uppercase; letter-spacing: 0.5px; background: #e0e7ff; padding: 4px 10px; border-radius: 999px;">@post.Category</span>
                        <span style="font-size: 12px; color: #94a3b8;">📅 @post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    
                    <h3 style="font-size: 20px; color: #020617; margin: 0 0 10px; line-height: 1.4;">
                        <a asp-controller="Home" asp-action="PostDetails" asp-route-id="@post.Id" style="color: inherit; text-decoration: none; font-weight: 700;">@post.Title</a>
                    </h3>
                    
                    <p style="color: #64748b; font-size: 14px; line-height: 1.6; margin: 0 0 20px;">@post.Content</p>
                    
                    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #e2e8f0; padding-top: 16px; font-size: 13px;">
                        <div style="display: flex; align-items: center; gap: 12px; color: #64748b;">
                            <span>👤 Đăng bởi: <strong>@post.AuthorName</strong></span>
                        </div>
                        <div style="display: flex; gap: 20px; color: #64748b;">
                            <span data-post-id="@post.Id" class="like-btn" style="display: flex; align-items: center; gap: 4px; cursor: pointer;" onclick="likePost(@post.Id, this)">👍 <span class="like-count">@post.LikesCount</span></span>
                            <a asp-controller="Home" asp-action="PostDetails" asp-route-id="@post.Id" style="display: flex; align-items: center; gap: 4px; text-decoration: none; color: inherit;">💬 @post.RepliesCount Phản hồi</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Right: Community Sidebar -->
        <div style="display: flex; flex-direction: column; gap: 20px;">
            <div class="info-card">
                <h3 style="font-size: 18px; color: #020617; margin-bottom: 15px;">🔥 Chủ đề hot tuần này</h3>
                <ul style="padding-left: 15px; margin: 0; color: #64748b; font-size: 13px; line-height: 1.8;">
                    @{
                        var hotPosts = Model?
                            .Where(p => p.CreatedAt >= DateTime.Now.AddDays(-7))
                            .OrderByDescending(p => p.LikesCount + p.RepliesCount)
                            .Take(5)
                            .ToList();
                        if (hotPosts == null || !hotPosts.Any())
                        {
                            hotPosts = Model?
                                .OrderByDescending(p => p.LikesCount + p.RepliesCount)
                                .Take(5)
                                .ToList();
                        }
                    }
                    @if (hotPosts != null && hotPosts.Any())
                    {
                        foreach (var post in hotPosts)
                        {
                            <li style="margin-bottom: 10px;">
                                <a asp-controller="Home" asp-action="PostDetails" asp-route-id="@post.Id" style="color: inherit; text-decoration: none; font-weight: 500; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@post.Title">
                                    @post.Title
                                </a>
                                <span style="font-size: 11px; color: #94a3b8; display: block;">👍 @post.LikesCount lượt thích · 💬 @post.RepliesCount phản hồi</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li style="margin-bottom: 10px;"><a href="#" style="color: inherit; text-decoration: none; font-weight: 500;">Cách Deal lương thử việc cho Dev Intern</a></li>
                        <li style="margin-bottom: 10px;"><a href="#" style="color: inherit; text-decoration: none; font-weight: 500;">Review phỏng vấn Kế toán tại BIG4</a></li>
                        <li style="margin-bottom: 10px;"><a href="#" style="color: inherit; text-decoration: none; font-weight: 500;">Tài liệu tự học Figma cơ bản cho UI/UX</a></li>
                    }
                </ul>
            </div>
            
            <div class="info-card" style="background: linear-gradient(135deg, #4f46e5 0%, #312e81 100%); color: #ffffff; border: none;">
                <h3 style="color: #ffffff; font-size: 18px; margin-bottom: 10px;">🌟 Trở thành Mentor cộng đồng</h3>
                <p style="font-size: 13px; line-height: 1.6; color: #e0e7ff; margin-bottom: 20px;">Bạn muốn chia sẻ kinh nghiệm sự nghiệp và dẫn dắt các thế hệ đàn em?</p>
                <button onclick="showToast('Đang chuyển hướng tới form ứng tuyển Mentor...', 'info')" style="width: 100%; height: 42px; border-radius: 10px; background: #ffffff; color: #4f46e5; border: none; font-weight: 700; cursor: pointer; transition: 0.2s;">Đăng ký Mentor ngay</button>
            </div>
        </div>
    </div>
</section>

<!-- Create Post Modal -->
<div id="createPostModal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px); align-items: center; justify-content: center;">
    <div class="info-card" style="background-color: #ffffff; padding: 32px; border-radius: 24px; max-width: 600px; width: 90%; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); margin: auto;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #f1f5f9; padding-bottom: 15px;">
            <h3 style="margin: 0; font-size: 20px; color: #0f172a; font-weight: 800;">Tạo thảo luận mới</h3>
            <span style="font-size: 24px; color: #94a3b8; cursor: pointer; font-weight: 700;" onclick="closeCreatePostModal()">&times;</span>
        </div>

        <form asp-controller="Home" asp-action="CreatePost" method="post">
            @Html.AntiForgeryToken()

            <div style="margin-bottom: 18px;">
                <label style="display: block; font-size: 13.5px; font-weight: 600; color: #1e293b; margin-bottom: 6px;">Tiêu đề thảo luận</label>
                <input type="text" name="title" required placeholder="Nhập tiêu đề ngắn gọn, rõ nghĩa..." style="width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; background: white;" />
            </div>

            <div style="margin-bottom: 18px;">
                <label style="display: block; font-size: 13.5px; font-weight: 600; color: #1e293b; margin-bottom: 6px;">Chuyên mục</label>
                <select name="category" required style="width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; background: white;">
                    <option value="Hỏi đáp">Hỏi đáp & Thắc mắc</option>
                    <option value="Góc chia sẻ">Góc chia sẻ kinh nghiệm</option>
                    <option value="Tài nguyên học tập">Tài nguyên & Tài liệu</option>
                    <option value="Góp ý hệ thống">Góc góp ý & Phản hồi</option>
                </select>
            </div>

            <div style="margin-bottom: 24px;">
                <label style="display: block; font-size: 13.5px; font-weight: 600; color: #1e293b; margin-bottom: 6px;">Nội dung thảo luận</label>
                <textarea name="content" required placeholder="Mô tả chi tiết câu hỏi hoặc chia sẻ của bạn tại đây..." style="width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; min-height: 150px; resize: vertical;"></textarea>
            </div>

            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button type="button" class="btn secondary-btn" style="border-radius: 10px; font-weight: 700; padding: 10px 20px;" onclick="closeCreatePostModal()">Hủy bỏ</button>
                <button type="submit" class="btn" style="background: #4f46e5; color: white; border: none; padding: 10px 24px; border-radius: 10px; font-weight: 700; cursor: pointer;">Đăng bài viết</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openCreatePostModal() {
        document.getElementById("createPostModal").style.display = "flex";
    }

    function closeCreatePostModal() {
        document.getElementById("createPostModal").style.display = "none";
    }

    // Close when clicking outside modal
    window.onclick = function(event) {
        var modal = document.getElementById("createPostModal");
        if (event.target == modal) {
            modal.style.display = "none";
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        const likedPosts = JSON.parse(localStorage.getItem('likedPosts') || '[]');
        likedPosts.forEach(postId => {
            const elements = document.querySelectorAll(`[data-post-id="${postId}"]`);
            elements.forEach(element => {
                element.classList.add('liked');
                element.style.color = '#4f46e5';
                element.style.fontWeight = 'bold';
            });
        });
    });

    function likePost(postId, element) {
        const likedPosts = JSON.parse(localStorage.getItem('likedPosts') || '[]');
        const isAlreadyLiked = likedPosts.includes(postId);
        
        fetch(`/Home/LikePost/${postId}?isUnlike=${isAlreadyLiked}`, {
            method: 'POST'
        })
        .then(response => {
            if (!response.ok) {
                throw new Error('Network response was not ok');
            }
            return response.json();
        })
        .then(data => {
            if (data.success) {
                const countElement = element.querySelector('.like-count');
                if (countElement) {
                    countElement.textContent = data.likesCount;
                }
                
                const allElementsOfThisPost = document.querySelectorAll(`[data-post-id="${postId}"]`);
                if (isAlreadyLiked) {
                    // Unlike
                    const index = likedPosts.indexOf(postId);
                    if (index > -1) likedPosts.splice(index, 1);
                    allElementsOfThisPost.forEach(el => {
                        el.classList.remove('liked');
                        el.style.color = 'inherit';
                        el.style.fontWeight = 'normal';
                    });
                    showToast('Đã bỏ thích bài viết!', 'info');
                } else {
                    // Like
                    likedPosts.push(postId);
                    allElementsOfThisPost.forEach(el => {
                        el.classList.add('liked');
                        el.style.color = '#4f46e5';
                        el.style.fontWeight = 'bold';
                    });
                    showToast('Đã thích bài viết!', 'success');
                }
                localStorage.setItem('likedPosts', JSON.stringify(likedPosts));
            } else {
                showToast('Không thể thực hiện hành động.', 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Có lỗi xảy ra, vui lòng thử lại.', 'error');
        });
    }
</script>