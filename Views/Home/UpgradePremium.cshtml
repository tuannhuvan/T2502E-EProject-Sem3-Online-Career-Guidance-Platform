@model Career_Guidance_Platform.Models.User
@{
    ViewData["Title"] = "Nâng cấp Premium - CareerPath";
}

<section class="page-hero" style="background: radial-gradient(circle at top left, #e0f2fe 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); padding-bottom: 20px;">
    <span class="page-badge">💎 Thành viên VIP</span>
    <h1>Nâng cấp tài khoản Premium</h1>
    <p>Mở khóa không giới hạn lượt làm bài kiểm tra đánh giá, truy cập đầy đủ kho học liệu và sơ đồ lộ trình nâng cao.</p>
</section>

<section class="content-section" style="max-width: 900px; padding-top: 10px;">
    @if (TempData["PremiumLimitMessage"] != null)
    {
        <div style="background: #fffbeb; border: 1px solid #fef08a; border-left: 5px solid #eab308; color: #854d0e; padding: 18px 24px; border-radius: 16px; margin-bottom: 30px; font-weight: 600; line-height: 1.6; font-size: 14.5px; box-shadow: 0 4px 15px rgba(234, 179, 8, 0.05);">
            ⚠️ @TempData["PremiumLimitMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background: #fef2f2; border: 1px solid #fecaca; border-left: 5px solid #ef4444; color: #991b1b; padding: 18px 24px; border-radius: 16px; margin-bottom: 30px; font-weight: 600; font-size: 14.5px;">
            ❌ @TempData["ErrorMessage"]
        </div>
    }

    <!-- Comparison Table / Grid -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-bottom: 48px;">
        
        <!-- Free Package -->
        <div class="info-card" style="padding: 35px 30px; border-radius: 24px; border: 1px solid #e2e8f0; background: #ffffff; display: flex; flex-direction: column; height: 100%; transition: all 0.3s;">
            <span style="font-size: 12px; font-weight: 800; text-transform: uppercase; color: #64748b; background: #f1f5f9; padding: 4px 10px; border-radius: 6px; display: inline-block; width: fit-content; margin-bottom: 15px;">FREE TIER</span>
            <h3 style="font-size: 26px; font-weight: 900; color: #020617; margin: 0 0 10px 0;">Miễn phí</h3>
            <div style="font-size: 32px; font-weight: 900; color: #020617; margin-bottom: 25px;">0 VNĐ <span style="font-size: 14px; color: #64748b; font-weight: 500;">/ trọn đời</span></div>
            
            <ul style="list-style: none; padding: 0; margin: 0 0 35px 0; display: flex; flex-direction: column; gap: 14px; font-size: 14px; color: #475569; flex-grow: 1;">
                <li style="display: flex; align-items: center; gap: 8px;">✔️ Giới hạn tối đa 3 lần làm test</li>
                <li style="display: flex; align-items: center; gap: 8px;">✔️ Xem lộ trình của 3 lần test đó</li>
                <li style="display: flex; align-items: center; gap: 8px;">✔️ Tạo CV cá nhân (CV Builder)</li>
                <li style="display: flex; align-items: center; gap: 8px;">✔️ Tìm việc làm & Ứng tuyển</li>
                <li style="color: #cbd5e1; text-decoration: line-through; display: flex; align-items: center; gap: 8px;">❌ Làm trắc nghiệm không giới hạn</li>
                <li style="color: #cbd5e1; text-decoration: line-through; display: flex; align-items: center; gap: 8px;">❌ Truy cập toàn bộ kho tài liệu nâng cao</li>
                <li style="color: #cbd5e1; text-decoration: line-through; display: flex; align-items: center; gap: 8px;">❌ Hỗ trợ ưu tiên từ Mentor</li>
            </ul>
            
            <button class="btn secondary-btn" disabled style="width: 100%; justify-content: center; opacity: 0.6; cursor: not-allowed; border-radius: 12px; padding: 12px;">Gói hiện tại của bạn</button>
        </div>

        <!-- Premium Package -->
        <div class="info-card" style="padding: 35px 30px; border-radius: 24px; border: 2px solid #3b82f6; background: #ffffff; display: flex; flex-direction: column; height: 100%; position: relative; box-shadow: 0 15px 35px -10px rgba(59, 130, 246, 0.15); transform: translateY(-4px);">
            <span style="position: absolute; top: -14px; left: 30px; background: #3b82f6; color: white; font-size: 11px; font-weight: 800; text-transform: uppercase; padding: 4px 12px; border-radius: 12px; letter-spacing: 0.5px;">Phổ biến nhất 🔥</span>
            
            <span style="font-size: 12px; font-weight: 800; text-transform: uppercase; color: #3b82f6; background: #eff6ff; padding: 4px 10px; border-radius: 6px; display: inline-block; width: fit-content; margin-bottom: 15px;">PREMIUM MEMBER</span>
            <h3 style="font-size: 26px; font-weight: 900; color: #020617; margin: 0 0 10px 0;">Premium VIP</h3>
            <div style="font-size: 32px; font-weight: 900; color: #020617; margin-bottom: 25px;">Chỉ 1 $ <span style="font-size: 14px; color: #64748b; font-weight: 500;">/ mua một lần, dùng vĩnh viễn</span></div>
            
            <ul style="list-style: none; padding: 0; margin: 0 0 35px 0; display: flex; flex-direction: column; gap: 14px; font-size: 14px; color: #0f172a; flex-grow: 1;">
                <li style="display: flex; align-items: center; gap: 8px;">💎 <strong>Làm bài đánh giá nghề nghiệp không giới hạn</strong></li>
                <li style="display: flex; align-items: center; gap: 8px;">💎 <strong>Truy cập toàn bộ học liệu & tài nguyên</strong></li>
                <li style="display: flex; align-items: center; gap: 8px;">💎 <strong>Mở khóa tất cả lộ trình nghề nghiệp (Roadmaps)</strong></li>
                <li style="display: flex; align-items: center; gap: 8px;">💎 Ưu tiên kết nối và đặt lịch hẹn Mentor</li>
                <li style="display: flex; align-items: center; gap: 8px;">💎 Đồng bộ tiến độ học tập và tích lũy kỹ năng VIP</li>
                <li style="display: flex; align-items: center; gap: 8px;">💎 Nhận huy hiệu Premium nổi bật trên hồ sơ cá nhân</li>
            </ul>

            <!-- PayPal Sandbox direct payment -->
            <form asp-controller="Home" asp-action="UpgradeToPremium" method="post" style="margin: 0; width: 100%;" id="paypalPaymentForm">
                @Html.AntiForgeryToken()
                
                <button type="submit" class="btn primary-btn" id="btnPaypalCheckout" style="width: 100%; justify-content: center; background: #ffc439; border-color: #ffc439; color: #111; font-weight: 700; border-radius: 12px; padding: 12px; display: flex; align-items: center; gap: 10px; transition: all 0.2s;">
                    <span style="font-style: italic; font-weight: 800; font-size: 16px; color: #003087;">Pay<span style="color: #0079c1;">Pal</span></span> 
                    <span>Thanh toán & Nâng cấp VIP</span>
                </button>
            </form>
        </div>

    </div>

    <!-- Features explanation -->
    <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 30px; border-radius: 20px; text-align: center;">
        <h4 style="margin-top: 0; margin-bottom: 8px; font-size: 16px; color: #0f172a; font-weight: 700;">Hỗ trợ thanh toán toàn cầu và an toàn</h4>
        <p style="margin: 0; font-size: 13.5px; color: #64748b; line-height: 1.6;">Giao dịch được bảo mật và xử lý trực tiếp thông qua cổng thanh toán PayPal quốc tế. Sau khi thanh toán thành công, tài khoản của bạn sẽ lập tức được chuyển sang trạng thái Premium VIP vĩnh viễn.</p>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const btnCheckout = document.getElementById("btnPaypalCheckout");
        const form = document.getElementById("paypalPaymentForm");

        if (btnCheckout && form) {
            form.addEventListener("submit", function() {
                btnCheckout.disabled = true;
                btnCheckout.innerHTML = "⌛ Đang chuyển hướng sang PayPal...";
            });
        }
    });
</script>
