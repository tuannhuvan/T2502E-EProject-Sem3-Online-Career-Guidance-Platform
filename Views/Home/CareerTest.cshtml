@model Career_Guidance_Platform.Models.ViewModels.TakeTestViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Đánh giá nghề nghiệp";
}

<section class="career-test-hero">
    <span class="page-badge">🧭 Career Assessment</span>
    <h1>Khám phá nghề nghiệp phù hợp với bạn</h1>
    <p>Trả lời bài đánh giá mẫu để hệ thống tính điểm và gợi ý nghề nghiệp phù hợp.</p>
    <!-- ... your existing static markup ... -->
</section>

<section class="content-section">
    <div class="career-test-main-full">
        <!-- Progress Bar -->
        <div class="test-progress-container" style="margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; font-size: 0.9rem; font-weight: 600; color: #4b5563;">
                <span id="questionCounter">Câu hỏi 0/0</span>
                <span id="progressText">Hoàn thành 0%</span>
            </div>
            <div style="width: 100%; height: 8px; background: #e5e7eb; border-radius: 999px; overflow: hidden;">
                <div id="progressBar" style="width: 0%; height: 100%; background: #020617; transition: width 0.3s ease;"></div>
            </div>
        </div>

        <div id="questionCard" class="question-card">
            <!-- JS will render question content -->
            <div class="question-header">
                <strong id="questionGroup">Nhóm: ...</strong>
            </div>
            <h2 id="questionTitle">Loading...</h2>
            <p class="question-desc">Hãy chọn phương án mô tả đúng nhất với bạn.</p>
            <div id="answerList" class="answer-list detailed"></div>
            <div class="test-actions">
                <button id="prevBtn" class="secondary-btn" type="button">Quay lại</button>
                <button id="nextBtn" class="primary-btn" type="button">Tiếp tục</button>
            </div>
        </div>

        <div id="resultBox" class="sample-result hidden">
            <div class="section-title">
                <span>📊 Kết quả bài test</span>
                <h3>Nghề nghiệp phù hợp với bạn</h3>
            </div>
            <div id="resultGrid" class="result-grid"></div>
            <div class="result-actions">
                <button id="restartBtn" class="secondary-btn" type="button">Làm lại bài test</button>
                <a class="primary-btn" asp-controller="Home" asp-action="CareerPath">Xem lộ trình nghề nghiệp</a>
            </div>
        </div>
    </div>
</section>

@* Hidden antiforgery token (rendered into a tiny hidden form for JS to copy) *@
<form id="__antiForgeryForm" style="display:none">
    @Html.AntiForgeryToken()
</form>

@* Embed server questions JSON for the JS to consume *@
<script>
    var serverQuestions = @Html.Raw(JsonSerializer.Serialize(Model.Questions));
    var serverTestId = @Model.TestId;
</script>

<script src="~/js/career-test.js" asp-append-version="true"></script>