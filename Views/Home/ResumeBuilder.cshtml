        const btnSaveResume = document.getElementById("btnSaveResume");
        if (btnSaveResume) {
            btnSaveResume.addEventListener("click", function() {
                const title = prompt("Nhập tiêu đề cho CV của bạn:", cvTitle);
                if (title === null) return; // user cancelled
                
                if (title.trim() === "") {
                    alert("Tiêu đề không được để trống!");
                    return;
                }
                
                cvTitle = title;
                
                // Show saving indicator
                const originalText = btnSaveResume.innerHTML;
                btnSaveResume.innerHTML = "⏳ Đang lưu...";
                btnSaveResume.disabled = true;
                
                fetch("/Manage/SaveResume", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        id: cvId,
                        title: cvTitle,
                        contentJson: JSON.stringify(cvData)
                    })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        cvId = data.id;
                        alert("Lưu CV thành công!");
                    } else {
                        alert("Lưu thất bại: " + data.message);
                    }
                })
                .catch(err => {
                    console.error("Lỗi lưu CV:", err);
                    alert("Có lỗi xảy ra trong quá trình lưu CV. Vui lòng thử lại.");
                })
                .finally(() => {
                    btnSaveResume.innerHTML = originalText;
                    btnSaveResume.disabled = false;
                });
            });
        }

