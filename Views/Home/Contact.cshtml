@{
    ViewData["Title"] = "Liên hệ";
}

<section class="page-hero">
    <span class="page-badge">📞 Liên hệ với chúng tôi</span>
    <h1>Kết nối với CareerPath</h1>
    <p>Bạn có câu hỏi, đóng góp ý kiến hoặc muốn hợp tác? Hãy gửi tin nhắn cho chúng tôi, đội ngũ hỗ trợ sẽ phản hồi bạn sớm nhất có thể.</p>
</section>

<section class="content-section">
    @if (TempData["ContactSuccess"] != null)
    {
        <div class="alert-success" style="padding: 20px; background-color: #d1e7dd; color: #0f5132; border: 1px solid #badbcc; border-radius: 16px; margin-bottom: 30px; font-weight: 500;">
            ✅ @TempData["ContactSuccess"]
        </div>
    }

    <div class="contact-grid">
        <div class="info-card">
            <h2>Gửi tin nhắn trực tuyến</h2>
            <p style="margin-bottom: 30px; color: #64748b;">Điền đầy đủ thông tin vào form dưới đây để gửi trực tiếp đến bộ phận chăm sóc khách hàng.</p>
            
            <form asp-controller="Home" asp-action="Contact" method="post" class="contact-form">
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                    <div>
                        <label for="name" style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #020617;">Họ và tên</label>
                        <input type="text" id="name" name="name" required placeholder="Nguyễn Văn A" style="width: 100%; height: 50px; border: 1px solid #d1d5db; border-radius: 12px; padding: 0 16px; outline: none; font-size: 15px;" />
                    </div>
                    <div>
                        <label for="email" style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #020617;">Email liên hệ</label>
                        <input type="email" id="email" name="email" required placeholder="example@email.com" style="width: 100%; height: 50px; border: 1px solid #d1d5db; border-radius: 12px; padding: 0 16px; outline: none; font-size: 15px;" />
                    </div>
                </div>
                
                <div style="margin-top: 16px;">
                    <label for="subject" style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #020617;">Chủ đề</label>
                    <input type="text" id="subject" name="subject" required placeholder="Hỏi về bài test, đề xuất hợp tác..." style="width: 100%; height: 50px; border: 1px solid #d1d5db; border-radius: 12px; padding: 0 16px; outline: none; font-size: 15px;" />
                </div>
                
                <div style="margin-top: 16px;">
                    <label for="message" style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #020617;">Nội dung tin nhắn</label>
                    <textarea id="message" name="message" required placeholder="Nhập nội dung tin nhắn chi tiết tại đây..." style="width: 100%; min-height: 150px; border: 1px solid #d1d5db; border-radius: 12px; padding: 16px; outline: none; font-size: 15px; resize: vertical; font-family: inherit;"></textarea>
                </div>
                
                <button type="submit" class="btn primary-btn" style="height: 50px; border-radius: 12px; font-weight: 700; font-size: 16px; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; margin-top: 10px; width: 100%;">Gửi tin nhắn</button>
            </form>
        </div>

        <div style="display: flex; flex-direction: column; gap: 20px;">
            <div class="info-card">
                <h3>📍 Địa chỉ văn phòng</h3>
                <p style="color: #64748b; line-height: 1.6;">Tòa nhà Công nghệ, Đường số 8, Khu đô thị mới, Cầu Giấy, Hà Nội</p>
            </div>
            <div class="info-card">
                <h3>📧 Email & Hotline</h3>
                <p style="color: #64748b; line-height: 1.6; margin-bottom: 8px;"><strong>Hỗ trợ chung:</strong> support@careerpath.vn</p>
                <p style="color: #64748b; line-height: 1.6; margin-bottom: 8px;"><strong>Hợp tác:</strong> partner@careerpath.vn</p>
                <p style="color: #64748b; line-height: 1.6; margin-bottom: 0;"><strong>Hotline:</strong> 1900 xxxx (8:00 - 17:30, Thứ 2 - Thứ 7)</p>
            </div>
            <div class="info-card" style="padding: 0; overflow: hidden; height: 260px; border-radius: 20px; position: relative;">
                <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 20px; box-sizing: border-box;">
                    <span style="font-size: 40px; margin-bottom: 10px;">🗺️</span>
                    <strong style="color: #020617; font-size: 16px;">Bản đồ CareerPath</strong>
                    <p style="font-size: 13px; color: #64748b; margin: 4px 0 0;">Cầu Giấy, Hà Nội, Việt Nam</p>
                    <a href="https://maps.google.com" target="_blank" class="btn secondary-btn" style="margin-top: 15px; border-radius: 8px; font-size: 13px; font-weight: 600;">Xem trên Google Maps</a>
                </div>
            </div>
        </div>
    </div>
</section>