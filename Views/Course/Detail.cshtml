@model Career_Guidance_Platform.Models.CareerPathCourse
@using Career_Guidance_Platform.Models

@{
    ViewData["Title"] = "Khóa học - " + Model.Title;
    var resources = ViewBag.Resources as List<Resource>;
    var progress = ViewBag.Progress as UserCourseProgress;
}

<section class="page-hero" style="background: radial-gradient(circle at top left, #f5f3ff 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); border-bottom: 1px solid #f1f5f9;">
    <span class="page-badge">📘 Khóa học chi tiết</span>
    <h1 style="max-width: 800px; margin-left: auto; margin-right: auto;">@Model.Title</h1>
    <p style="max-width: 700px; margin-left: auto; margin-right: auto;">@Model.Description</p>
</section>

<section class="content-section" style="max-width: 1000px; padding: 50px 24px;">
    @if (TempData["CourseSuccessMessage"] != null)
    {
        <div style="background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 18px 24px; border-radius: 16px; margin-bottom: 30px; font-weight: 700; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.05);">
            <span>🎉</span> @TempData["CourseSuccessMessage"]
        </div>
    }
    @if (TempData["CourseTestMessage"] != null)
    {
        <div style="background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 18px 24px; border-radius: 16px; margin-bottom: 30px; font-weight: 700; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.05);">
            <span>⚠️</span> @TempData["CourseTestMessage"]
        </div>
    }

    <div class="info-card" style="padding: 36px; margin-bottom: 36px; border-radius: 24px; border: 1px solid #e2e8f0; background: #ffffff; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.04);">
        <h2 style="font-size: 22px; font-weight: 800; color: #0f172a; margin-top: 0; margin-bottom: 24px; display: flex; align-items: center; gap: 8px;">
            <span>ℹ️</span> Thông tin khóa học
        </h2>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; background: #f8fafc; padding: 20px; border-radius: 14px; border: 1px solid #e2e8f0;">
            <div>
                <span style="font-size: 13px; color: #64748b; display: block; margin-bottom: 4px; font-weight: 600;">LỘ TRÌNH</span>
                <strong style="font-size: 16px; color: #0f172a;">🧭 @(Model.CareerPath?.Title ?? "Định hướng nghề nghiệp")</strong>
            </div>
            <div>
                <span style="font-size: 13px; color: #64748b; display: block; margin-bottom: 4px; font-weight: 600;">THỜI GIAN HỌC</span>
                <strong style="font-size: 16px; color: #0f172a;">⏱️ @Model.EstimatedDays ngày học tập</strong>
            </div>
        </div>

        @if (progress == null)
        {
            <div style="padding: 30px; border-radius: 20px; background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%); border: 1px solid #cbd5e1; text-align: center;">
                <h3 style="margin-top: 0; color: #3730a3; font-weight: 800; font-size: 18px; margin-bottom: 10px;">Bạn chưa bắt đầu khóa học này</h3>
                <p style="color: #4338ca; margin-bottom: 24px; line-height: 1.6; max-width: 600px; margin-left: auto; margin-right: auto; font-size: 14.5px;">
                    Sau khi bấm nút bắt đầu học, hệ thống sẽ tự động tính thời hạn hoàn thành dựa trên số ngày khóa học và mở khóa tài liệu học tập cùng bài kiểm tra cuối kỳ.
                </p>

                <a asp-controller="Course"
                   asp-action="Start"
                   asp-route-id="@Model.Id"
                   class="btn primary-btn"
                   style="padding: 14px 36px; font-size: 15px; border-radius: 10px; display: inline-flex;">
                    🚀 Bắt đầu học tập ngay
                </a>
            </div>
        }
        else
        {
            <div style="padding: 28px; border-radius: 20px; background: #ffffff; border: 1px solid #e2e8f0; box-shadow: 0 4px 15px rgba(0,0,0,0.01);">
                <h3 style="margin-top: 0; font-size: 18px; font-weight: 800; color: #0f172a; margin-bottom: 20px; border-bottom: 1px solid #f1f5f9; padding-bottom: 10px;">📊 Tiến độ & Trạng thái</h3>

                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
                    <div>
                        <span style="font-size: 13px; color: #64748b; display: block; margin-bottom: 4px;">Ngày bắt đầu</span>
                        <strong style="color: #334155; font-size: 15px;">📅 @progress.StartDate.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                    <div>
                        <span style="font-size: 13px; color: #64748b; display: block; margin-bottom: 4px;">Hạn hoàn thành</span>
                        <strong style="color: #334155; font-size: 15px;">⏳ @progress.DeadlineDate.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                    <div>
                        <span style="font-size: 13px; color: #64748b; display: block; margin-bottom: 4px;">Trạng thái học</span>
                        @if (progress.Status == "Learning")
                        {
                            <span style="background: #dbeafe; color: #1d4ed8; padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 13px; border: 1px solid #bfdbfe; display: inline-block;">
                                Đang học
                            </span>
                        }
                        else if (progress.Status == "Completed")
                        {
                            <span style="background: #dcfce7; color: #15803d; padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 13px; border: 1px solid #bbf7d0; display: inline-block;">
                                Hoàn thành
                            </span>
                        }
                        else if (progress.Status == "Expired")
                        {
                            <span style="background: #fee2e2; color: #b91c1c; padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 13px; border: 1px solid #fecaca; display: inline-block;">
                                Hết hạn
                            </span>
                        }
                        else
                        {
                            <strong style="color: #334155; font-size: 15px;">@progress.Status</strong>
                        }
                    </div>
                </div>

                <div style="margin-bottom: 28px; border-top: 1px solid #f1f5f9; padding-top: 20px;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 14.5px;">
                        <strong style="color: #475569;">Tiến trình học tập</strong>
                        <strong style="color: #4f46e5;">@progress.ProgressPercent%</strong>
                    </div>

                    <div style="height: 12px; background: #e2e8f0; border-radius: 999px; overflow: hidden; box-shadow: inset 0 1px 2px rgba(0,0,0,0.05);">
                        <div style="height: 100%; width: @progress.ProgressPercent%; background: linear-gradient(90deg, #4f46e5 0%, #06b6d4 100%); border-radius: 999px; transition: width 0.5s ease;"></div>
                    </div>
                </div>

                @if (progress.Status == "Learning")
                {
                    <div class="countdown-panel" style="margin-bottom: 28px;">
                        <h3 style="margin-top: 0; color: #94a3b8; font-size: 14px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">⏳ Thời gian làm bài test còn lại</h3>
                        <div id="countdown" class="countdown-timer" data-deadline="@progress.DeadlineDate.ToString("yyyy-MM-ddTHH:mm:ss")">
                            Đang kết nối thời gian...
                        </div>
                        <p style="color: #fca5a5; font-size: 13px; margin: 0;">
                            Bạn bắt buộc phải thực hiện bài trắc nghiệm khóa học trước khi thời hạn đếm ngược kết thúc.
                        </p>
                    </div>

                    <div style="margin-top: 24px; display: flex; justify-content: center; gap: 16px;">
                        <a href="#resources" class="btn secondary-btn" style="padding: 12px 24px; font-size: 14.5px;">
                            📚 Xem tài liệu học tập
                        </a>

                        <a asp-controller="Course"
                           asp-action="Test"
                           asp-route-id="@Model.Id"
                           class="btn"
                           style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 12px 28px; border-radius: 12px; font-weight: 700; box-shadow: 0 4px 14px rgba(16, 185, 129, 0.25); text-decoration: none; font-size: 14.5px;">
                            📝 Làm bài kiểm tra trắc nghiệm
                        </a>
                    </div>
                }
                else if (progress.Status == "Expired")
                {
                    <div style="padding: 24px; border-radius: 16px; background: #fff5f5; border: 1px solid #fecaca; text-align: center;">
                        <h3 style="margin-top: 0; color: #b91c1c; font-size: 17px; font-weight: 800; margin-bottom: 8px;">⚠️ Khóa học đã quá hạn hoàn thành</h3>
                        <p style="color: #991b1b; margin: 0; font-size: 14px;">
                            Bạn đã không thực hiện bài kiểm tra cuối khóa trong thời gian quy định. Vui lòng liên hệ quản trị viên hoặc gia hạn học tập.
                        </p>
                    </div>
                }
                else if (progress.Status == "Completed")
                {
                    <div style="padding: 24px; border-radius: 16px; background: #f0fdf4; border: 1px solid #bbf7d0; display: flex; align-items: center; justify-content: center; gap: 12px;">
                        <span style="font-size: 28px;">✅</span>
                        <div>
                            <h3 style="margin: 0; color: #15803d; font-size: 17px; font-weight: 800;">Chúc mừng! Bạn đã hoàn thành khóa học này</h3>
                            <p style="color: #166534; margin: 4px 0 0 0; font-size: 14px; font-weight: 700;">Điểm kiểm tra trắc nghiệm: @progress.TestScore / 100</p>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div id="resources" class="info-card" style="padding: 36px; border-radius: 24px; border: 1px solid #e2e8f0; background: #ffffff; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.04);">
        <h2 style="font-size: 22px; font-weight: 800; color: #0f172a; margin-top: 0; margin-bottom: 8px; display: flex; align-items: center; gap: 8px;">
            <span>📚</span> Tài liệu nghiên cứu học tập
        </h2>
        <p style="color: #64748b; font-size: 14.5px; margin-bottom: 24px;">Hãy chủ động đọc kỹ tài liệu nghiên cứu dưới đây trước khi thực hiện bài kiểm tra.</p>

        @if (resources != null && resources.Any())
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 20px;">
                @foreach (var item in resources)
                {
                    <div style="border: 1px solid #e2e8f0; border-radius: 16px; padding: 24px; background: #f8fafc; display: flex; flex-direction: column; height: 100%;">
                        <div style="margin-bottom: 12px;">
                            <span style="font-size: 11px; font-weight: 800; color: #0ea5e9; background: #e0f2fe; padding: 4px 10px; border-radius: 6px; border: 1px solid #bae6fd; text-transform: uppercase;">
                                📄 @item.ResourceType
                            </span>
                        </div>

                        <h3 style="font-size: 16.5px; font-weight: 800; color: #0f172a; margin: 0 0 20px 0; line-height: 1.4; flex-grow: 1;">
                            @item.Title
                        </h3>

                        <a href="@item.Url"
                           target="_blank"
                           class="btn primary-btn"
                           style="width: 100%; justify-content: center; font-size: 13.5px; padding: 10px; background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%); box-shadow: 0 4px 12px rgba(14, 165, 233, 0.2);">
                            📖 Mở tài liệu học
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="padding: 24px; text-align: center; background: #f8fafc; border-radius: 14px; border: 1px dashed #cbd5e1;">
                <p style="color: #64748b; font-style: italic; margin: 0;">Tài liệu nghiên cứu cho khóa học này đang được chuẩn bị. Vui lòng quay lại sau.</p>
            </div>
        }
    </div>

    <div style="margin-top: 40px; text-align: center;">
        <a asp-controller="CareerPath"
           asp-action="Roadmap"
           asp-route-id="@Model.CareerPathId"
           class="btn secondary-btn"
           style="padding: 12px 32px;">
            ⬅ Quay lại danh sách Lộ trình học
        </a>
    </div>
</section>

@section Scripts{
    <script src="~/js/course-detail.js"></script>
}