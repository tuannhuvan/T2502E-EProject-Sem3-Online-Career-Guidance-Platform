@model Career_Guidance_Platform.Models.CareerPath
@{
    ViewData["Title"] = "Lộ trình học tập - " + Model.Title;
    var courses = ViewBag.Courses as List<Career_Guidance_Platform.Models.CareerPathCourse>;
}

<section class="page-hero">
    <span class="page-badge">🚀 Lộ trình học tập</span>
    <h1>@Model.Title</h1>
    <p>Hoàn thành từng khóa học để tăng mức độ phù hợp với nghề nghiệp này.</p>
</section>

<section class="content-section" style="max-width: 1100px;">
    <h2 style="font-size: 26px; color: #020617; margin-bottom: 30px;">
        Danh sách khóa học trong lộ trình
    </h2>

    @if (courses != null && courses.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;">
            @foreach (var course in courses)
            {
                <div class="info-card" style="padding: 26px; border-radius: 20px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                        <span style="font-size:13px;font-weight:700;color:#4f46e5;background:#eef2ff;padding:6px 12px;border-radius:999px;">
                            Course @course.SortOrder
                        </span>

                        <span style="font-size:13px;color:#64748b;">
                            ⏱ @course.EstimatedDays ngày
                        </span>
                    </div>

                    <h3 style="font-size:21px;color:#020617;margin-bottom:10px;">
                        @course.Title
                    </h3>

                    <p style="font-size:14px;color:#64748b;line-height:1.7;min-height:70px;">
                        @course.Description
                    </p>

                    <a asp-controller="Course"
                       asp-action="Detail"
                       asp-route-id="@course.Id"
                       class="btn"
                       style="display:inline-block;background:#4f46e5;color:white;padding:10px 18px;border-radius:10px;font-weight:700;text-decoration:none;">
                        Bắt đầu học
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="info-card" style="padding:30px;">
            <p style="margin:0;color:#64748b;">
                Chưa có khóa học nào cho lộ trình này.
            </p>
        </div>
    }

    <div style="margin-top:40px;text-align:center;">
        <a asp-controller="CareerPath"
           asp-action="Details"
           asp-route-id="@Model.Id"
           class="btn secondary-btn">
            ⬅ Quay lại Career Path
        </a>
    </div>
</section>