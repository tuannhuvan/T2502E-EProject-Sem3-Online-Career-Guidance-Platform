@model Career_Guidance_Platform.Models.CareerPath
@{
    ViewData["Title"] = "Chi tiết Lộ trình: " + Model.Title;
}

<section class="page-hero" style="background: radial-gradient(circle at top left, #f5f3ff 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);">
    <span class="page-badge">🎯 Bản đồ sự nghiệp</span>
    <h1>@Model.Title</h1>
    <p>Lộ trình phát triển năng lực toàn diện được thiết kế bởi các chuyên gia trong ngành giúp bạn đi đúng hướng.</p>
</section>

<section class="content-section" style="max-width: 1100px;">
    <!-- Overview Card -->
    <div class="info-card" style="margin-bottom: 40px; border-left: 6px solid #4f46e5;">
        <h2 style="font-size: 24px; color: #020617; margin-bottom: 12px;">Tổng quan nghề nghiệp</h2>
        <p style="font-size: 16px; line-height: 1.7; color: #4b5563; margin: 0;">@Model.Content</p>
    </div>

    <!-- Timeline of Milestones -->
    <h2 style="font-size: 26px; color: #020617; margin-bottom: 30px; text-align: center;">🗺️ Các cột mốc thời gian & Lộ trình học tập</h2>
    
    <div style="display: flex; flex-direction: column; gap: 30px; position: relative; margin-bottom: 60px; padding-left: 30px; border-left: 2px solid #e5e7eb;">
        <!-- Milestone 1 -->
        <div style="position: relative;">
            <div style="position: absolute; left: -39px; top: 0; width: 16px; height: 16px; border-radius: 50%; background: #4f46e5; border: 4px solid #ffffff; box-shadow: 0 0 0 4px #e0e7ff;"></div>
            <div class="info-card" style="padding: 24px;">
                <span style="font-weight: 700; color: #4f46e5; font-size: 14px; text-transform: uppercase;">Tháng 1 - Tháng 3</span>
                <h3 style="font-size: 20px; color: #020617; margin: 6px 0 10px;">Giai đoạn 1: Nền tảng tư duy & Công cụ cơ bản</h3>
                <p style="font-size: 14px; line-height: 1.6; color: #64748b; margin-bottom: 15px;">Tập trung nắm vững các lý thuyết nền tảng, làm quen với bộ công cụ chuẩn và xây dựng phương pháp học tập chủ động.</p>
                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Lý thuyết cơ bản</span>
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Sử dụng công cụ chính</span>
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Bài tập thực hành nhỏ</span>
                </div>
            </div>
        </div>

        <!-- Milestone 2 -->
        <div style="position: relative;">
            <div style="position: absolute; left: -39px; top: 0; width: 16px; height: 16px; border-radius: 50%; background: #06b6d4; border: 4px solid #ffffff; box-shadow: 0 0 0 4px #cffafe;"></div>
            <div class="info-card" style="padding: 24px;">
                <span style="font-weight: 700; color: #0891b2; font-size: 14px; text-transform: uppercase;">Tháng 4 - Tháng 6</span>
                <h3 style="font-size: 20px; color: #020617; margin: 6px 0 10px;">Giai đoạn 2: Phát triển kỹ năng chuyên sâu & Dự án mẫu</h3>
                <p style="font-size: 14px; line-height: 1.6; color: #64748b; margin-bottom: 15px;">Đi sâu vào kiến thức nghiệp vụ nâng cao, tham gia làm các bài tập lớn mô phỏng dự án thực tế của doanh nghiệp để rèn luyện kỹ năng giải quyết vấn đề.</p>
                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Nghiệp vụ nâng cao</span>
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Thực hành dự án (Clone)</span>
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Tư duy hệ thống</span>
                </div>
            </div>
        </div>

        <!-- Milestone 3 -->
        <div style="position: relative;">
            <div style="position: absolute; left: -39px; top: 0; width: 16px; height: 16px; border-radius: 50%; background: #10b981; border: 4px solid #ffffff; box-shadow: 0 0 0 4px #d1fae5;"></div>
            <div class="info-card" style="padding: 24px;">
                <span style="font-weight: 700; color: #059669; font-size: 14px; text-transform: uppercase;">Tháng 7 - Tháng 12</span>
                <h3 style="font-size: 20px; color: #020617; margin: 6px 0 10px;">Giai đoạn 3: Hoàn thiện Portfolio & Kết nối thực tập</h3>
                <p style="font-size: 14px; line-height: 1.6; color: #64748b; margin-bottom: 15px;">Xây dựng hồ sơ năng lực (Portfolio) cá nhân ấn tượng. Luyện tập kỹ năng trả lời phỏng vấn và ứng tuyển vào các doanh nghiệp đối tác để bắt đầu kỳ thực tập chính thức.</p>
                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Xây dựng Portfolio</span>
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Luyện phỏng vấn</span>
                    <span style="font-size: 12px; font-weight: 600; color: #374151; background: #f3f4f6; padding: 4px 10px; border-radius: 6px;">Ứng tuyển Intern/Junior</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Partner Businesses -->
    <div class="info-card" style="background: #f0fdf4; border: 1px solid #d1fae5; padding: 32px; border-radius: 24px;">
        <h2 style="font-size: 24px; color: #065f46; margin-top: 0; margin-bottom: 12px; display: flex; align-items: center; gap: 10px;">
            <span>🏢</span> Doanh nghiệp đối tác tuyển dụng
        </h2>
        <p style="color: #047857; font-size: 15px; margin-bottom: 24px; line-height: 1.6;">Dưới đây là danh sách các đối tác chiến lược của CareerPath đang tìm kiếm ứng viên cho lộ trình này:</p>
        
        @if (ViewBag.Jobs != null && ((IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs).Any())
        {
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
                @foreach (var job in (IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs)
                {
                    <div style="background: #ffffff; border: 1px solid #e6f4ea; border-radius: 16px; padding: 20px; box-shadow: 0 4px 12px rgba(6, 95, 70, 0.04);">
                        <h4 style="margin: 0; color: #065f46; font-size: 17px; font-weight: 700;">@job.Title</h4>
                        <div style="font-size: 14px; color: #047857; font-weight: 600; margin: 6px 0;">💼 Công ty: @job.CompanyName</div>
                        @if (job.Salary > 0)
                        {
                            <div style="font-size: 14px; color: #10b981; font-weight: 700; margin-bottom: 10px;">💰 Lương: @job.Salary.ToString("N0") VNĐ</div>
                        }
                        <p style="font-size: 13px; color: #4b5563; line-height: 1.6; margin: 0 0 16px;">@job.Description</p>
                        <button class="btn" style="background: #10b981; color: white; border: none; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer;" onclick="alert('Đã gửi hồ sơ ứng tuyển của bạn đến @job.CompanyName!')">Ứng tuyển ngay</button>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: #065f46; font-style: italic; margin: 0;">Hiện tại chưa có tin tuyển dụng phù hợp cho lộ trình này. Vui lòng quay lại sau.</p>
        }
    </div>

    <!-- Back button -->
    <div style="text-align: center; margin-top: 40px;">
        <a href="javascript:history.back()" class="btn secondary-btn" style="padding: 12px 30px; border-radius: 12px; font-weight: 700;">⬅ Quay lại kết quả</a>
    </div>
</section>
