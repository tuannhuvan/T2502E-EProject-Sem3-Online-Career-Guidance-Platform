@model Career_Guidance_Platform.Models.CareerPath
@{
    ViewData["Title"] = "Chi tiết Lộ trình: " + Model.Title;
}

<section class="page-hero" style="background: radial-gradient(circle at top left, #f5f3ff 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);">
    <span class="page-badge">🎯 Bản đồ sự nghiệp</span>
    <h1>@Model.Title</h1>
    <p>Lộ trình phát triển năng lực toàn diện được thiết kế bởi các chuyên gia trong ngành giúp bạn đi đúng hướng.</p>
</section>

<section class="content-section" style="max-width: 1100px;">
    <!-- Overview Card -->
    <div class="info-card" style="margin-bottom: 40px; border-left: 6px solid #4f46e5;">
        <h2 style="font-size: 24px; color: #020617; margin-bottom: 12px;">Tổng quan nghề nghiệp</h2>
        <p style="font-size: 16px; line-height: 1.7; color: #4b5563; margin: 0;">@Model.Content</p>
    </div>

    <!-- Timeline of Milestones -->
    <h2 style="font-size: 26px; color: #020617; margin-bottom: 30px; text-align: center;">🗺️ Các cột mốc thời gian & Lộ trình học tập</h2>
    
    @if (ViewBag.Stages != null && ((IEnumerable<Career_Guidance_Platform.Models.CareerStage>)ViewBag.Stages).Any())
    {
        <div style="display: flex; flex-direction: column; gap: 30px; position: relative; margin-bottom: 60px; padding-left: 30px; border-left: 2px solid #e5e7eb;">
            @foreach (var stage in (IEnumerable<Career_Guidance_Platform.Models.CareerStage>)ViewBag.Stages)
            {
                var bgColors = new[] { "#4f46e5", "#06b6d4", "#10b981", "#f59e0b" };
                var shadowColors = new[] { "#e0e7ff", "#cffafe", "#d1fae5", "#fef3c7" };
                var colorIdx = (stage.SequenceOrder - 1) % bgColors.Length;
                var color = bgColors[colorIdx];
                var shadow = shadowColors[colorIdx];

                <div style="position: relative;">
                    <div style="position: absolute; left: -39px; top: 0; width: 16px; height: 16px; border-radius: 50%; background: @color; border: 4px solid #ffffff; box-shadow: 0 0 0 4px @shadow;"></div>
                    <div class="info-card" style="padding: 24px;">
                        <span style="font-weight: 700; color: @color; font-size: 14px; text-transform: uppercase;">Cấp bậc @stage.SequenceOrder</span>
                        <h3 style="font-size: 20px; color: #020617; margin: 6px 0 10px;">@stage.Title</h3>
                        <p style="font-size: 14px; line-height: 1.6; color: #64748b; margin-bottom: 15px;">@stage.Description</p>
                        
                        @if (stage.CareerStageSkills != null && stage.CareerStageSkills.Any())
                        {
                            <div style="margin-top: 10px;">
                                <strong style="font-size: 13px; color: #1e293b; display: block; margin-bottom: 8px;">Kỹ năng yêu cầu:</strong>
                                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                                    @foreach (var css in stage.CareerStageSkills)
                                    {
                                        if (css.Skill != null)
                                        {
                                            <span style="font-size: 12px; font-weight: 600; color: #0f172a; background: #f1f5f9; padding: 6px 12px; border-radius: 6px; border: 1px solid #e2e8f0; display: inline-flex; align-items: center; gap: 4px;">
                                                ⚙️ @css.Skill.Name
                                                <span style="font-size: 10px; font-weight: 700; color: #4f46e5; background: #e0e7ff; padding: 2px 6px; border-radius: 4px;">@css.ProficiencyRequired</span>
                                            </span>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p style="text-align: center; color: #64748b; font-style: italic; margin-bottom: 60px;">Chưa có lộ trình cấp bậc nghề nghiệp được thiết lập cho ngành này.</p>
    }
    <div style="text-align: center; margin-top: 40px;">
        <a asp-controller="CareerPath"
           asp-action="Roadmap"
           asp-route-id="@Model.Id"
           class="btn"
           style="background:#4f46e5;color:white;padding:12px 30px;border-radius:12px;font-weight:700;text-decoration:none;">
            🚀 Xem lộ trình học tập
        </a>
    </div>

    <!-- Partner Businesses -->
    <div class="info-card" style="background: #f0fdf4; border: 1px solid #d1fae5; padding: 32px; border-radius: 24px;">
        <h2 style="font-size: 24px; color: #065f46; margin-top: 0; margin-bottom: 12px; display: flex; align-items: center; gap: 10px;">
            <span>🏢</span> Doanh nghiệp đối tác tuyển dụng
        </h2>
        <p style="color: #047857; font-size: 15px; margin-bottom: 24px; line-height: 1.6;">Dưới đây là danh sách các đối tác chiến lược của CareerPath đang tìm kiếm ứng viên cho lộ trình này:</p>
        
        @if (ViewBag.Jobs != null && ((IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs).Any())
        {
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
                @foreach (var job in (IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs)
                {
                    <div style="background: #ffffff; border: 1px solid #e6f4ea; border-radius: 16px; padding: 20px; box-shadow: 0 4px 12px rgba(6, 95, 70, 0.04);">
                        <h4 style="margin: 0; color: #065f46; font-size: 17px; font-weight: 700;">@job.Title</h4>
                        <div style="font-size: 14px; color: #047857; font-weight: 600; margin: 6px 0;">💼 Công ty: @job.CompanyName</div>
                        @if (job.Salary > 0)
                        {
                            <div style="font-size: 14px; color: #10b981; font-weight: 700; margin-bottom: 10px;">💰 Lương: @job.Salary.ToString("N0") VNĐ</div>
                        }
                        <p style="font-size: 13px; color: #4b5563; line-height: 1.6; margin: 0 0 16px;">@job.Description</p>
                        <button class="btn" style="background: #10b981; color: white; border: none; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer;" onclick="alert('Đã gửi hồ sơ ứng tuyển của bạn đến @job.CompanyName!')">Ứng tuyển ngay</button>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: #065f46; font-style: italic; margin: 0;">Hiện tại chưa có tin tuyển dụng phù hợp cho lộ trình này. Vui lòng quay lại sau.</p>
        }
    </div>

    <!-- Back button -->
    <div style="text-align: center; margin-top: 40px;">
        <a href="javascript:history.back()" class="btn secondary-btn" style="padding: 12px 30px; border-radius: 12px; font-weight: 700;">⬅ Quay lại kết quả</a>
    </div>
</section>
