@inject Microsoft.AspNetCore.Identity.UserManager<Career_Guidance_Platform.Models.User> UserManager
@{
    ViewData["Title"] = "Chi tiết Lộ trình: " + Model.Title;
    var currentUser = await UserManager.GetUserAsync(User);
    var isPremium = currentUser?.IsPremium == true || User.IsInRole("Admin") || User.IsInRole("Mentor");
    var testCount = currentUser?.TestAttemptsCount ?? 0;
    var isLimitReached = !isPremium && testCount >= 3;
}

<section class="page-hero" style="background: radial-gradient(circle at top left, #f5f3ff 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);">
    <div style="display: flex; justify-content: center; gap: 8px; flex-wrap: wrap; margin-bottom: 12px;">
        <span class="page-badge">🎯 Bản đồ sự nghiệp</span>
        @if (isPremium)
        {
            <span class="page-badge" style="background: #eff6ff; color: #3b82f6; border-color: #bfdbfe;">💎 Premium Account</span>
        }
    </div>
    <h1>@Model.Title</h1>
    <p>Lộ trình phát triển năng lực toàn diện được thiết kế bởi các chuyên gia trong ngành giúp bạn đi đúng hướng.</p>
</section>

<section class="content-section" style="max-width: 1100px;">
    @if (isLimitReached)
    {
        <div class="premium-upgrade-banner" style="background: linear-gradient(135deg, #fffbeb 0%, #fef08a 100%); border: 1px solid #eab308; border-left: 6px solid #eab308; padding: 20px 24px; border-radius: 16px; margin-bottom: 30px; color: #854d0e; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 10px 25px -10px rgba(234,179,8,0.15); width: 100%;">
            <div style="display: flex; align-items: center; gap: 15px;">
                <span style="font-size: 32px;">⚠️</span>
                <div style="text-align: left;">
                    <h4 style="margin: 0 0 4px 0; font-size: 16px; font-weight: 800;">Gói thành viên Free đã đạt giới hạn</h4>
                    <p style="margin: 0; font-size: 13.5px; opacity: 0.9;">Bạn đã hết lượt làm bài miễn phí. Hãy nâng cấp Premium để tiếp tục lộ trình học tập và xem toàn bộ học liệu.</p>
                </div>
            </div>
            <a href="/Home/UpgradePremium" class="btn primary-btn" style="background: #0f172a; border-color: #0f172a; color: white; padding: 10px 20px; text-decoration: none; border-radius: 10px; font-weight: 700; font-size: 13px; white-space: nowrap;">Nâng cấp VIP ngay</a>
        </div>
    }
    <!-- Overview Card -->
    <div class="info-card" style="margin-bottom: 40px; border-left: 6px solid #4f46e5;">
        <h2 style="font-size: 24px; color: #020617; margin-bottom: 12px;">Tổng quan nghề nghiệp</h2>
        <p style="font-size: 16px; line-height: 1.7; color: #4b5563; margin: 0;">@Model.Content</p>
    </div>

    <!-- Timeline of Milestones -->
    <h2 style="font-size: 26px; color: #020617; margin-bottom: 30px; text-align: center;">🗺️ Các cột mốc & Lộ trình phát triển</h2>
    
    @if (ViewBag.Stages != null && ((IEnumerable<Career_Guidance_Platform.Models.CareerStage>)ViewBag.Stages).Any())
    {
        <div class="timeline-track">
            @foreach (var stage in (IEnumerable<Career_Guidance_Platform.Models.CareerStage>)ViewBag.Stages)
            {
                var bgColors = new[] { "#4f46e5", "#06b6d4", "#10b981", "#f59e0b" };
                var shadowColors = new[] { "rgba(79, 70, 229, 0.15)", "rgba(6, 182, 212, 0.15)", "rgba(16, 185, 129, 0.15)", "rgba(245, 158, 11, 0.15)" };
                var colorIdx = (stage.SequenceOrder - 1) % bgColors.Length;
                var color = bgColors[colorIdx];
                var shadow = shadowColors[colorIdx];

                <div class="timeline-node">
                    <div class="timeline-marker" style="border-color: @color; box-shadow: 0 0 0 4px @shadow;"></div>
                    <div class="info-card" style="padding: 28px; border-radius: 20px; border: 1px solid #e2e8f0; background: #ffffff; transition: all 0.25s ease;">
                        <span style="font-weight: 800; color: @color; font-size: 12px; text-transform: uppercase; background: @(color)10; padding: 4px 10px; border-radius: 6px; border: 1px solid @(color)20; display: inline-block; margin-bottom: 12px;">
                            Cấp bậc @stage.SequenceOrder
                        </span>
                        <h3 style="font-size: 20px; font-weight: 800; color: #0f172a; margin: 0 0 10px 0;">@stage.Title</h3>
                        <p style="font-size: 15px; line-height: 1.7; color: #64748b; margin: 0 0 20px 0;">@stage.Description</p>
                        
                        @if (stage.CareerStageSkills != null && stage.CareerStageSkills.Any())
                        {
                            <div style="margin-top: 15px; border-top: 1px solid #f1f5f9; padding-top: 15px;">
                                <strong style="font-size: 13.5px; color: #334155; display: block; margin-bottom: 10px;">🛠️ Kỹ năng yêu cầu:</strong>
                                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                                    @foreach (var css in stage.CareerStageSkills)
                                    {
                                        if (css.Skill != null)
                                        {
                                            <div class="skill-badge-btn" 
                                                 data-id="@css.Skill.Id"
                                                 style="font-size: 12.5px; font-weight: 600; color: #1e293b; background: #f8fafc; padding: 6px 12px; border-radius: 8px; border: 1px solid #e2e8f0; display: inline-flex; align-items: center; gap: 8px; cursor: pointer; transition: all 0.2s;" 
                                                 onmouseover="this.style.background='#eef2ff'; this.style.borderColor='#cbd5e1'; this.style.transform='translateY(-1px)';" 
                                                 onmouseout="this.style.background='#f8fafc'; this.style.borderColor='#e2e8f0'; this.style.transform='none';"
                                                 onclick="openSkillPopup(@css.Skill.Id)">
                                                <input type="checkbox" class="skill-select-checkbox" data-id="@css.Skill.Id" onclick="event.stopPropagation(); toggleSkillSelection()" style="width: 15px; height: 15px; cursor: pointer; border-radius: 4px; border: 1px solid #cbd5e1;" />
                                                <span>⚙️</span>
                                                <span>@css.Skill.Name</span>
                                                <span style="font-size: 10px; font-weight: 800; color: @color; background: @(color)15; padding: 2px 6px; border-radius: 4px;">@css.ProficiencyRequired</span>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 40px; background: #f8fafc; border-radius: 20px; border: 1px dashed #cbd5e1; margin-bottom: 48px;">
            <p style="color: #64748b; font-style: italic; margin: 0;">Chưa có lộ trình cấp bậc nghề nghiệp được thiết lập cho ngành này.</p>
        </div>
    }

    <div style="text-align: center; margin-top: 40px;">
        <a asp-controller="CareerPath"
           asp-action="Roadmap"
           asp-route-id="@Model.Id"
           class="btn"
           style="background:#4f46e5;color:white;padding:12px 30px;border-radius:12px;font-weight:700;text-decoration:none;">
            🚀 Xem lộ trình học tập
        </a>
    </div>

    <!-- Partner Businesses -->
    <div class="info-card" style="background: #f0fdf4; border: 1px solid #d1fae5; padding: 32px; border-radius: 24px;">
        <h2 style="font-size: 24px; color: #065f46; margin-top: 0; margin-bottom: 12px; display: flex; align-items: center; gap: 10px;">
            <span>🏢</span> Doanh nghiệp đối tác tuyển dụng
        </h2>
        <p style="color: #047857; font-size: 15px; margin-bottom: 24px; line-height: 1.6;">Dưới đây là danh sách các đối tác chiến lược của CareerPath đang tìm kiếm ứng viên cho lộ trình này:</p>
        
        @if (ViewBag.Jobs != null && ((IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs).Any())
        {
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
                @foreach (var job in (IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs)
                {
                    <div style="background: #ffffff; border: 1px solid #e6f4ea; border-radius: 16px; padding: 20px; box-shadow: 0 4px 12px rgba(6, 95, 70, 0.04);">
                        <h4 style="margin: 0; color: #065f46; font-size: 17px; font-weight: 700;">@job.Title</h4>
                        <div style="font-size: 14px; color: #047857; font-weight: 600; margin: 6px 0;">💼 Công ty: @job.CompanyName</div>
                        @if (job.Salary > 0)
                        {
                            <div style="font-size: 14px; color: #10b981; font-weight: 700; margin-bottom: 10px;">💰 Lương: @job.Salary.ToString("N0") VNĐ</div>
                        }
                        <p style="font-size: 13.5px; color: #475569; line-height: 1.6; margin: 0 0 20px 0; flex-grow: 1;">@job.Description</p>
                        
                        <button class="btn" style="background: #10b981; color: white; border: none; padding: 10px 20px; border-radius: 10px; font-size: 14px; font-weight: 700; cursor: pointer; width: 100%; transition: all 0.2s;" onmouseover="this.style.background='#059669'" onmouseout="this.style.background='#10b981'" onclick="showToast('Đã gửi hồ sơ ứng tuyển của bạn đến @job.CompanyName!', 'success')">
                            Apply ứng tuyển
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: #065f46; font-style: italic; margin: 0;">Hiện tại chưa có tin tuyển dụng phù hợp cho lộ trình này. Vui lòng quay lại sau.</p>
        }
    </div>

    <!-- Actions and Navigation -->
    <div style="margin-top: 50px; text-align: center; display: flex; justify-content: center; gap: 15px;">
        <a asp-controller="CareerTest"
           asp-action="GetResultDetail"
           asp-route-id="@Model.Id"
           class="btn secondary-btn"
           style="padding: 12px 28px; border-radius: 12px;">
            ⬅ Quay lại trang kết quả
        </a>
        <a href="javascript:history.back()" class="btn secondary-btn" style="padding: 12px 28px; border-radius: 12px;">
            ⬅ Quay lại danh sách
        </a>
    </div>
</section>

<!-- Floating Action Bar for Multiple Skill Selection -->
<div id="floatingSelectionBar" class="floating-selection-bar hidden">
    <div class="floating-content">
        <span class="count-badge">💡 Đã chọn <strong id="selectedSkillsCount">0</strong> kỹ năng</span>
        <button onclick="@(isPremium ? "addSelectedSkillsToGoals()" : "window.location.href='/Home/UpgradePremium'")" class="btn primary-btn btn-sm">🎯 @(isPremium ? "Thêm vào Mục tiêu" : "🔒 Thêm vào Mục tiêu (Premium)")</button>
        <button onclick="clearSkillSelection()" class="btn secondary-btn btn-sm" style="color: white; border-color: rgba(255,255,255,0.3); background: transparent;">Hủy</button>
    </div>
</div>

<!-- Modal Skill Details -->
<div id="skillDetailsModal" class="modal-overlay hidden" onclick="closeSkillPopup()">
    <div class="modal-card" onclick="event.stopPropagation()">
        <button class="modal-close-btn" onclick="closeSkillPopup()">×</button>
        
        <div class="modal-header">
            <span id="popupSkillType" class="badge">Hard Skill</span>
            <h2 id="popupSkillName">Tên kỹ năng</h2>
            <div class="skill-meta-tags">
                <span class="meta-tag">⏱️ <span id="popupSkillHours">10</span> giờ học</span>
                <span id="popupSkillDifficulty" class="meta-tag difficulty-tag medium">Trung bình</span>
            </div>
        </div>
        
        <div class="modal-body">
            <div class="info-section">
                <h4>🎯 Mô tả kỹ năng</h4>
                <p id="popupSkillDesc">Chi tiết mô tả kỹ năng sẽ được hiển thị ở đây...</p>
            </div>
            
            <div class="info-section">
                <h4>📚 Tài liệu & Học liệu liên quan</h4>
                <div id="popupResourcesList" class="resources-grid">
                    <!-- Loaded dynamically -->
                </div>
            </div>
        </div>
        
        <div class="modal-footer">
            <button id="btnAddSingleGoal" onclick="@(isPremium ? "addCurrentSkillToGoals()" : "window.location.href='/Home/UpgradePremium'")" class="btn secondary-btn">🎯 @(isPremium ? "Thêm vào Mục tiêu" : "🔒 Thêm vào Mục tiêu (Premium)")</button>
            <form id="startLearningForm" method="post" action="/Goal/StartLearning" style="margin: 0;">
                <input type="hidden" name="skillId" id="startLearningSkillId" value="" />
                <button type="@(isPremium ? "submit" : "button")" onclick="@(isPremium ? "" : "window.location.href='/Home/UpgradePremium'")" class="btn primary-btn" style="@(isPremium ? "" : "background: #cbd5e1; border-color: #cbd5e1; color: #64748b;")">
                    @(isPremium ? "🚀 Bắt đầu học ngay" : "🔒 Bắt đầu học ngay (Premium)")
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    /* Floating Action Bar */
    .floating-selection-bar {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(15, 23, 42, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 100px;
        padding: 12px 24px;
        z-index: 999;
        box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.3);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .floating-selection-bar.hidden {
        opacity: 0;
        transform: translate(-50%, 30px);
        pointer-events: none;
    }
    .floating-content {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .floating-content .count-badge {
        color: white;
        font-size: 14.5px;
        font-weight: 600;
    }
    .floating-content .btn-sm {
        padding: 8px 16px;
        font-size: 13.5px;
        border-radius: 999px;
    }

    /* Modal Styling */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        transition: all 0.25s ease;
    }
    .modal-overlay.hidden {
        opacity: 0;
        pointer-events: none;
    }
    .modal-card {
        background: #ffffff;
        border-radius: 24px;
        width: 90%;
        max-width: 580px;
        box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.25);
        border: 1px solid #cbd5e1;
        overflow: hidden;
        position: relative;
        transform: translateY(0);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        display: flex;
        flex-direction: column;
        max-height: 85vh;
    }
    .modal-overlay.hidden .modal-card {
        transform: translateY(40px);
    }
    .modal-close-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        background: #f1f5f9;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        cursor: pointer;
        color: #64748b;
        transition: all 0.2s;
    }
    .modal-close-btn:hover {
        background: #e2e8f0;
        color: #0f172a;
    }
    .modal-header {
        padding: 32px 32px 20px;
        border-bottom: 1px solid #f1f5f9;
    }
    .modal-header .badge {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        color: #4f46e5;
        background: #eef2ff;
        padding: 4px 10px;
        border-radius: 6px;
        display: inline-block;
        margin-bottom: 12px;
    }
    .modal-header h2 {
        margin: 0 0 12px;
        font-size: 24px;
        font-weight: 800;
        color: #0f172a;
    }
    .skill-meta-tags {
        display: flex;
        gap: 12px;
    }
    .meta-tag {
        font-size: 13px;
        color: #64748b;
        font-weight: 600;
        background: #f8fafc;
        padding: 4px 10px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
    }
    .difficulty-tag.easy { color: #10b981; background: #ecfdf5; border-color: #a7f3d0; }
    .difficulty-tag.medium { color: #f59e0b; background: #fffbeb; border-color: #fde68a; }
    .difficulty-tag.hard { color: #ef4444; background: #fef2f2; border-color: #fecaca; }

    .modal-body {
        padding: 24px 32px 32px;
        overflow-y: auto;
        flex-grow: 1;
    }
    .info-section {
        margin-bottom: 24px;
    }
    .info-section h4 {
        margin: 0 0 10px;
        font-size: 14.5px;
        font-weight: 800;
        color: #334155;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .info-section p {
        margin: 0;
        font-size: 15px;
        line-height: 1.6;
        color: #475569;
    }
    .resources-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .resource-card-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-decoration: none;
        transition: all 0.2s;
    }
    .resource-card-item:hover {
        background: #f1f5f9;
        border-color: #cbd5e1;
    }
    .resource-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .resource-title {
        font-weight: 700;
        color: #0f172a;
        font-size: 14px;
    }
    .resource-type {
        font-size: 11px;
        text-transform: uppercase;
        font-weight: 800;
        color: #64748b;
    }
    .resource-icon {
        font-size: 18px;
    }

    .modal-footer {
        padding: 20px 32px 28px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        background: #f8fafc;
    }
</style>

<script>
    let selectedSkillIds = [];
    let currentSkillId = null;

    function openSkillPopup(skillId) {
        currentSkillId = skillId;
        
        // Show loading status in popup
        document.getElementById("popupSkillName").innerText = "Đang tải dữ liệu...";
        document.getElementById("popupSkillDesc").innerText = "Vui lòng chờ giây lát...";
        document.getElementById("popupResourcesList").innerHTML = "<p style='color: #64748b; font-style: italic;'>Đang tìm tài liệu học tập...</p>";
        
        // Open modal first
        document.getElementById("skillDetailsModal").classList.remove("hidden");
        
        // Fetch detailed data via AJAX
        fetch(`/Goal/GetSkillDetails?skillId=${skillId}`)
            .then(res => res.json())
            .then(data => {
                document.getElementById("popupSkillName").innerText = data.name;
                document.getElementById("popupSkillDesc").innerText = data.description || "Chưa có mô tả chi tiết.";
                document.getElementById("popupSkillType").innerText = data.skillType;
                document.getElementById("popupSkillHours").innerText = data.estimatedHours;
                
                // Difficulty tag styling
                const diffTag = document.getElementById("popupSkillDifficulty");
                diffTag.innerText = data.difficulty === "Easy" ? "Dễ" : data.difficulty === "Hard" ? "Khó" : "Trung bình";
                diffTag.className = "meta-tag difficulty-tag " + data.difficulty.toLowerCase();
                
                // Set form input for Start Learning
                document.getElementById("startLearningSkillId").value = data.id;

                // Load resources
                const list = document.getElementById("popupResourcesList");
                list.innerHTML = "";
                
                if (data.resources && data.resources.length > 0) {
                    data.resources.forEach(r => {
                        const typeEmoji = r.resourceType === "Video" ? "🎥" : r.resourceType === "PDF" ? "📕" : "📖";
                        const item = document.createElement("a");
                        item.href = r.url || "#";
                        item.target = "_blank";
                        item.className = "resource-card-item";
                        item.innerHTML = `
                            <div class="resource-info">
                                <span class="resource-title">${r.title}</span>
                                <span class="resource-type">${r.resourceType} - ${r.description || "Tài liệu học tập"}</span>
                            </div>
                            <span class="resource-icon">${typeEmoji}</span>
                        `;
                        list.appendChild(item);
                    });
                } else {
                    list.innerHTML = "<p style='color: #64748b; font-style: italic; font-size: 13.5px; margin: 0;'>Chưa có học liệu liên kết cho kỹ năng này. Hãy bấm học để sử dụng học liệu lộ trình chung.</p>";
                }
            })
            .catch(err => {
                console.error(err);
                document.getElementById("popupSkillName").innerText = "Lỗi kết nối";
                document.getElementById("popupSkillDesc").innerText = "Không thể tải dữ liệu kỹ năng. Vui lòng kiểm tra lại.";
            });
    }

    function closeSkillPopup() {
        document.getElementById("skillDetailsModal").classList.add("hidden");
    }

    function addCurrentSkillToGoals() {
        if (!currentSkillId) return;
        
        fetch(`/Goal/AddSkillToGoals?skillId=${currentSkillId}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                showToast(data.message, data.success ? 'success' : 'error');
                if (data.success) {
                    closeSkillPopup();
                }
            })
            .catch(err => showToast("Có lỗi xảy ra: " + err, "error"));
    }

    function toggleSkillSelection() {
        const checkboxes = document.querySelectorAll(".skill-select-checkbox:checked");
        selectedSkillIds = Array.from(checkboxes).map(cb => parseInt(cb.getAttribute("data-id")));
        
        const bar = document.getElementById("floatingSelectionBar");
        const count = document.getElementById("selectedSkillsCount");
        
        if (selectedSkillIds.length > 0) {
            count.innerText = selectedSkillIds.length;
            bar.classList.remove("hidden");
        } else {
            bar.classList.add("hidden");
        }
    }

    function clearSkillSelection() {
        const checkboxes = document.querySelectorAll(".skill-select-checkbox:checked");
        checkboxes.forEach(cb => cb.checked = false);
        selectedSkillIds = [];
        document.getElementById("floatingSelectionBar").classList.add("hidden");
    }

    function addSelectedSkillsToGoals() {
        if (selectedSkillIds.length === 0) return;
        
        fetch('/Goal/AddMultipleSkillsToGoals', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(selectedSkillIds)
        })
        .then(res => res.json())
        .then(data => {
            showToast(data.message, data.success ? 'success' : 'error');
            if (data.success) {
                clearSkillSelection();
            }
        })
        .catch(err => showToast("Có lỗi xảy ra: " + err, "error"));
    }
</script>

