@model Career_Guidance_Platform.Models.TestResult

@{
    ViewData["Title"] = "Kết quả bài test";
}

<section class="content-section result-detail">
    <div class="container">
        <div class="section-header">
            <h1>Kết quả bài test</h1>
            <p>Chi tiết kết quả đánh giá nghề nghiệp của bạn</p>
        </div>

        <div class="result-summary card">
            <div class="result-left">
                <h2>Kết quả chính</h2>

                @if (Model.RecommendedCareerPath != null)
                {
                    <div class="recommended-career">
                        <h3>@Model.RecommendedCareerPath.Title</h3>
                        @if (!string.IsNullOrWhiteSpace(Model.RecommendedCareerPath.Content))
                        {
                            <div class="career-content">@Html.Raw(Model.RecommendedCareerPath.Content)</div>
                        }
                    </div>
                }
                else
                {
                    <p><em>Không có nghề nghiệp gợi ý.</em></p>
                }

                <div class="compatibility" style="margin-top:0.8rem">
                    <strong>Độ phù hợp:</strong>
                    @if (Model.CompatibilityScore.HasValue)
                    {
                        <span class="score">@Model.CompatibilityScore.Value.ToString("0.##") %</span>
                    }
                    else
                    {
                        <span class="score">—</span>
                    }
                </div>

                <div class="meta" style="margin-top:0.6rem">
                    <small>Ngày làm: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small><br />
                    <small>Lần làm bài: <strong>Lần thứ @Model.AttemptNumber</strong></small><br />
                    <small>Người làm: @(Model.User?.FullName ?? "Học viên")</small>
                </div>

                <div class="chart-container" style="margin-top: 1.5rem; margin-bottom: 1.5rem; padding: 1.25rem; background: #f8fafc; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                    <h4 style="margin: 0 0 1rem 0; font-size: 1.05rem; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 6px;">
                        <span>📊</span> Biểu đồ tương thích ngành nghề
                    </h4>
                    <div style="position: relative; height: 320px; width: 100%;">
                        <canvas id="compatibilityChart"></canvas>
                    </div>
                </div>

                <div class="result-actions" style="margin-top:1.5rem; margin-bottom: 1.5rem; display: flex; flex-wrap: wrap; gap: 12px;">
                    @if (Model.RecommendedCareerPathId.HasValue)
                    {
                        <!-- Button 1: Xem lộ trình nghề nghiệp (CTA chính) -->
                        <a asp-controller="CareerPath" asp-action="Details" asp-route-id="@Model.RecommendedCareerPathId.Value" class="btn primary-btn" style="font-weight: 700;">Xem lộ trình nghề nghiệp</a>

                        <!-- Button 2: Nâng cấp nghề nghiệp (Bồi dưỡng kiến thức) -->
                        @if (Model.CompatibilityScore.HasValue && Model.CompatibilityScore.Value < 80)
                        {
                            <a asp-controller="Home" asp-action="Training" asp-route-careerPathId="@Model.RecommendedCareerPathId.Value" class="btn" style="background-color: #4f46e5; color: white; font-weight: 700; border: none; display: inline-flex; align-items: center;">Nâng cấp nghề nghiệp</a>
                        }
                        else
                        {
                            <button class="btn" disabled style="background-color: #cbd5e1; color: #64748b; cursor: not-allowed; opacity: 0.8; font-weight: 700; display: inline-flex; align-items: center; border: 1px solid #cbd5e1;" title="Bạn đã đạt chuẩn kiến thức cho lộ trình này, sẵn sàng kết nối doanh nghiệp!">Nâng cấp nghề nghiệp 🔒</button>
                        }
                    }

                    <!-- Button 3: Làm lại bài test -->
                    <a asp-controller="Home" asp-action="CareerTest" class="btn secondary-btn" style="font-weight: 700;">Làm lại bài test</a>
                </div>

                @if (ViewBag.Jobs != null && ((IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs).Any())
                {
                    <div class="recommended-jobs" style="margin-top: 2rem; padding: 1.5rem; border-top: 4px solid #10b981; border-radius: 16px; background: #f0fdf4; border: 1px solid #d1fae5; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.08);">
                        <h3 style="color: #065f46; margin: 0 0 0.5rem 0; font-size: 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                            <span>🏢</span> Kết nối Doanh nghiệp - Việc làm đề xuất
                        </h3>
                        <p style="font-size: 0.9rem; color: #047857; margin-bottom: 1.25rem; line-height: 1.5;">Dựa trên kết quả định hướng của bạn, các doanh nghiệp sau đang tuyển dụng vị trí phù hợp:</p>
                        <div class="jobs-list" style="display: flex; flex-direction: column; gap: 1rem;">
                            @foreach (var job in (IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs)
                            {
                                <div class="job-item" style="background: #ffffff; padding: 1.25rem; border: 1px solid #e6f4ea; border-radius: 12px; transition: all 0.2s;">
                                    <h4 style="margin: 0; color: #065f46; font-size: 1.05rem; font-weight: 700;">@job.Title</h4>
                                    <div style="font-size: 0.9rem; color: #047857; font-weight: 600; margin: 0.35rem 0;">💼 @job.CompanyName</div>
                                    @if (job.Salary > 0)
                                    {
                                        <div style="font-size: 0.9rem; color: #10b981; font-weight: 700;">💰 Mức lương: @job.Salary.ToString("N0") VNĐ</div>
                                    }
                                    <p style="margin: 0.75rem 0; font-size: 0.9rem; color: #4b5563; line-height: 1.5;">@job.Description</p>
                                    <button class="btn btn-sm" style="background: #10b981; color: white; border: none; padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 0.25rem;" onclick="alert('Đã gửi thông tin định hướng của bạn đến doanh nghiệp!')">Ứng tuyển & Kết nối</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="result-right">
                <h3>Chi tiết câu hỏi & đáp án</h3>

                @if (Model.TestAnswers != null && Model.TestAnswers.Any())
                {
                    <ol class="answer-list">
                        @foreach (var ans in Model.TestAnswers)
                        {
                            <li class="answer-item">
                                <div class="question">
                                    <strong>
                                        @(
                                            !string.IsNullOrWhiteSpace(ans.QuestionTest?.Content)
                                            ? ans.QuestionTest.Content
                                            : $"Câu hỏi #{ans.QuestionId}"
                                        )
                                    </strong>
                                </div>
                                <div class="selected-option" style="margin-top:.35rem">
                                    <span style="font-size:.95rem;color:#666">Đáp án đã chọn:</span>
                                    <div class="option-content" style="margin-top:.25rem">
                                        @if (ans.QuestionOption != null)
                                        {
                                            <strong>@ans.QuestionOption.Content</strong>
                                        }
                                        else
                                        {
                                            <em>Không tìm thấy đáp án (id: @ans.QuestionOptionId)</em>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ol>
                }
                else
                {
                    <p>Không có câu trả lời lưu trữ.</p>
                }
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        var ctx = document.getElementById('compatibilityChart').getContext('2d');
        
        var labels = [];
        var dataValues = [];
        
        @if (Model.TestResultScores != null && Model.TestResultScores.Any())
        {
            foreach (var score in Model.TestResultScores.OrderByDescending(s => s.Score))
            {
                <text>
                (function() {
                    var title = "@Html.Raw(score.CareerPath?.Title ?? "Chưa đặt tên")";
                    var scoreVal = @score.Score.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                    var parts = title.split(" (");
                    if (parts.length > 1) {
                        // Split into Vietnamese title on Line 1, and English title on Line 2
                        labels.push([parts[0], "(" + parts[1]]);
                    } else {
                        labels.push(title);
                    }
                    dataValues.push(scoreVal);
                })();
                </text>
            }
        }
        
        if (labels.length === 0) {
            labels = ["Chưa có dữ liệu"];
            dataValues = [0];
        }

        // Custom plugin to draw values at the end of each horizontal bar
        const chartDataLabelsPlugin = {
            id: 'chartDataLabels',
            afterDatasetsDraw(chart, args, pluginOptions) {
                const { ctx, chartArea: { right }, scales: { y } } = chart;
                ctx.save();
                ctx.font = 'bold 12px Inter, sans-serif';
                ctx.fillStyle = '#4f46e5';
                ctx.textAlign = 'left';
                ctx.textBaseline = 'middle';

                chart.data.datasets.forEach((dataset, i) => {
                    const meta = chart.getDatasetMeta(i);
                    meta.data.forEach((bar, index) => {
                        const val = dataset.data[index];
                        if (val > 0) {
                            const xPos = bar.x + 8; // 8px spacing from end of bar
                            const yPos = bar.y;
                            ctx.fillText(val + '%', xPos, yPos);
                        }
                    });
                });
                ctx.restore();
            }
        };

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Độ tương thích (%)',
                    data: dataValues,
                    backgroundColor: 'rgba(79, 70, 229, 0.85)',
                    borderColor: 'rgb(79, 70, 229)',
                    borderWidth: 1.5,
                    borderRadius: 8,
                    barPercentage: 0.6,
                    categoryPercentage: 0.8
                }]
            },
            plugins: [chartDataLabelsPlugin],
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                layout: {
                    padding: {
                        left: 10,
                        right: 40 // Space for labels at the end of bars
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: '#0f172a',
                        titleFont: { size: 13, weight: 'bold' },
                        bodyFont: { size: 12 },
                        padding: 10,
                        cornerRadius: 8,
                        callbacks: {
                            label: function(context) {
                                return ' ' + context.raw + '% tương thích';
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        max: 100,
                        grid: {
                            color: '#f1f5f9',
                            drawBorder: false
                        },
                        ticks: {
                            color: '#64748b',
                            font: { size: 11, weight: '600' },
                            callback: function(value) {
                                return value + '%';
                            }
                        }
                    },
                    y: {
                        grid: {
                            display: false,
                            drawBorder: false
                        },
                        ticks: {
                            color: '#334155',
                            font: { size: 11, weight: '700' },
                            autoSkip: false
                        }
                    }
                }
            }
        });
    });
</script>