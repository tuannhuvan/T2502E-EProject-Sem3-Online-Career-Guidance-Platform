@model Career_Guidance_Platform.Models.TestResult

@{
    ViewData["Title"] = "Kết quả bài test";
}

<section class="content-section result-detail">
    <div class="container">
        <div class="section-header">
            <h1>Kết quả bài test</h1>
            <p>Chi tiết kết quả đánh giá nghề nghiệp của bạn</p>
        </div>

        <div class="result-summary card">
            <div class="result-left">
                <h2>Kết quả chính</h2>

                @if (Model.RecommendedCareerPath != null)
                {
                    <div class="recommended-career">
                        <h3>@Model.RecommendedCareerPath.Title</h3>
                        @if (!string.IsNullOrWhiteSpace(Model.RecommendedCareerPath.Content))
                        {
                            <div class="career-content">@Html.Raw(Model.RecommendedCareerPath.Content)</div>
                        }
                    </div>
                }
                else
                {
                    <p><em>Không có nghề nghiệp gợi ý.</em></p>
                }

                <div class="compatibility" style="margin-top:0.8rem">
                    <strong>Độ phù hợp:</strong>
                    @if (Model.CompatibilityScore.HasValue)
                    {
                        <span class="score">@Model.CompatibilityScore.Value.ToString("0.##") %</span>
                    }
                    else
                    {
                        <span class="score">—</span>
                    }
                </div>

                <div class="meta" style="margin-top:0.6rem">
                    <small>Ngày làm: @Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small><br />
                    <small>Người làm: @Model.User?.FullName ?? Model.UserId.ToString()</small>
                </div>

                <div class="result-actions" style="margin-top:1rem; margin-bottom: 1.5rem;">
                    @if (Model.RecommendedCareerPath != null)
                    {
                        <a asp-controller="CareerPath" asp-action="Details" asp-route-id="@Model.RecommendedCareerPath.Id" class="btn primary-btn">Xem lộ trình nghề nghiệp</a>
                    }
                    <a asp-controller="Home" asp-action="CareerTest" class="btn secondary-btn">Làm lại bài test</a>
                    <a asp-controller="Home" asp-action="Index" class="btn">Trang chủ</a>
                </div>

                @if (ViewBag.Jobs != null && ((IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs).Any())
                {
                    <div class="recommended-jobs" style="margin-top: 2rem; padding: 1.5rem; border-top: 4px solid #10b981; border-radius: 16px; background: #f0fdf4; border: 1px solid #d1fae5; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.08);">
                        <h3 style="color: #065f46; margin: 0 0 0.5rem 0; font-size: 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                            <span>🏢</span> Kết nối Doanh nghiệp - Việc làm đề xuất
                        </h3>
                        <p style="font-size: 0.9rem; color: #047857; margin-bottom: 1.25rem; line-height: 1.5;">Dựa trên kết quả định hướng của bạn, các doanh nghiệp sau đang tuyển dụng vị trí phù hợp:</p>
                        <div class="jobs-list" style="display: flex; flex-direction: column; gap: 1rem;">
                            @foreach (var job in (IEnumerable<Career_Guidance_Platform.Models.JobPosting>)ViewBag.Jobs)
                            {
                                <div class="job-item" style="background: #ffffff; padding: 1.25rem; border: 1px solid #e6f4ea; border-radius: 12px; transition: all 0.2s;">
                                    <h4 style="margin: 0; color: #065f46; font-size: 1.05rem; font-weight: 700;">@job.Title</h4>
                                    <div style="font-size: 0.9rem; color: #047857; font-weight: 600; margin: 0.35rem 0;">💼 @job.CompanyName</div>
                                    @if (job.Salary > 0)
                                    {
                                        <div style="font-size: 0.9rem; color: #10b981; font-weight: 700;">💰 Mức lương: @job.Salary.ToString("N0") VNĐ</div>
                                    }
                                    <p style="margin: 0.75rem 0; font-size: 0.9rem; color: #4b5563; line-height: 1.5;">@job.Description</p>
                                    <button class="btn btn-sm" style="background: #10b981; color: white; border: none; padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 0.25rem;" onclick="alert('Đã gửi thông tin định hướng của bạn đến doanh nghiệp!')">Ứng tuyển & Kết nối</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="result-right">
                <h3>Chi tiết câu hỏi & đáp án</h3>

                @if (Model.TestAnswers != null && Model.TestAnswers.Any())
                {
                    <ol class="answer-list">
                        @foreach (var ans in Model.TestAnswers)
                        {
                            <li class="answer-item">
                                <div class="question">
                                    <strong>
                                        @(
                                            !string.IsNullOrWhiteSpace(ans.QuestionTest?.Content)
                                            ? ans.QuestionTest.Content
                                            : $"Câu hỏi #{ans.QuestionId}"
                                        )
                                    </strong>
                                </div>
                                <div class="selected-option" style="margin-top:.35rem">
                                    <span style="font-size:.95rem;color:#666">Đáp án đã chọn:</span>
                                    <div class="option-content" style="margin-top:.25rem">
                                        @if (ans.QuestionOption != null)
                                        {
                                            <strong>@ans.QuestionOption.Content</strong>
                                        }
                                        else
                                        {
                                            <em>Không tìm thấy đáp án (id: @ans.QuestionOptionId)</em>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ol>
                }
                else
                {
                    <p>Không có câu trả lời lưu trữ.</p>
                }
            </div>
        </div>
    </div>
</section>