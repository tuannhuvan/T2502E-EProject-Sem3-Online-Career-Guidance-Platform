@model Career_Guidance_Platform.Models.MentorProfile
@{
    ViewData["Title"] = $"Cố vấn {Model.User?.FullName}";
    var reviews = ViewBag.Reviews as IEnumerable<Career_Guidance_Platform.Models.MentorReview>;
    var currentRequest = ViewBag.CurrentRequest as Career_Guidance_Platform.Models.MentorshipRequest;
    var menteeMeetings = ViewBag.MenteeMeetings as IEnumerable<Career_Guidance_Platform.Models.MentorshipMeeting>;
}

<section class="page-hero" style="background: radial-gradient(circle at top left, #f5f3ff 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); border-bottom: 1px solid #e2e8f0; padding: 50px 24px;">
    <div style="max-width: 1100px; margin: 0 auto; display: flex; align-items: center; gap: 30px;">
        <div style="width: 90px; height: 90px; border-radius: 24px; background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%); display: flex; align-items: center; justify-content: center; font-size: 44px; box-shadow: 0 10px 20px rgba(79, 70, 229, 0.15); flex-shrink: 0;">
            👨‍🏫
        </div>
        <div>
            <span style="font-size: 12px; font-weight: 700; color: #4f46e5; text-transform: uppercase; background: #eef2ff; padding: 4px 12px; border-radius: 8px;">Cố vấn Chuyên môn</span>
            <h1 style="font-size: 32px; font-weight: 900; color: #0f172a; margin: 8px 0 4px; letter-spacing: -0.5px;">@Model.User?.FullName</h1>
            <p style="color: #4f46e5; font-size: 16px; font-weight: 700; margin: 0;">
                @Model.JobTitle @(string.IsNullOrEmpty(Model.Company) ? "" : $"tại {Model.Company}")
            </p>
        </div>
    </div>
</section>

<section class="content-section" style="max-width: 1100px; margin: 0 auto; padding: 40px 24px;">
    
    @if (TempData["MessageSuccess"] != null)
    {
        <div style="background: #dcfce7; border: 1px solid #bbf7d0; color: #15803d; padding: 16px; border-radius: 12px; margin-bottom: 30px; font-weight: 600;">
            🎉 @TempData["MessageSuccess"]
        </div>
    }
    @if (TempData["MessageWarning"] != null)
    {
        <div style="background: #fef3c7; border: 1px solid #fde68a; color: #b45309; padding: 16px; border-radius: 12px; margin-bottom: 30px; font-weight: 600;">
            ⚠️ @TempData["MessageWarning"]
        </div>
    }
    @if (TempData["BookingSuccess"] != null)
    {
        <div style="background: #e0f2fe; border: 1px solid #bae6fd; color: #0369a1; padding: 16px; border-radius: 12px; margin-bottom: 30px; font-weight: 600;">
            📅 @TempData["BookingSuccess"]
        </div>
    }

    <div style="display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 40px; align-items: start;">
        
        <!-- Left Column: Biography, Experience, Reviews -->
        <div style="display: flex; flex-direction: column; gap: 30px;">
            <!-- Bio & Introduction -->
            <div class="info-card" style="padding: 30px; border-radius: 20px; background: #ffffff; border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(0,0,0,0.01);">
                <h3 style="font-size: 20px; color: #0f172a; font-weight: 800; margin-top: 0; margin-bottom: 16px; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px;">👤 Giới thiệu bản thân</h3>
                <p style="color: #475569; font-size: 15px; line-height: 1.7; margin: 0; white-space: pre-line;">@Model.Biography</p>
            </div>

            <!-- Detailed Experience -->
            @if (!string.IsNullOrEmpty(Model.ExperienceDescription))
            {
                <div class="info-card" style="padding: 30px; border-radius: 20px; background: #ffffff; border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(0,0,0,0.01);">
                    <h3 style="font-size: 20px; color: #0f172a; font-weight: 800; margin-top: 0; margin-bottom: 16px; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px;">💼 Kinh nghiệm chuyên sâu</h3>
                    <p style="color: #475569; font-size: 15px; line-height: 1.7; margin: 0; white-space: pre-line;">@Model.ExperienceDescription</p>
                </div>
            }

            <!-- Reviews and Ratings list -->
            <div class="info-card" style="padding: 30px; border-radius: 20px; background: #ffffff; border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(0,0,0,0.01);">
                <h3 style="font-size: 20px; color: #0f172a; font-weight: 800; margin-top: 0; margin-bottom: 20px; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; display: flex; justify-content: space-between; align-items: center;">
                    <span>⭐ Đánh giá từ Học viên (@(reviews?.Count() ?? 0))</span>
                    <span style="font-size: 16px; color: #f59e0b; background: #fef3c7; padding: 4px 12px; border-radius: 999px;">
                        ★ @ViewBag.AverageRating.ToString("0.0")
                    </span>
                </h3>

                @if (reviews != null && reviews.Any())
                {
                    <div style="display: flex; flex-direction: column; gap: 20px; max-height: 380px; overflow-y: auto; padding-right: 8px;">
                        @foreach (var review in reviews)
                        {
                            <div style="padding: 16px; border: 1px solid #e2e8f0; border-radius: 16px; background: #f8fafc;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                    <strong style="color: #0f172a;">@review.Mentee?.FullName</strong>
                                    <span style="color: #f59e0b; font-weight: 700;">
                                        @for (int i = 0; i < review.Rating; i++) { <span>★</span> }
                                        @for (int i = review.Rating; i < 5; i++) { <span style="color: #cbd5e1;">★</span> }
                                    </span>
                                </div>
                                <p style="color: #475569; font-size: 13.5px; line-height: 1.6; margin: 0 0 8px 0;">@review.Comment</p>
                                <small style="color: #94a3b8; font-size: 11px;">Ngày đánh giá: @review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p style="font-style: italic; color: #64748b; margin: 0; text-align: center; padding: 20px;">Chưa có đánh giá nào cho cố vấn này. Hãy đặt lịch và chia sẻ nhận xét của bạn sau buổi học nhé!</p>
                }
            </div>

            <!-- Mentorship Meetings List for Mentee -->
            @if (menteeMeetings != null && menteeMeetings.Any())
            {
                <div class="info-card" style="padding: 30px; border-radius: 20px; background: #ffffff; border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(0,0,0,0.01);">
                    <h3 style="font-size: 20px; color: #0f172a; font-weight: 800; margin-top: 0; margin-bottom: 16px; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px;">📅 Lịch hẹn tư vấn của bạn</h3>
                    <div style="display: flex; flex-direction: column; gap: 16px; max-height: 380px; overflow-y: auto; padding-right: 8px;">
                        @foreach (var meeting in menteeMeetings)
                        {
                            <div style="padding: 20px; border: 1px solid #e2e8f0; border-radius: 16px; background: #fafafa; display: flex; flex-direction: column; gap: 10px;">
                                <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 10px;">
                                    <div>
                                        <h4 style="font-size: 16px; font-weight: 700; color: #0f172a; margin: 0 0 4px 0;">@meeting.Title</h4>
                                        <span style="font-size: 13.5px; color: #4f46e5; font-weight: 600;">
                                            🕒 @meeting.ScheduledTime.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </div>
                                    <div>
                                        @if (meeting.Status == "Scheduled")
                                        {
                                            <span style="background: #e0f2fe; color: #0369a1; padding: 4px 12px; border-radius: 999px; font-size: 12.5px; font-weight: 700;">Đã lên lịch</span>
                                        }
                                        else if (meeting.Status == "Completed")
                                        {
                                            <span style="background: #dcfce7; color: #15803d; padding: 4px 12px; border-radius: 999px; font-size: 12.5px; font-weight: 700;">Đã hoàn thành</span>
                                        }
                                        else
                                        {
                                            <span style="background: #f1f5f9; color: #64748b; padding: 4px 12px; border-radius: 999px; font-size: 12.5px; font-weight: 700;">@meeting.Status</span>
                                        }
                                    </div>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(meeting.Description))
                                {
                                    <p style="color: #475569; font-size: 14px; margin: 0; line-height: 1.5; background: #ffffff; padding: 10px 14px; border-radius: 8px; border: 1px solid #f1f5f9;">
                                        <strong>Nội dung:</strong> @meeting.Description
                                    </p>
                                }

                                @if (meeting.Status == "Scheduled")
                                {
                                    <div style="margin-top: 5px;">
                                        <a href="@meeting.MeetingUrl" target="_blank" class="btn" style="display: inline-flex; align-items: center; gap: 8px; background: #10b981; color: white; text-decoration: none; padding: 10px 20px; border-radius: 10px; font-weight: 700; font-size: 14px; transition: background 0.2s; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);">
                                            🎥 Vào phòng họp trực tuyến (Jitsi)
                                        </a>
                                    </div>
                                }
                                else if (meeting.Status == "Completed")
                                {
                                    <div style="margin-top: 5px;">
                                        <a asp-controller="Mentorship" asp-action="WriteReview" asp-route-meetingId="@meeting.Id" class="btn" style="display: inline-flex; align-items: center; gap: 8px; background: #4f46e5; color: white; text-decoration: none; padding: 10px 20px; border-radius: 10px; font-weight: 700; font-size: 14px;">
                                            ⭐ Viết đánh giá cho Mentor
                                        </a>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Right Column: Connect & Booking Box -->
        <div>
            <div class="info-card" style="padding: 30px; border-radius: 20px; background: #ffffff; border: 2px solid #e2e8f0; position: sticky; top: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
                <h4 style="font-size: 18px; color: #0f172a; margin-top: 0; margin-bottom: 15px; font-weight: 800;">Thông tin bổ sung</h4>
                
                <div style="display: flex; flex-direction: column; gap: 15px; margin-bottom: 24px; font-size: 14.5px;">
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: #64748b;">Hình thức tư vấn:</span>
                        <strong style="color: #10b981;">Kết nối Miễn phí</strong>
                    </div>

                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: #64748b;">Số buổi tư vấn:</span>
                        <strong style="color: #0f172a;">@ViewBag.CompletedSessions buổi hoàn thành</strong>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.LinkedInUrl))
                    {
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: #64748b;">Mạng xã hội:</span>
                            <a href="@Model.LinkedInUrl" target="_blank" style="color: #0077b5; font-weight: 700; text-decoration: none;">LinkedIn Profile ↗</a>
                        </div>
                    }
                </div>

                <!-- Connect/Booking Logic based on authentication and request state -->
                @if (User.Identity?.IsAuthenticated == false)
                {
                    <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; text-align: center;">
                        <p style="color: #475569; font-size: 13.5px; line-height: 1.5; margin-bottom: 16px;">Vui lòng đăng nhập hoặc đăng ký tài khoản học viên để gửi yêu cầu kết nối với Cố vấn này.</p>
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Mentorship/Details/@Model.UserId" class="btn primary-btn" style="width: 100%; border-radius: 10px; font-weight: 700; text-decoration: none; display: block; text-align: center; box-sizing: border-box; padding-top: 10px; height: 40px;">Đăng nhập để đặt lịch</a>
                    </div>
                }
                else
                {
                    @if (currentRequest == null)
                    {
                        <!-- Not yet connected: Show connection request form -->
                        <h4 style="font-size: 16px; color: #0f172a; margin-top: 0; margin-bottom: 12px; font-weight: 700; border-top: 1px solid #f1f5f9; padding-top: 20px;">Gửi yêu cầu kết nối</h4>
                        <p style="font-size: 13px; color: #64748b; line-height: 1.5; margin-bottom: 15px;">Bạn cần được cố vấn phê duyệt kết nối học tập trước khi có thể đặt lịch hẹn tư vấn 1-1.</p>
                        
                        <form asp-controller="Mentorship" asp-action="RequestMentorship" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="mentorId" value="@Model.UserId" />
                            <textarea name="message" required placeholder="Nhập mục tiêu học tập, dự án bạn muốn nhận định hướng..." style="width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 10px; font-size: 13.5px; min-height: 80px; margin-bottom: 15px; resize: vertical;"></textarea>
                            <button type="submit" class="btn primary-btn" style="width: 100%; border-radius: 10px; font-weight: 700; cursor: pointer; border: none; height: 42px;">Gửi yêu cầu kết nối</button>
                        </form>
                    }
                    else if (currentRequest.Status == "Pending")
                    {
                        <div style="background: #fffbeb; border: 1px solid #fef3c7; border-radius: 12px; padding: 20px; text-align: center; border-left: 5px solid #d97706;">
                            <span style="font-size: 24px; display: block; margin-bottom: 10px;">⏳</span>
                            <strong style="color: #b45309; font-size: 14.5px; display: block; margin-bottom: 6px;">Đang chờ phê duyệt</strong>
                            <p style="color: #b45309; font-size: 13px; line-height: 1.5; margin: 0;">Yêu cầu kết nối của bạn đã được gửi đi. Hãy kiểm tra lại sau khi cố vấn phê duyệt.</p>
                        </div>
                    }
                    else if (currentRequest.Status == "Rejected" || currentRequest.Status == "Cancelled")
                    {
                        <div style="background: #fef2f2; border: 1px solid #fee2e2; border-radius: 12px; padding: 20px; text-align: center; border-left: 5px solid #dc2626;">
                            <span style="font-size: 24px; display: block; margin-bottom: 10px;">❌</span>
                            <strong style="color: #991b1b; font-size: 14.5px; display: block; margin-bottom: 6px;">Yêu cầu bị từ chối</strong>
                            <p style="color: #991b1b; font-size: 13px; line-height: 1.5; margin: 0;">Cố vấn hiện chưa thể nhận hỗ trợ bạn tại thời điểm này. Bạn có thể tìm cố vấn khác trong danh bạ.</p>
                        </div>
                    }
                    else if (currentRequest.Status == "Approved")
                    {
                        <!-- Connected: Show Book Meeting Form OR Active Meeting Info -->
                        <h4 style="font-size: 16px; color: #0f172a; margin-top: 0; margin-bottom: 12px; font-weight: 700; border-top: 1px solid #f1f5f9; padding-top: 20px; display: flex; align-items: center; gap: 8px;">
                            <span style="color: #10b981;">✔</span> Đã kết nối học tập
                        </h4>

                        var activeMeeting = menteeMeetings?.FirstOrDefault(m => m.Status == "Scheduled");

                        @if (activeMeeting != null)
                        {
                            <div style="background: #e0f2fe; border: 1px solid #bae6fd; border-radius: 12px; padding: 20px; border-left: 5px solid #0284c7;">
                                <strong style="color: #0369a1; font-size: 15px; display: block; margin-bottom: 8px;">📅 Bạn có lịch hẹn chưa hoàn thành</strong>
                                <p style="color: #0f172a; font-size: 13.5px; font-weight: 600; margin: 0 0 6px 0;">@activeMeeting.Title</p>
                                <p style="color: #475569; font-size: 13px; margin: 0 0 12px 0;">
                                    Thời gian: <strong>@activeMeeting.ScheduledTime.ToString("dd/MM/yyyy HH:mm")</strong>
                                </p>
                                <a href="@activeMeeting.MeetingUrl" target="_blank" class="btn" style="display: inline-flex; align-items: center; justify-content: center; gap: 8px; background: #10b981; color: white; text-decoration: none; padding: 10px 16px; border-radius: 8px; font-weight: 700; font-size: 13.5px; width: 100%; box-sizing: border-box; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);">
                                    🎥 Vào phòng họp trực tuyến (Jitsi)
                                </a>
                                <p style="color: #64748b; font-size: 12px; font-style: italic; margin-top: 10px; margin-bottom: 0; text-align: center;">
                                    * Hãy hoàn thành buổi tư vấn này để có thể đặt lịch hẹn tiếp theo.
                                </p>
                            </div>
                        }
                        else
                        {
                            <p style="font-size: 13px; color: #64748b; line-height: 1.5; margin-bottom: 15px;">Hãy điền các thông tin hẹn lịch tư vấn 1-1 bên dưới:</p>
                            
                            <form asp-controller="Mentorship" asp-action="BookMentor" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="mentorId" value="@Model.UserId" />

                                <div style="margin-bottom: 15px;">
                                    <label style="display: block; font-size: 13px; font-weight: 600; color: #334155; margin-bottom: 5px;">Chọn Ngày tư vấn</label>
                                    <input type="date" name="meetingDate" id="meetingDateInput" min="@DateTime.Now.ToString("yyyy-MM-dd")" required style="width: 100%; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 13.5px;" />
                                </div>

                                <div style="margin-bottom: 15px;">
                                    <label style="display: block; font-size: 13px; font-weight: 600; color: #334155; margin-bottom: 5px;">Chọn Khung giờ</label>
                                    <select name="meetingTime" id="meetingTimeSelect" required style="width: 100%; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 13.5px; background: white;">
                                        <option value="09:00">09:00 - 10:00 (Sáng)</option>
                                        <option value="10:30">10:30 - 11:30 (Sáng)</option>
                                        <option value="14:00">14:00 - 15:00 (Chiều)</option>
                                        <option value="15:30">15:30 - 16:30 (Chiều)</option>
                                        <option value="19:00">19:00 - 20:00 (Tối)</option>
                                        <option value="20:30">20:30 - 21:30 (Tối)</option>
                                    </select>
                                </div>

                                <div style="margin-bottom: 20px;">
                                    <label style="display: block; font-size: 13px; font-weight: 600; color: #334155; margin-bottom: 5px;">Mục tiêu cần giải đáp</label>
                                    <textarea name="notes" required placeholder="Ghi rõ nội dung bạn mong muốn cố vấn hỗ trợ chuyên môn..." style="width: 100%; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 13px; min-height: 80px; resize: vertical;"></textarea>
                                </div>

                                <button type="submit" class="btn primary-btn" style="width: 100%; border-radius: 10px; font-weight: 700; cursor: pointer; border: none; height: 42px;">Xác nhận đặt lịch hẹn</button>
                            </form>

                            <script>
                                document.addEventListener("DOMContentLoaded", function () {
                                    const dateInput = document.getElementById("meetingDateInput");
                                    const timeSelect = document.getElementById("meetingTimeSelect");
                                    if (!dateInput || !timeSelect) return;

                                    const busyTimes = @Html.Raw(Json.Serialize(ViewBag.MentorBusyTimes ?? new List<string>()));
                                    
                                    // Lưu lại text gốc của option
                                    const originalOptions = [];
                                    Array.from(timeSelect.options).forEach(opt => {
                                        originalOptions.push({
                                            value: opt.value,
                                            text: opt.text
                                        });
                                    });

                                    function updateAvailableTimes() {
                                        const selectedDate = dateInput.value;
                                        if (!selectedDate) return;

                                        const now = new Date();
                                        const todayStr = now.getFullYear() + "-" + String(now.getMonth() + 1).padStart(2, '0') + "-" + String(now.getDate()).padStart(2, '0');

                                        Array.from(timeSelect.options).forEach((opt, index) => {
                                            const optTimeStr = `${selectedDate} ${opt.value}`;
                                            const original = originalOptions[index];

                                            // 1. Kiểm tra lịch bận của mentor
                                            const isBusy = busyTimes.includes(optTimeStr);

                                            // 2. Kiểm tra nếu là ngày hôm nay, loại bỏ những giờ đã qua
                                            let isPast = false;
                                            if (selectedDate === todayStr) {
                                                const [optHour, optMin] = opt.value.split(':').map(Number);
                                                const optDateTime = new Date(now.getFullYear(), now.getMonth(), now.getDate(), optHour, optMin);
                                                if (optDateTime <= now) {
                                                    isPast = true;
                                                }
                                            }

                                            if (isBusy) {
                                                opt.disabled = true;
                                                opt.text = original.text + " (Đã có lịch hẹn)";
                                            } else if (isPast) {
                                                opt.disabled = true;
                                                opt.text = original.text + " (Đã qua giờ)";
                                            } else {
                                                opt.disabled = false;
                                                opt.text = original.text;
                                            }
                                        });

                                        // Chọn option đầu tiên không bị disabled nếu option hiện tại bị disabled
                                        if (timeSelect.selectedOptions[0] && timeSelect.selectedOptions[0].disabled) {
                                            const firstAvailable = Array.from(timeSelect.options).find(opt => !opt.disabled);
                                            if (firstAvailable) {
                                                timeSelect.value = firstAvailable.value;
                                            } else {
                                                timeSelect.value = "";
                                            }
                                        }
                                    }

                                    dateInput.addEventListener("change", updateAvailableTimes);
                                    
                                    // Set mặc định ngày hôm nay và kích hoạt cập nhật giờ
                                    dateInput.value = "@DateTime.Now.ToString("yyyy-MM-dd")";
                                    updateAvailableTimes();
                                });
                            </script>
                        }
                    }
                }
            </div>
        </div>

    </div>
</section>
