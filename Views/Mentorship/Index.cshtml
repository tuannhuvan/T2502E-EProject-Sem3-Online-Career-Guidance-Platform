@model IEnumerable<Career_Guidance_Platform.Controllers.RankedMentorViewModel>
@{
    ViewData["Title"] = "Danh bạ Cố vấn học tập";
}

<section class="page-hero" style="background: radial-gradient(circle at top left, #e0e7ff 0%, transparent 40%), linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); border-bottom: 1px solid #e2e8f0; padding: 60px 24px; text-align: center;">
    <span class="page-badge" style="background: #eef2ff; color: #4f46e5; border: 1px solid #e0e7ff; padding: 6px 16px; border-radius: 999px; font-size: 13px; font-weight: 800; text-transform: uppercase;">🎓 Mentorship Platform</span>
    <h1 style="font-size: 40px; font-weight: 900; color: #0f172a; margin-top: 16px; margin-bottom: 12px; letter-spacing: -0.5px;">Kết nối Cố vấn chuyên môn</h1>
    <p style="color: #64748b; font-size: 17px; max-width: 650px; margin: 0 auto; line-height: 1.6;">Học hỏi từ các chuyên gia đầu ngành thông qua tư vấn 1-1, định hình lại con đường sự nghiệp và định hướng kỹ năng thực chiến.</p>
    <div style="margin-top: 20px;">
        <a href="/Mentor/Apply" class="btn primary-btn" style="text-decoration: none; padding: 10px 22px; font-size: 14px; font-weight: 700; border-radius: 12px; display: inline-flex; align-items: center; gap: 8px;">✨ Đăng ký làm Mentor</a>
    </div>
</section>

<section class="content-section" style="max-width: 1200px; margin: 0 auto; padding: 40px 24px;">
    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" style="background: #ecfdf5; border: 1px solid #d1fae5; color: #065f46; padding: 15px; border-radius: 12px; margin-bottom: 25px; font-size: 14px;">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info" style="background: #eff6ff; border: 1px solid #dbeafe; color: #1e40af; padding: 15px; border-radius: 12px; margin-bottom: 25px; font-size: 14px;">
            @TempData["Info"]
        </div>
    }
    
    <!-- Search and Filter Bar -->
    <div class="info-card" style="padding: 24px; border-radius: 20px; background: #ffffff; border: 1px solid #e2e8f0; box-shadow: 0 10px 30px rgba(0,0,0,0.02); margin-bottom: 40px;">
        <form method="get" asp-controller="Mentorship" asp-action="Index" style="display: grid; grid-template-columns: 2fr 1fr 1fr auto; gap: 15px; align-items: end;">
            <div>
                <label style="display: block; font-size: 13px; font-weight: 700; color: #475569; margin-bottom: 6px;">Tìm kiếm cố vấn</label>
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Nhập tên cố vấn, từ khóa chuyên môn..." style="width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 10px; font-size: 14px;" />
            </div>

            <div>
                <label style="display: block; font-size: 13px; font-weight: 700; color: #475569; margin-bottom: 6px;">Lọc theo Kỹ năng</label>
                <select name="skill" style="width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 10px; font-size: 14px; background: white;">
                    <option value="">-- Tất cả kỹ năng --</option>
                    @foreach (var s in ViewBag.Skills)
                    {
                        if (ViewBag.Skill == s)
                        {
                            <option value="@s" selected="selected">@s</option>
                        }
                        else
                        {
                            <option value="@s">@s</option>
                        }
                    }
                </select>
            </div>

            <div>
                <label style="display: block; font-size: 13px; font-weight: 700; color: #475569; margin-bottom: 6px;">Lọc theo Ngành nghề</label>
                <select name="careerPath" style="width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 10px; font-size: 14px; background: white;">
                    <option value="">-- Tất cả ngành --</option>
                    @foreach (var cp in ViewBag.CareerPathsList)
                    {
                        if (ViewBag.CareerPath == cp)
                        {
                            <option value="@cp" selected="selected">@cp</option>
                        }
                        else
                        {
                            <option value="@cp">@cp</option>
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn primary-btn" style="padding: 12px 24px; border-radius: 10px; font-weight: 700; height: 43px; display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
                🔍 Tìm kiếm
            </button>
        </form>
    </div>

    <!-- Actions bar for Mentees/Mentors -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h2 style="font-size: 24px; font-weight: 800; color: #0f172a; margin: 0;">Cố vấn được đề xuất nhiều nhất</h2>
        <div style="display: flex; gap: 12px;">
            <a asp-controller="Mentorship" asp-action="GroupSessions" class="btn secondary-btn" style="padding: 10px 20px; border-radius: 10px; font-weight: 700; text-decoration: none; font-size: 14px;">
                🗣️ Hội thảo Nhóm (Group Sessions)
            </a>

        </div>
    </div>

    <!-- Mentors Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 30px;">
        @if (Model != null && Model.Any())
        {
            foreach (var rMentor in Model)
            {
                var m = rMentor.Profile;
                <div class="info-card" style="padding: 32px; display: flex; flex-direction: column; justify-content: space-between; border-radius: 24px; border: 1px solid #e2e8f0; background: #ffffff; box-shadow: 0 4px 20px rgba(0,0,0,0.02); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='#4f46e5';" onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='#e2e8f0';">
                    <div>
                        <!-- Header with Avatar and Ranking Badge -->
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
                            <div style="width: 64px; height: 64px; border-radius: 20px; background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%); display: flex; align-items: center; justify-content: center; font-size: 32px; box-shadow: 0 8px 16px rgba(79, 70, 229, 0.1);">
                                👨‍🏫
                            </div>
                            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                                <span style="font-size: 13px; font-weight: 700; color: #f59e0b; background: #fef3c7; padding: 4px 10px; border-radius: 999px; display: inline-flex; align-items: center; gap: 4px;">
                                    ⭐ @rMentor.AverageRating.ToString("0.0") (@rMentor.TotalReviews đánh giá)
                                </span>
                                <span style="font-size: 11px; font-weight: 700; color: #10b981; background: #ecfdf5; padding: 2px 8px; border-radius: 6px;">
                                    Score: @rMentor.RankScore.ToString("0.00")
                                </span>
                            </div>
                        </div>

                        <!-- Info -->
                        <h3 style="font-size: 22px; color: #0f172a; margin: 0 0 6px; font-weight: 800;">@m.User?.FullName</h3>
                        <div style="font-size: 14.5px; font-weight: 700; color: #4f46e5; margin-bottom: 16px;">
                            @m.JobTitle @(string.IsNullOrEmpty(m.Company) ? "" : $"tại {m.Company}")
                        </div>

                        <p style="font-size: 14px; color: #64748b; line-height: 1.6; margin-bottom: 20px; min-height: 70px;">
                            @if (!string.IsNullOrEmpty(m.Biography) && m.Biography.Length > 150)
                            {
                                @(m.Biography.Substring(0, 147) + "...")
                            }
                            else
                            {
                                @m.Biography
                            }
                        </p>

                        <!-- Expertise Badges -->
                        <div style="margin-bottom: 24px;">
                            <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                                @if (!string.IsNullOrEmpty(m.Specialization))
                                {
                                    foreach (var spec in m.Specialization.Split(",").Select(s => s.Trim()))
                                    {
                                        <span style="font-size: 11.5px; font-weight: 600; color: #475569; background: #f8fafc; padding: 4px 10px; border-radius: 8px; border: 1px solid #e2e8f0;">
                                            @spec
                                        </span>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Footer Action -->
                    <div style="border-top: 1px solid #f1f5f9; padding-top: 20px; display: flex; justify-content: space-between; align-items: center; margin-top: auto;">
                        <div>
                            @if (rMentor.IsRecommended)
                            {
                                <span style="font-size: 11.5px; font-weight: 700; color: #4f46e5; background: #eef2ff; padding: 6px 12px; border-radius: 8px;" title="Cố vấn có các kỹ năng bạn đang đăng ký học hoặc đặt mục tiêu">
                                    🎯 Trùng khớp: @(string.Join(", ", rMentor.MatchedSkills))
                                </span>
                            }
                            else
                            {
                                <span style="font-size: 11.5px; font-weight: 700; color: #64748b; background: #f1f5f9; padding: 6px 12px; border-radius: 8px;">
                                    💡 Sẵn sàng cố vấn
                                </span>
                            }
                        </div>
                        
                        <a asp-controller="Mentorship" asp-action="Details" asp-route-id="@m.UserId" class="btn primary-btn" style="padding: 10px 22px; border-radius: 12px; font-weight: 700; text-decoration: none; font-size: 13.5px; display: inline-flex; align-items: center; gap: 6px; background: #4f46e5; border-color: #4f46e5; color: white;">
                            Xem chi tiết ➔
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="info-card" style="grid-column: 1 / -1; text-align: center; padding: 60px; border-radius: 24px; border: 1px dashed #cbd5e1; background: #f8fafc;">
                <span style="font-size: 48px; display: block; margin-bottom: 16px;">🧭</span>
                <h4 style="font-size: 18px; color: #475569; margin-bottom: 8px;">Không tìm thấy Cố vấn</h4>
                <p style="color: #64748b; font-style: italic; margin: 0;">Vui lòng thử tìm kiếm với các từ khóa hoặc chuyên môn khác.</p>
            </div>
        }
    </div>
</section>
