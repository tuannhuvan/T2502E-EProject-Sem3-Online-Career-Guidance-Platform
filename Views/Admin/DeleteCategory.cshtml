@model Career_Guidance_Platform.Models.Category

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Delete Category";
}

<div class="page-header d-print-none mb-3">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Management</div>
            <h2 class="page-title">Delete Category</h2>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h3 class="card-title text-danger">Are you sure you want to delete this category?</h3>
        <p class="text-muted">This action cannot be undone. Category details:</p>
        
        <dl class="row my-4">
            <dt class="col-sm-3 font-weight-bold">Name:</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3 font-weight-bold">Description:</dt>
            <dd class="col-sm-9">@(Model.Description ?? "No description")</dd>

            <dt class="col-sm-3 font-weight-bold">Status:</dt>
            <dd class="col-sm-9">
                @(Model.Status == 1 ? "Active" : "Inactive")
            </dd>
        </dl>

        <form asp-action="DeleteCategory" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Yes, Delete Category</button>
            <a asp-action="Categories" class="btn btn-link link-secondary">Cancel</a>
        </form>
    </div>
</div>
