@model Career_Guidance_Platform.Models.CareerPath

@{
    ViewData["Title"] = "Thêm Career Path";
    Layout = "_AdminLayout";
}

<div class="page-header d-print-none">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">Thêm Career Path</h2>
            <div class="text-muted mt-1">Tạo lộ trình nghề nghiệp mới và thiết lập các giai đoạn phát triển</div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs" data-bs-toggle="tabs">
            <li class="nav-item">
                <a href="#tab-basic" class="nav-link active" data-bs-toggle="tab">
                    <i class="ti ti-info-circle me-1"></i> Thông tin cơ bản
                </a>
            </li>
            <li class="nav-item">
                <a href="#tab-skills" class="nav-link" data-bs-toggle="tab">
                    <i class="ti ti-bulb me-1"></i> Kỹ năng yêu cầu chung
                </a>
            </li>
            <li class="nav-item">
                <a href="#tab-stages" class="nav-link" data-bs-toggle="tab">
                    <i class="ti ti-timeline me-1"></i> Các giai đoạn & Kỹ năng
                </a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <!-- TAB 1: BASIC INFO -->
            <div class="tab-pane active show" id="tab-basic">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label required">Tên Career Path</label>
                        <input type="text" id="path-title" class="form-control" placeholder="Ví dụ: Software Engineer" value="@Model.Title" />
                        <span class="text-danger small id-error-title" style="display:none;">Tên Lộ trình không được để trống</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label required">Danh mục ngành nghề</label>
                        <select id="path-category" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span class="text-danger small id-error-category" style="display:none;">Vui lòng chọn danh mục</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Lộ trình cha (Parent Path)</label>
                        <select id="path-parent" class="form-select" asp-items="ViewBag.ParentPaths">
                            <option value="">-- Lộ trình cấp cao nhất (Không có) --</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Trạng thái hoạt động</label>
                        <select id="path-status" class="form-select">
                            <option value="1">Đang hoạt động (Active)</option>
                            <option value="0">Tạm dừng (Inactive)</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Lương khởi điểm (Min)</label>
                        <div class="input-group">
                            <input type="number" id="path-salary-min" class="form-control" placeholder="0" value="@Model.SalaryMin" />
                            <span class="input-group-text">VND</span>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Lương tối đa (Max)</label>
                        <div class="input-group">
                            <input type="number" id="path-salary-max" class="form-control" placeholder="0" value="@Model.SalaryMax" />
                            <span class="input-group-text">VND</span>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Triển vọng nghề nghiệp (%)</label>
                        <div class="input-group">
                            <input type="number" step="0.1" id="path-outlook" class="form-control" placeholder="0" value="@Model.JobOutlook" />
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nội dung mô tả lộ trình</label>
                    <textarea id="path-content" class="form-control" rows="8" placeholder="Giới thiệu chung về lộ trình phát triển sự nghiệp này...">@Model.Content</textarea>
                </div>
            </div>

            <!-- TAB 2: GENERAL SKILLS -->
            <div class="tab-pane" id="tab-skills">
                <div class="card-title mb-2">Chọn các kỹ năng cần thiết cho toàn bộ lộ trình nghề nghiệp này:</div>
                <div class="input-icon mb-3">
                    <span class="input-icon-addon">
                        <i class="ti ti-search"></i>
                    </span>
                    <input type="text" id="skill-search" class="form-control" placeholder="Tìm kiếm kỹ năng bằng tên hoặc phân loại..." onkeyup="filterPathSkills()">
                </div>
                <div class="table-responsive border rounded-3 bg-white" style="max-height: 480px; overflow-y: auto;">
                    <table class="table table-vcenter card-table align-middle" id="skills-table">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width: 50px;">Chọn</th>
                                <th>Tên Kỹ Năng</th>
                                <th>Phân loại</th>
                                <th>Độ khó</th>
                                <th style="width: 220px;">Mức độ quan trọng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var skill in (IEnumerable<Career_Guidance_Platform.Models.Skill>)ViewBag.Skills)
                            {
                                <tr class="skill-row" data-name="@skill.Name.ToLower()" data-type="@skill.SkillType.ToLower()">
                                    <td>
                                        <input type="checkbox" class="form-check-input skill-chk" data-id="@skill.Id" onchange="togglePathSkill(@skill.Id, this.checked)" />
                                    </td>
                                    <td>
                                        <strong class="text-dark">@skill.Name</strong>
                                        <div class="text-muted small">@skill.Description</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-blue-lite text-blue">@skill.SkillType</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-orange-lite text-orange">@skill.Difficulty</span>
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm skill-importance" data-id="@skill.Id" style="display: none;" onchange="updatePathSkillImportance(@skill.Id, this.value)">
                                            <option value="Required">Bắt buộc (Required)</option>
                                            <option value="Preferred">Ưu tiên (Preferred)</option>
                                            <option value="Optional">Không bắt buộc (Optional)</option>
                                        </select>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- TAB 3: STAGES & STAGE SKILLS -->
            <div class="tab-pane" id="tab-stages">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h4 class="mb-0">Các giai đoạn phát triển lộ trình</h4>
                        <div class="text-muted small">Tạo các cột mốc nghề nghiệp tương ứng với các giai đoạn từ thấp đến cao</div>
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="addStage()">
                        <i class="ti ti-plus me-1"></i>Thêm Giai Đoạn
                    </button>
                </div>

                <div id="stages-container">
                    <!-- Stages cards will be rendered dynamically by JavaScript -->
                </div>
            </div>
        </div>
    </div>
    
    <div class="card-footer bg-light d-flex justify-content-between align-items-center">
        <div id="message-container"></div>
        <div class="d-flex gap-2">
            <button type="button" id="btn-save" class="btn btn-primary" onclick="saveCareerPath()">
                <i class="ti ti-device-floppy me-1"></i>Lưu Lộ Trình
            </button>
            <a asp-controller="Admin" asp-action="CareerPaths" class="btn btn-secondary">
                Quay lại
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // HTML Escaping Utility to prevent XSS issues in input fields
        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // Available skills from ViewBag
        const allSkills = @Html.Raw(Json.Serialize(((IEnumerable<Career_Guidance_Platform.Models.Skill>)ViewBag.Skills).Select(s => new {
            id = s.Id,
            name = s.Name,
            type = s.SkillType,
            difficulty = s.Difficulty
        })));

        // Initial empty arrays for Create page
        let stages = [];
        let pathSkills = [];

        // Dynamic Stage Management
        function renderStages() {
            const container = document.getElementById('stages-container');
            container.innerHTML = '';
            
            // Sort stages by sequenceOrder
            stages.sort((a, b) => a.sequenceOrder - b.sequenceOrder);
            
            if (stages.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-5 border border-dashed rounded-3 bg-light text-muted">
                        <i class="ti ti-timeline fs-1 mb-2"></i>
                        <p class="mb-0">Chưa có giai đoạn phát triển nào được thiết lập cho lộ trình này.</p>
                        <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addStage()">
                            <i class="ti ti-plus me-1"></i>Thêm Giai Đoạn Đầu Tiên
                        </button>
                    </div>
                `;
                return;
            }
            
            stages.forEach((stage, index) => {
                const card = document.createElement('div');
                card.className = 'card mb-3 border-start border-start-width-3 border-primary shadow-sm';
                
                // Render stage skills
                let skillsHtml = '';
                if (stage.skills.length === 0) {
                    skillsHtml = '<div class="text-muted small py-2">Chưa gán kỹ năng nào cho giai đoạn này.</div>';
                } else {
                    skillsHtml = `
                        <div class="table-responsive">
                            <table class="table table-vcenter table-sm card-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Tên Kỹ Năng</th>
                                        <th style="width: 180px;">Trình độ yêu cầu</th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${stage.skills.map((stageSkill, skillIdx) => {
                                        const skillInfo = allSkills.find(s => s.id == stageSkill.skillId);
                                        if (!skillInfo) return '';
                                        return `
                                            <tr>
                                                <td>
                                                    <div class="font-weight-medium text-dark">${skillInfo.name}</div>
                                                    <div class="text-muted small">${skillInfo.type} - Đợ khó: ${skillInfo.difficulty}</div>
                                                </td>
                                                <td>
                                                    <select class="form-select form-select-sm" onchange="updateStageSkillProficiency(${index}, ${skillIdx}, this.value)">
                                                        <option value="Basic" ${stageSkill.proficiencyRequired === 'Basic' ? 'selected' : ''}>Cơ bản (Basic)</option>
                                                        <option value="Intermediate" ${stageSkill.proficiencyRequired === 'Intermediate' ? 'selected' : ''}>Trung cấp (Intermediate)</option>
                                                        <option value="Advanced" ${stageSkill.proficiencyRequired === 'Advanced' ? 'selected' : ''}>Nâng cao (Advanced)</option>
                                                    </select>
                                                </td>
                                                <td class="text-end">
                                                    <button type="button" class="btn btn-sm btn-icon btn-ghost-danger border-0" onclick="removeSkillFromStage(${index}, ${skillIdx})" title="Xóa kỹ năng">
                                                        <i class="ti ti-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        `;
                                    }).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                }
                
                // Dropdown of skills not currently selected for this stage
                const availableSkillsForStage = allSkills.filter(s => !stage.skills.some(ss => ss.skillId == s.id));
                let addSkillSelectHtml = '';
                if (availableSkillsForStage.length > 0) {
                    addSkillSelectHtml = `
                        <div class="input-group input-group-flat input-group-sm" style="max-width: 350px;">
                            <select class="form-select form-select-sm select-add-skill-${index}">
                                <option value="">-- Chọn kỹ năng để gán --</option>
                                ${availableSkillsForStage.map(s => `<option value="${s.id}">${s.name} (${s.type})</option>`).join('')}
                            </select>
                            <span class="input-group-text p-0">
                                <button type="button" class="btn btn-primary btn-sm px-3" style="border-radius: 0 4px 4px 0;" onclick="addSkillToStage(${index})">
                                    Thêm
                                </button>
                            </span>
                        </div>
                    `;
                } else {
                    addSkillSelectHtml = '<span class="text-muted small">Tất cả kỹ năng đều đã được thêm.</span>';
                }
                
                card.innerHTML = `
                    <div class="card-header bg-light py-2 px-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-2">
                            <span class="avatar avatar-xs bg-primary text-white rounded-circle font-weight-bold" style="width:20px; height:20px; font-size:11px;">${index + 1}</span>
                            <input type="text" class="form-control form-control-sm font-weight-bold" style="width: 280px; font-size: 14px;" value="${escapeHtml(stage.title)}" onchange="updateStageTitle(${index}, this.value)" placeholder="Tên giai đoạn (ví dụ: Junior Developer)">
                        </div>
                        <div class="d-flex gap-1">
                            <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" onclick="moveStageUp(${index})" ${index === 0 ? 'disabled' : ''} title="Di chuyển lên">
                                <i class="ti ti-arrow-narrow-up"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" onclick="moveStageDown(${index})" ${index === stages.length - 1 ? 'disabled' : ''} title="Di chuyển xuống">
                                <i class="ti ti-arrow-narrow-down"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-icon btn-outline-danger" onclick="deleteStage(${index})" title="Xóa giai đoạn">
                                <i class="ti ti-trash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-3">
                        <div class="mb-3">
                            <label class="form-label small font-weight-bold text-muted mb-1">Mô tả mục tiêu & công việc của giai đoạn</label>
                            <textarea class="form-control form-control-sm" rows="2" onchange="updateStageDescription(${index}, this.value)" placeholder="Nhập tóm tắt công việc phát triển hoặc mục tiêu chuyên môn đạt được trong giai đoạn này...">${escapeHtml(stage.description || '')}</textarea>
                        </div>
                        <div class="border rounded-2 p-2 bg-light-lt">
                            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                <span class="font-weight-bold text-dark small"><i class="ti ti-checklist me-1"></i>Các kỹ năng bắt buộc đạt được trong giai đoạn này</span>
                                ${addSkillSelectHtml}
                            </div>
                            ${skillsHtml}
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function addStage() {
            stages.push({
                id: 0,
                title: 'Giai đoạn mới',
                description: '',
                sequenceOrder: stages.length + 1,
                skills: []
            });
            renderStages();
        }

        function updateStageTitle(stageIndex, val) {
            stages[stageIndex].title = val;
        }

        function updateStageDescription(stageIndex, val) {
            stages[stageIndex].description = val;
        }

        function deleteStage(stageIndex) {
            if (confirm('Bạn có chắc muốn xóa giai đoạn này và các kỹ năng liên kết?')) {
                stages.splice(stageIndex, 1);
                // Reorder sequence indices
                stages.forEach((stage, idx) => {
                    stage.sequenceOrder = idx + 1;
                });
                renderStages();
            }
        }

        function moveStageUp(index) {
            if (index > 0) {
                const temp = stages[index];
                stages[index] = stages[index - 1];
                stages[index - 1] = temp;
                
                stages[index].sequenceOrder = index + 1;
                stages[index - 1].sequenceOrder = index;
                renderStages();
            }
        }

        function moveStageDown(index) {
            if (index < stages.length - 1) {
                const temp = stages[index];
                stages[index] = stages[index + 1];
                stages[index + 1] = temp;
                
                stages[index].sequenceOrder = index + 1;
                stages[index + 1].sequenceOrder = index + 2;
                renderStages();
            }
        }

        function addSkillToStage(stageIndex) {
            const selectEl = document.querySelector(`.select-add-skill-${stageIndex}`);
            const skillIdVal = selectEl.value;
            if (!skillIdVal) return;
            
            const skillId = parseInt(skillIdVal);
            stages[stageIndex].skills.push({
                skillId: skillId,
                proficiencyRequired: 'Basic'
            });
            renderStages();
        }

        function removeSkillFromStage(stageIndex, skillIndex) {
            stages[stageIndex].skills.splice(skillIndex, 1);
            renderStages();
        }

        function updateStageSkillProficiency(stageIndex, skillIndex, val) {
            stages[stageIndex].skills[skillIndex].proficiencyRequired = val;
        }

        // General CareerPath Skills Management
        function togglePathSkill(skillId, isChecked) {
            const importanceSelect = document.querySelector(`.skill-importance[data-id="${skillId}"]`);
            if (isChecked) {
                importanceSelect.style.display = 'block';
                if (!pathSkills.some(s => s.skillId == skillId)) {
                    pathSkills.push({ skillId: skillId, importanceLevel: importanceSelect.value });
                }
            } else {
                importanceSelect.style.display = 'none';
                pathSkills = pathSkills.filter(s => s.skillId != skillId);
            }
        }

        function updatePathSkillImportance(skillId, importanceLevel) {
            const skill = pathSkills.find(s => s.skillId == skillId);
            if (skill) {
                skill.importanceLevel = importanceLevel;
            }
        }

        function filterPathSkills() {
            const query = document.getElementById('skill-search').value.toLowerCase();
            const rows = document.querySelectorAll('.skill-row');
            rows.forEach(row => {
                const name = row.getAttribute('data-name');
                const type = row.getAttribute('data-type');
                if (name.includes(query) || type.includes(query)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        // Document Ready / Initialization
        document.addEventListener('DOMContentLoaded', function() {
            renderStages();
        });

        // AJAX Save
        function saveCareerPath() {
            const title = document.getElementById('path-title').value.trim();
            const categoryIdVal = document.getElementById('path-category').value;
            
            // Client-side Validation
            let hasError = false;
            document.querySelector('.id-error-title').style.display = 'none';
            document.querySelector('.id-error-category').style.display = 'none';

            if (!title) {
                document.querySelector('.id-error-title').style.display = 'block';
                hasError = true;
            }
            if (!categoryIdVal) {
                document.querySelector('.id-error-category').style.display = 'block';
                hasError = true;
            }

            if (hasError) {
                const triggerTabBasic = document.querySelector('a[href="#tab-basic"]');
                const tab = new bootstrap.Tab(triggerTabBasic);
                tab.show();
                return;
            }

            const parentIdVal = document.getElementById('path-parent').value;
            const status = parseInt(document.getElementById('path-status').value);
            const salaryMin = parseFloat(document.getElementById('path-salary-min').value) || 0;
            const salaryMax = parseFloat(document.getElementById('path-salary-max').value) || 0;
            const outlook = parseFloat(document.getElementById('path-outlook').value) || 0;
            const content = document.getElementById('path-content').value;

            const dto = {
                id: 0, // 0 for Create
                title: title,
                categoryId: parseInt(categoryIdVal),
                parentPathId: parentIdVal ? parseInt(parentIdVal) : null,
                content: content,
                salaryMin: salaryMin,
                salaryMax: salaryMax,
                jobOutlook: outlook,
                status: status,
                skills: pathSkills,
                stages: stages
            };

            const btnSave = document.getElementById('btn-save');
            btnSave.disabled = true;
            btnSave.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Đang lưu...';

            const msgContainer = document.getElementById('message-container');
            msgContainer.innerHTML = '';

            fetch('/Admin/SaveCareerPath', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(dto)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    msgContainer.innerHTML = `<div class="text-success small font-weight-bold"><i class="ti ti-circle-check me-1"></i>${data.message} Đang chuyển hướng...</div>`;
                    setTimeout(() => {
                        window.location.href = '/Admin/CareerPaths';
                    }, 1200);
                } else {
                    btnSave.disabled = false;
                    btnSave.innerHTML = '<i class="ti ti-device-floppy me-1"></i>Lưu Lộ Trình';
                    msgContainer.innerHTML = `<div class="text-danger small font-weight-bold"><i class="ti ti-circle-x me-1"></i>Lưu thất bại: ${data.message}</div>`;
                }
            })
            .catch(err => {
                btnSave.disabled = false;
                btnSave.innerHTML = '<i class="ti ti-device-floppy me-1"></i>Lưu Lộ Trình';
                msgContainer.innerHTML = `<div class="text-danger small font-weight-bold"><i class="ti ti-circle-x me-1"></i>Đã có lỗi hệ thống: ${err}</div>`;
            });
        }
    </script>
}