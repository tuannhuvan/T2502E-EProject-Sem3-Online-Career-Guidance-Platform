@model Career_Guidance_Platform.Models.Question
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Career Tests";
}

<h2 class="page-title mb-3">Career Tests</h2>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Career Test Questions</h3>
        <div class="card-actions">
            <a href="#" class="btn btn-primary">Add Question</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table card-table table-vcenter">
            <thead>
            <tr>
                <th>Question</th>
                <th>Group</th>
                <th>Answers</th>
                <th>Status</th>
            </tr>
            </thead>

            <tbody>
            <tr>
                <td>Bạn thích hoạt động nào nhất?</td>
                <td>Interest</td>
                <td>4</td>
                <td><span class="badge bg-green-lt">Active</span></td>
            </tr>

            <tr>
                <td>Bạn tự tin nhất với kỹ năng nào?</td>
                <td>Skill</td>
                <td>4</td>
                <td><span class="badge bg-green-lt">Active</span></td>
            </tr>
            </tbody>
        </table>
    </div>
</div>