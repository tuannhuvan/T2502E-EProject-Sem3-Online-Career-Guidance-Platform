@model Career_Guidance_Platform.Models.CareerEvent
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh sửa Sự kiện";
}

<div class="page-header d-print-none mb-3">
    <div class="row g-2 align-items-center">
        <div class="col">
            <h2 class="page-title">Chỉnh sửa Sự kiện: @Model.Title</h2>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="EditEvent" asp-route-id="@Model.Id" method="post" class="card">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label required">Tên sự kiện</label>
                    <input type="text" asp-for="Title" class="form-control" required />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label required">Diễn giả (Speaker)</label>
                    <input type="text" asp-for="Speaker" class="form-control" required />
                    <span asp-validation-for="Speaker" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Mô tả sự kiện</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label required">Thời gian diễn ra</label>
                        <input type="datetime-local" asp-for="EventDate" class="form-control" value="@Model.EventDate.ToString("yyyy-MM-ddTHH:mm")" required />
                        <span asp-validation-for="EventDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label required">Số lượng người tham gia tối đa (Capacity)</label>
                        <input type="number" asp-for="MaxParticipants" class="form-control" min="1" required />
                        <span asp-validation-for="MaxParticipants" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Địa điểm tổ chức</label>
                    <input type="text" asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Link đăng ký ngoài (Không bắt buộc)</label>
                    <input type="text" asp-for="RegistrationUrl" class="form-control" />
                    <span asp-validation-for="RegistrationUrl" class="text-danger"></span>
                </div>
            </div>

            <div class="card-footer text-end">
                <a asp-action="Events" class="btn btn-link">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>
