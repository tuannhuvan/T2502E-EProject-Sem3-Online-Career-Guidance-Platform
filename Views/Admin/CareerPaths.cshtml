@model IEnumerable<Career_Guidance_Platform.Models.CareerPath>

@{
    ViewData["Title"] = "Quản lý Career Paths";
    Layout = "_AdminLayout";
}

<div class="page-header d-print-none">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">Quản lý Career Paths</h2>
            <div class="text-muted mt-1">Danh sách lộ trình nghề nghiệp trong hệ thống</div>
        </div>
        <div class="col-auto">
            <a asp-controller="Admin" asp-action="CreateCareerPath" class="btn btn-primary">
                <i class="ti ti-plus me-1"></i>
                Thêm Career Path
            </a>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>Career Path</th>
                <th>Category</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        <strong>@item.Title</strong>
                        <div class="text-muted small">
                            @(item.Content?.Length > 120 ? item.Content.Substring(0, 120) + "..." : item.Content)
                        </div>
                    </td>
                    <td>@item.Category?.Name</td>
                    <td>
                        @if (item.Status == 1)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-controller="CareerPath"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-info">
                            View
                        </a>

                        <a asp-controller="Admin"
                           asp-action="EditCareerPath"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <form asp-controller="Admin"
                              asp-action="DeleteCareerPath"
                              asp-route-id="@item.Id"
                              method="post"
                              style="display:inline;"
                              onsubmit="return confirm('Bạn có chắc muốn xóa Career Path này?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>