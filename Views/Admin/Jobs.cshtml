@model IEnumerable<Career_Guidance_Platform.Models.JobPosting>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Jobs";
}

<div class="page-header d-print-none mb-3">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Management</div>
            <h2 class="page-title">Job Listings</h2>
        </div>
        <div class="col-auto ms-auto">
            <a asp-controller="Admin" asp-action="CreateJob" class="btn btn-primary">
                <i class="ti ti-plus me-1"></i> Add Job
            </a>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-9">
                <input id="job-search" class="form-control"
                       placeholder="Tìm kiếm theo tiêu đề, công ty, lộ trình nghề nghiệp hoặc địa điểm..." />
            </div>

            <div class="col-md-3">
                <select id="status-select" class="form-select">
                    <option value="">Tất cả trạng thái</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table card-table table-vcenter">
            <thead>
            <tr>
                <th>Job Title</th>
                <th>Company</th>
                <th>Career Path</th>
                <th>Location / Experience</th>
                <th>Type</th>
                <th>Salary</th>
                <th>Deadline</th>
                <th>Status</th>
                <th width="150" class="text-end">Actions</th>
            </tr>
            </thead>

            <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var job in Model)
                {
                    <tr class="job-row"
                        data-title="@job.Title?.ToLower()"
                        data-company="@job.CompanyName?.ToLower()"
                        data-careerpath="@job.CareerPath?.Title?.ToLower()"
                        data-location="@job.Location?.ToLower()"
                        data-status="@(job.Status == 1 ? "active" : "inactive")">
                        <td><strong>@job.Title</strong></td>
                        <td>@job.CompanyName</td>
                        <td>
                            @if (job.CareerPath != null)
                            {
                                <span class="badge bg-purple-lt">@job.CareerPath.Title</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            <div class="small">Loc: @(job.Location ?? "N/A")</div>
                            <div class="small text-muted">Exp: @(job.ExperienceLevel ?? "N/A")</div>
                        </td>
                        <td><span class="badge bg-blue-lt">@job.JobType</span></td>
                        <td>@job.Salary.ToString("N0") VND</td>
                        <td>@(job.ExpiredAt?.ToString("dd/MM/yyyy") ?? "No Deadline")</td>
                        <td>
                            @if (job.Status == 1)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-controller="Admin" asp-action="EditJob" asp-route-id="@job.Id" class="btn btn-sm btn-outline-primary me-1">
                                Edit
                            </a>
                            <form asp-controller="Admin" asp-action="DeleteJob" asp-route-id="@job.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this job posting?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted py-3">No jobs found in database.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex align-items-center justify-content-between">
        <span id="entryText">
            Showing 1 to 10 of @(Model?.Count() ?? 0) entries
        </span>
        <ul class="pagination m-0 ms-auto" id="pagination-ul">
        </ul>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const searchInput = document.getElementById('job-search');
            const statusSelect = document.getElementById('status-select');
            const rows = document.querySelectorAll('.job-row');

            let currentPage = 1;
            const pageSize = 10;

            function filterAndPaginateJobs(resetPage = false) {
                if (resetPage === true) {
                    currentPage = 1;
                }

                const query = searchInput.value.toLowerCase().trim();
                const status = statusSelect.value;

                const matchedRows = [];

                rows.forEach(row => {
                    const title = row.getAttribute('data-title') || '';
                    const company = row.getAttribute('data-company') || '';
                    const careerpath = row.getAttribute('data-careerpath') || '';
                    const location = row.getAttribute('data-location') || '';
                    const jobStatus = row.getAttribute('data-status') || '';

                    const matchesSearch = !query || 
                        title.includes(query) || 
                        company.includes(query) || 
                        careerpath.includes(query) || 
                        location.includes(query);

                    const matchesStatus = !status || jobStatus === status;

                    if (matchesSearch && matchesStatus) {
                        matchedRows.push(row);
                    } else {
                        row.style.display = 'none';
                    }
                });

                const totalItems = matchedRows.length;
                const totalPages = Math.ceil(totalItems / pageSize) || 1;

                if (currentPage > totalPages) {
                    currentPage = totalPages;
                }

                const startIdx = (currentPage - 1) * pageSize;
                const endIdx = startIdx + pageSize;

                matchedRows.forEach((row, index) => {
                    if (index >= startIdx && index < endIdx) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });

                // Update entry text
                const startEntry = totalItems === 0 ? 0 : startIdx + 1;
                const endEntry = Math.min(endIdx, totalItems);
                document.getElementById('entryText').innerHTML = `Hiển thị từ ${startEntry} đến ${endEntry} trong số ${totalItems} công việc`;

                // Render pagination
                const paginationUl = document.getElementById('pagination-ul');
                if (paginationUl) {
                    paginationUl.innerHTML = '';

                    // Prev Button
                    const prevLi = document.createElement('li');
                    prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
                    prevLi.innerHTML = `<a class="page-link" href="#" tabindex="-1" aria-disabled="${currentPage === 1}"><i class="ti ti-chevron-left"></i> prev</a>`;
                    if (currentPage > 1) {
                        prevLi.querySelector('a').addEventListener('click', function(e) {
                            e.preventDefault();
                            currentPage--;
                            filterAndPaginateJobs();
                        });
                    }
                    paginationUl.appendChild(prevLi);

                    // Page buttons
                    const maxButtons = 5;
                    let startPage = Math.max(1, currentPage - Math.floor(maxButtons / 2));
                    let endPage = Math.min(totalPages, startPage + maxButtons - 1);
                    if (endPage - startPage + 1 < maxButtons) {
                        startPage = Math.max(1, endPage - maxButtons + 1);
                    }

                    for (let i = startPage; i <= endPage; i++) {
                        const li = document.createElement('li');
                        li.className = `page-item ${currentPage === i ? 'active' : ''}`;
                        li.innerHTML = `<a class="page-link" href="#">${i}</a>`;
                        li.querySelector('a').addEventListener('click', function(e) {
                            e.preventDefault();
                            currentPage = i;
                            filterAndPaginateJobs();
                        });
                        paginationUl.appendChild(li);
                    }

                    // Next Button
                    const nextLi = document.createElement('li');
                    nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
                    nextLi.innerHTML = `<a class="page-link" href="#">next <i class="ti ti-chevron-right"></i></a>`;
                    if (currentPage < totalPages) {
                        nextLi.querySelector('a').addEventListener('click', function(e) {
                            e.preventDefault();
                            currentPage++;
                            filterAndPaginateJobs();
                        });
                    }
                    paginationUl.appendChild(nextLi);
                }
            }

            searchInput.addEventListener('input', () => filterAndPaginateJobs(true));
            statusSelect.addEventListener('change', () => filterAndPaginateJobs(true));

            // Initial run
            filterAndPaginateJobs(true);
        });
    </script>
}