@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Jobs";
}

<h2 class="page-title mb-3">Jobs</h2>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Job Listings</h3>
        <div class="card-actions">
            <a href="#" class="btn btn-primary">Add Job</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table card-table table-vcenter">
            <thead>
            <tr>
                <th>Job</th>
                <th>Company</th>
                <th>Type</th>
                <th>Deadline</th>
                <th>Status</th>
            </tr>
            </thead>

            <tbody>
            <tr>
                <td>Junior .NET Developer</td>
                <td>ABC Technology</td>
                <td>Full-time</td>
                <td>30/06/2026</td>
                <td><span class="badge bg-green-lt">Active</span></td>
            </tr>

            <tr>
                <td>UI/UX Intern</td>
                <td>Creative Studio</td>
                <td>Internship</td>
                <td>25/06/2026</td>
                <td><span class="badge bg-green-lt">Active</span></td>
            </tr>
            </tbody>
        </table>
    </div>
</div>