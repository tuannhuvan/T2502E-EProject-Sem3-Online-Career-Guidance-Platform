@model Career_Guidance_Platform.Models.Goal

@{
    ViewData["Title"] = "Xóa Goal";
    Layout = "_AdminLayout";
}

<div class="page-body">
    <div class="container-xl">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title text-danger">Xóa Goal</h3>
            </div>

            <div class="card-body">
                <p>Bạn có chắc muốn xóa Goal này không?</p>

                <div class="alert alert-warning">
                    <strong>@Model.Title</strong><br />
                    User: @Model.Student?.FullName<br />
                    Career Path: @(Model.CareerPath?.Title ?? "-")
                </div>

                <form asp-action="DeleteGoal" method="post">
                    <input type="hidden" asp-for="Id" />

                    <button class="btn btn-danger">Xóa</button>
                    <a asp-action="Goals" class="btn btn-secondary">Hủy</a>
                </form>
            </div>
        </div>
    </div>
</div>