@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="page-header d-print-none mb-3">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Overview</div>
            <h2 class="page-title">Career Guidance Dashboard</h2>
        </div>
        <div class="col-auto ms-auto">
            <a href="#" class="btn btn-primary">
                <i class="ti ti-download me-1"></i>
                Export Report
            </a>
        </div>
    </div>
</div>

<div class="row row-deck row-cards">
    <div class="col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Total Users</div>
                <div class="h1 mb-2">@ViewBag.TotalUsers</div>
                <div class="text-success"><i class="ti ti-trending-up"></i> Registered members</div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Mentors</div>
                <div class="h1 mb-2">@ViewBag.TotalMentors</div>
                <div class="text-muted">@ViewBag.VerifiedMentors verified mentors</div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Career Tests</div>
                <div class="h1 mb-2">@ViewBag.TotalTests</div>
                <div class="text-success">Completed tests</div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Jobs Posted</div>
                <div class="h1 mb-2">@ViewBag.TotalJobs</div>
                <div class="text-muted">Active job listings</div>
            </div>
        </div>
    </div>
</div>

<div class="row row-cards mt-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Career Test Analytics</h3>
            </div>

            <div class="card-body">
                <canvas id="careerChart" height="110"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Top Careers</h3>
            </div>

            <div class="list-group list-group-flush">
                @{
                    var labels = ViewBag.PathLabels as List<string>;
                    var counts = ViewBag.PathCounts as List<int>;
                }
                @if (labels != null && counts != null && labels.Count > 0)
                {
                    for (int i = 0; i < labels.Count; i++)
                    {
                        <div class="list-group-item d-flex justify-content-between">
                            @labels[i] <span class="badge bg-blue-lt">@counts[i]</span>
                        </div>
                    }
                }
                else
                {
                    <div class="list-group-item text-muted text-center py-3">No career test data available.</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        <h3 class="card-title">Recent Test Results</h3>
    </div>

    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
            <tr>
                <th>User</th>
                <th>Top Career</th>
                <th>Score</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
            </thead>

            <tbody>
            @{
                var recentResults = ViewBag.RecentResults as List<TestResult>;
            }
            @if (recentResults != null && recentResults.Any())
            {
                foreach (var tr in recentResults)
                {
                    <tr>
                        <td>@(tr.User?.FullName ?? "Anonymous")</td>
                        <td>@(tr.RecommendedCareerPath?.Title ?? "None")</td>
                        <td><span class="badge bg-green-lt">@((tr.CompatibilityScore ?? 0).ToString("0"))%</span></td>
                        <td><span class="badge bg-blue-lt">@(tr.Status == 1 ? "Completed" : "Pending")</span></td>
                        <td>@tr.DateTaken.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-3">No test results found.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    new Chart(document.getElementById("careerChart"), {
        type: "bar",
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.PathLabels ?? new List<string>())),
            datasets: [{
                label: "Career Match Count",
                data: @Html.Raw(Json.Serialize(ViewBag.PathCounts ?? new List<int>())),
                borderWidth: 1,
                backgroundColor: 'rgba(32, 107, 196, 0.1)',
                borderColor: 'rgba(32, 107, 196, 1)'
            }]
        },
        options: {
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    });
</script>
}