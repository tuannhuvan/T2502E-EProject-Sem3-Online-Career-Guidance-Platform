@model Career_Guidance_Platform.Models.Goal

@{
    ViewData["Title"] = "Sửa Goal";
    Layout = "_AdminLayout";
}

<div class="page-body">
    <div class="container-xl">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Sửa Goal</h3>
            </div>

            <div class="card-body">
                <form asp-action="EditGoal" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="StudentId" />

                    <div class="mb-3">
                        <label class="form-label">Tên Goal</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Loại Goal</label>
                        <select asp-for="GoalType" class="form-select">
                            <option value="ShortTerm">Ngắn hạn</option>
                            <option value="LongTerm">Dài hạn</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Career Path</label>
                        <select asp-for="CareerPathId" asp-items="ViewBag.CareerPaths" class="form-select">
                            <option value="">-- Không chọn --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Progress</label>
                        <input asp-for="Progress" type="number" min="0" max="100" class="form-control" />
                        <span asp-validation-for="Progress" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Deadline</label>
                        <input asp-for="TargetDate" type="date" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="1">Active</option>
                            <option value="0">Inactive</option>
                            <option value="3">Deleted</option>
                        </select>
                    </div>

                    <button class="btn btn-primary">Cập nhật</button>
                    <a asp-action="Goals" class="btn btn-secondary">Quay lại</a>
                </form>
            </div>
        </div>
    </div>
</div>