@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Reports";
}

<h2 class="page-title mb-3">Reports</h2>

<div class="row row-cards">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">User Growth</h3>
            </div>
            <div class="card-body">
                <canvas id="userGrowthChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Mentor Bookings</h3>
            </div>
            <div class="card-body">
                <canvas id="bookingChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    new Chart(document.getElementById("userGrowthChart"), {
        type: "line",
        data: {
            labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
            datasets: [{
                label: "Users",
                data: [120, 180, 260, 420, 760, 1240]
            }]
        }
    });

    new Chart(document.getElementById("bookingChart"), {
        type: "bar",
        data: {
            labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
            datasets: [{
                label: "Bookings",
                data: [12, 28, 40, 64, 88, 120]
            }]
        }
    });
</script>
}