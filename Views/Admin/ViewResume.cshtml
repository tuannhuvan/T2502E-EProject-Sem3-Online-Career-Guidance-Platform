@model Career_Guidance_Platform.Models.Resume
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Hồ sơ CV: " + Model.Title;
}

<div class="page-header d-print-none mb-3">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Ứng viên: @(Model.User?.FullName ?? Model.User?.Email)</div>
            <h2 class="page-title">CV: @Model.Title</h2>
        </div>
        <div class="col-auto ms-auto d-flex gap-2">
            <a asp-controller="Admin" asp-action="JobApplications" class="btn btn-outline-secondary">
                <i class="ti ti-arrow-left me-1"></i> Trở về danh sách ứng tuyển
            </a>
            <button type="button" class="btn btn-primary" onclick="window.print()">
                <i class="ti ti-printer me-1"></i> In / Xuất PDF
            </button>
        </div>
    </div>
</div>

<div class="card mb-3 print-hide">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <span class="fw-bold">Ứng viên:</span> @(Model.User?.FullName) (@(Model.User?.Email))
            <span class="ms-3 text-muted">Ngày tạo: @Model.CreatedAt.ToString("dd/MM/yyyy")</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <label for="templateSelect" class="fw-bold mb-0">Mẫu hiển thị:</label>
            <select id="templateSelect" class="form-select form-select-sm" style="width: 200px;">
                <option value="modern" selected>Modern Indigo</option>
                <option value="minimalist">Minimalist Classic</option>
                <option value="professional">Professional Sidebar</option>
            </select>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-4 bg-light d-flex justify-content-center">
        <div id="cvPreview" class="cv-preview modern shadow bg-white p-4" style="width: 100%; max-width: 850px; min-height: 1100px; border-radius: 8px;">
            <!-- Rendered CV content -->
        </div>
    </div>
</div>

<script id="savedCvJson" type="application/json">@Html.Raw(Model.ContentJson)</script>

<style>
    .cv-preview.modern h1 { color: #4f46e5; font-size: 28px; font-weight: 800; margin-bottom: 4px; }
    .cv-preview.modern .section-title { color: #4f46e5; border-bottom: 2px solid #e0e7ff; font-weight: 700; font-size: 16px; margin-top: 20px; margin-bottom: 10px; padding-bottom: 4px; }
    
    .cv-preview.minimalist h1 { color: #0f172a; font-size: 26px; font-weight: 700; border-bottom: 2px solid #0f172a; padding-bottom: 10px; }
    .cv-preview.minimalist .section-title { color: #0f172a; font-weight: 700; font-size: 15px; margin-top: 18px; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }

    .cv-preview.professional h1 { color: #0284c7; font-size: 28px; font-weight: 800; }
    .cv-preview.professional .section-title { color: #0284c7; font-weight: 700; font-size: 16px; border-left: 4px solid #0284c7; padding-left: 8px; margin-top: 20px; margin-bottom: 10px; }

    @@media print {
        .page-header, .print-hide, navbar, header, footer { display: none !important; }
        body { background: white !important; }
        .card { border: none !important; box-shadow: none !important; }
        .card-body { padding: 0 !important; background: white !important; }
        #cvPreview { max-width: 100% !important; box-shadow: none !important; border: none !important; padding: 0 !important; }
    }
</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rawJson = document.getElementById('savedCvJson')?.textContent || '{}';
            let cvData = {};
            try {
                cvData = JSON.parse(rawJson);
            } catch (e) {
                console.error("Invalid CV JSON", e);
            }

            const cvPreview = document.getElementById('cvPreview');
            const templateSelect = document.getElementById('templateSelect');

            function renderCV(template) {
                if (!cvPreview) return;
                cvPreview.className = `cv-preview ${template} shadow bg-white p-4`;

                const personal = cvData.personal || {};
                const summary = cvData.summary || '';
                const experiences = cvData.experiences || [];
                const education = cvData.education || [];
                const skills = cvData.skills || [];
                const projects = cvData.projects || [];
                const certs = cvData.certifications || [];

                let html = `
                    <div class="cv-header mb-4">
                        <h1>${personal.fullName || 'Họ và tên chưa cập nhật'}</h1>
                        <div class="text-primary fw-bold mb-2 fs-5">${personal.title || ''}</div>
                        <div class="d-flex flex-wrap gap-3 text-muted small">
                            ${personal.email ? `<span><i class="ti ti-mail"></i> ${personal.email}</span>` : ''}
                            ${personal.phone ? `<span><i class="ti ti-phone"></i> ${personal.phone}</span>` : ''}
                            ${personal.address ? `<span><i class="ti ti-map-pin"></i> ${personal.address}</span>` : ''}
                            ${personal.linkedin ? `<span><i class="ti ti-brand-linkedin"></i> ${personal.linkedin}</span>` : ''}
                        </div>
                    </div>
                `;

                if (summary) {
                    html += `
                        <div class="cv-section mb-3">
                            <div class="section-title">Giới thiệu bản thân</div>
                            <p class="text-secondary" style="line-height: 1.6;">${summary}</p>
                        </div>
                    `;
                }

                if (experiences.length > 0) {
                    html += `
                        <div class="cv-section mb-3">
                            <div class="section-title">Kinh nghiệm làm việc</div>
                            ${experiences.map(exp => `
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between font-weight-bold">
                                        <span class="fw-bold text-dark">${exp.position || ''} - ${exp.company || ''}</span>
                                        <span class="text-muted small">${exp.startDate || ''} - ${exp.endDate || 'Hiện tại'}</span>
                                    </div>
                                    <div class="text-secondary small mt-1">${exp.description || ''}</div>
                                </div>
                            `).join('')}
                        </div>
                    `;
                }

                if (education.length > 0) {
                    html += `
                        <div class="cv-section mb-3">
                            <div class="section-title">Học vấn</div>
                            ${education.map(edu => `
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-bold text-dark">${edu.degree || ''} - ${edu.school || ''}</span>
                                        <span class="text-muted small">${edu.year || ''}</span>
                                    </div>
                                    <div class="text-secondary small">${edu.details || ''}</div>
                                </div>
                            `).join('')}
                        </div>
                    `;
                }

                if (skills.length > 0) {
                    html += `
                        <div class="cv-section mb-3">
                            <div class="section-title">Kỹ năng chuyên môn</div>
                            <div class="d-flex flex-wrap gap-2">
                                ${skills.map(skill => `<span class="badge bg-light text-dark border px-2 py-1">${skill}</span>`).join('')}
                            </div>
                        </div>
                    `;
                }

                if (projects.length > 0) {
                    html += `
                        <div class="cv-section mb-3">
                            <div class="section-title">Dự án tiêu biểu</div>
                            ${projects.map(proj => `
                                <div class="mb-2">
                                    <div class="fw-bold text-dark">${proj.name || ''}</div>
                                    <div class="text-secondary small">${proj.description || ''}</div>
                                </div>
                            `).join('')}
                        </div>
                    `;
                }

                if (certs.length > 0) {
                    html += `
                        <div class="cv-section mb-3">
                            <div class="section-title">Chứng chỉ</div>
                            <ul class="mb-0 ps-3 small text-secondary">
                                ${certs.map(c => `<li>${c}</li>`).join('')}
                            </ul>
                        </div>
                    `;
                }

                cvPreview.innerHTML = html;
            }

            renderCV(templateSelect ? templateSelect.value : 'modern');

            if (templateSelect) {
                templateSelect.addEventListener('change', function () {
                    renderCV(this.value);
                });
            }
        });
    </script>
}
