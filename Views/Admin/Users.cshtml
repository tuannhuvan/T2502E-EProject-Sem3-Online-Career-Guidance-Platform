@model IEnumerable<Career_Guidance_Platform.Models.User>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Users";
}

<div class="page-header d-print-none mb-3">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Management</div>
            <h2 class="page-title">Users</h2>
        </div>

        <div class="col-auto ms-auto">
            <button class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#userModal"
                    onclick="openAddUserModal()">
                <i class="ti ti-plus me-1"></i>
                Add User
            </button>
        </div>
    </div>
</div>

<div class="card">

    <div class="card-body border-bottom py-3">
        <div class="row g-2">

            <div class="col-md-4">
                <input id="searchInput"
                       class="form-control"
                       placeholder="Search user..."
                       onkeyup="filterUsers()" />
            </div>

            <div class="col-md-3">
                <select id="roleFilter"
                        class="form-select"
                        onchange="filterUsers()">
                    <option value="">All Roles</option>
                    <option value="User">User</option>
                    <option value="Mentor">Mentor</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>

            <div class="col-md-3">
                <select id="statusFilter"
                        class="form-select"
                        onchange="filterUsers()">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Pending">Pending</option>
                    <option value="Blocked">Blocked</option>
                </select>
            </div>

            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100"
                        onclick="filterUsers()">
                    Filter
                </button>
            </div>

        </div>
    </div>

    <div class="table-responsive">

        <table class="table table-vcenter card-table">

            <thead>
            <tr>
                <th width="40">
                    <input type="checkbox" class="form-check-input">
                </th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th width="150">Actions</th>
            </tr>
            </thead>

            <tbody id="userTableBody">
            @if (Model != null && Model.Any())
            {
                foreach (var user in Model)
                {
                    var displayRole = user.Role == "Student" ? "User" : user.Role;
                    var displayStatus = user.Status == 1 ? "Active" : (user.Status == 2 ? "Pending" : "Blocked");
                    var badgeClass = user.Status == 1 ? "bg-green-lt" : (user.Status == 2 ? "bg-yellow-lt" : "bg-red-lt");
                    <tr class="user-row">
                        <td>
                            <input type="checkbox" class="form-check-input">
                        </td>
                        <td class="user-name">@user.FullName</td>
                        <td class="user-email">@user.Email</td>
                        <td class="user-role">@displayRole</td>
                        <td>
                            <span class="badge @badgeClass">@displayStatus</span>
                        </td>
                        <td class="table-actions">
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    data-id="@user.Id"
                                    data-fullname="@user.FullName"
                                    data-email="@user.Email"
                                    data-role="@displayRole"
                                    data-status="@displayStatus"
                                    data-bs-toggle="modal"
                                    data-bs-target="#userModal"
                                    onclick="openEditUserModal(this)">
                                Edit
                            </button>

                            <button class="btn btn-sm btn-outline-danger"
                                    onclick="deleteUser(@user.Id)">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-3">No users found in database.</td>
                </tr>
            }
            </tbody>

        </table>

    </div>

    <div class="card-footer">
        <span id="entryText">
            Showing 1 to @(Model?.Count() ?? 0) entries
        </span>
    </div>

</div>

<!-- Modal -->

<div class="modal modal-blur fade"
     id="userModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title"
                    id="modalTitle">
                    Add User
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden"
                       id="editingUserId">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Full Name
                        </label>

                        <input id="fullNameInput"
                               class="form-control">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Email
                        </label>

                        <input id="emailInput"
                               type="email"
                               class="form-control">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Role
                        </label>

                        <select id="roleInput"
                                class="form-select">
                            <option>User</option>
                            <option>Mentor</option>
                            <option>Admin</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Status
                        </label>

                        <select id="statusInput"
                                class="form-select">
                            <option>Active</option>
                            <option>Pending</option>
                            <option>Blocked</option>
                        </select>
                    </div>

                    <div class="col-12 mb-3" id="passwordGroup">
                        <label class="form-label">
                            Password <span class="text-muted">(Default: User@123456)</span>
                        </label>
                        <input id="passwordInput"
                               type="password"
                               class="form-control"
                               placeholder="Enter password or leave blank for default">
                    </div>



                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-primary"
                        onclick="saveUser()">
                    Save User
                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script src="~/js/admin/users.js"></script>
}